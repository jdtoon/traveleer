# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Uses ASP.NET Core __ (double underscore) convention for nested keys.
# DO NOT commit .env to source control.
# =============================================================================

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=8080

# --- Site ---
Site__BaseUrl=https://myapp.com
Site__Name=My SaaS App
Site__SupportEmail=support@myapp.com

# --- Database ---
ConnectionStrings__CoreDatabase=Data Source=/app/db/core.db
ConnectionStrings__AuditDatabase=Data Source=/app/db/audit.db
Tenancy__DatabasePath=/app/db/tenants

# --- Super Admin ---
SuperAdmin__Email=admin@myapp.com

# --- Email ---
Email__Provider=SES
Email__FromAddress=noreply@myapp.com
Email__SES__AccessKey=AKIA_xxxxx
Email__SES__SecretKey=xxxxx
Email__SES__Region=eu-west-1

# --- Billing (Paystack) ---
Billing__Provider=Paystack
Billing__Paystack__SecretKey=sk_live_xxxxx
Billing__Paystack__PublicKey=pk_live_xxxxx
Billing__Paystack__WebhookSecret=whsec_xxxxx
Billing__Paystack__CallbackBaseUrl=https://myapp.com

# --- Bot Protection (Cloudflare Turnstile) ---
Turnstile__Provider=Cloudflare
Turnstile__SiteKey=0x4AAAAAAA_xxxxx
Turnstile__SecretKey=0x4AAAAAAA_xxxxx

# --- Feature Flags ---
FeatureFlags__AllEnabledLocally=false

# --- Storage (Cloudflare R2) ---
Storage__Provider=R2
Storage__R2Bucket=saas-uploads
Storage__R2Endpoint=https://<account-id>.r2.cloudflarestorage.com
Storage__R2AccessKey=xxxxx
Storage__R2SecretKey=xxxxx
Storage__R2PublicUrl=https://assets.myapp.com

# --- Litestream / Cloudflare R2 ---
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=saas-backups

# --- Backup Module ---
Backup__LitestreamConfigPath=/app/db/litestream.yml
Backup__SentinelPath=/app/db/.litestream-reload
Backup__R2Bucket=saas-backups
Backup__R2Endpoint=https://<account-id>.r2.cloudflarestorage.com
