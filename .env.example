# =============================================================================
# Environment Variables for docker-compose.yml
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Uses ASP.NET Core __ (double underscore) convention for nested keys.
# DO NOT commit .env to source control.
#
# Usage:
#   Dev:        docker compose up                        (uses defaults below)
#   Production: docker compose --profile production up   (requires .env)
# =============================================================================

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production            # Development | Production
APP_PORT=8080

# --- Site ---
Site__BaseUrl=https://myapp.com              # REQUIRED — public URL (no trailing slash)
Site__Name=My SaaS App
Site__SupportEmail=support@myapp.com

# --- Super Admin ---
SuperAdmin__Email=admin@myapp.com            # REQUIRED — email that can access /super-admin

# --- Email ---
Email__Provider=MailerSend                   # Console | Smtp | MailerSend
Email__FromAddress=noreply@myapp.com
Email__FromName=My SaaS App
Email__MailerSend__ApiToken=
# SMTP settings (when Email__Provider=Smtp):
# Email__Smtp__Host=smtp.gmail.com
# Email__Smtp__Port=587
# Email__Smtp__Username=
# Email__Smtp__Password=
# Email__Smtp__UseSsl=true

# --- Billing (Paystack) ---
Billing__Provider=Paystack                   # Mock | Paystack
Billing__Paystack__SecretKey=sk_live_xxxxx
Billing__Paystack__PublicKey=pk_live_xxxxx
Billing__Paystack__WebhookSecret=whsec_xxxxx
Billing__Paystack__CallbackBaseUrl=https://myapp.com

# --- Bot Protection (Cloudflare Turnstile) ---
Turnstile__Provider=Cloudflare               # Mock | Cloudflare
Turnstile__SiteKey=0x4AAAAAAA_xxxxx
Turnstile__SecretKey=0x4AAAAAAA_xxxxx

# --- Storage (Cloudflare R2) ---
Storage__Provider=R2                         # Local | R2
Storage__LocalBasePath=/app/db/uploads
Storage__R2Bucket=saas-uploads
Storage__R2Endpoint=https://<account-id>.r2.cloudflarestorage.com
Storage__R2AccessKey=xxxxx
Storage__R2SecretKey=xxxxx
Storage__R2PublicUrl=https://assets.myapp.com

# --- Litestream / Backup (Cloudflare R2) ---
# These are used by both the app (to generate litestream.yml) and the
# litestream sidecar container (for S3 auth).
R2_ACCESS_KEY_ID=xxxxx                       # REQUIRED for Litestream
R2_SECRET_ACCESS_KEY=xxxxx                   # REQUIRED for Litestream
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=saas-backups

# --- Litestream automation tuning ---
Litestream__Enabled=true
Litestream__AutoRestoreEnabled=true
Litestream__KeyBackupEnabled=true
Litestream__KeyBackupInterval=1h

# --- Messaging (InMemory | RabbitMQ) ---
Messaging__Provider=RabbitMQ                 # InMemory | RabbitMQ
Messaging__RabbitMQ__Host=rabbitmq
Messaging__RabbitMQ__Username=guest          # CHANGE in production
Messaging__RabbitMQ__Password=guest          # CHANGE in production

# --- Caching (Memory | Redis) ---
Caching__Provider=Redis                      # Memory | Redis
Caching__Redis__ConnectionString=redis:6379

# --- Hangfire (InMemory | SQLite) ---
Hangfire__Storage=SQLite                     # InMemory | SQLite
Hangfire__SQLitePath=/app/db/hangfire.db
Hangfire__WorkerCount=2

# --- Seq (structured logging) ---
Seq__Url=http://seq:5341

# --- Health Check ---
HealthCheck__AllowedIPs=                     # Comma-separated IPs (empty = allow all)

# --- Rate Limiting ---
RateLimiting__GlobalPerMinute=100
RateLimiting__StrictPerMinute=5
RateLimiting__RegistrationPerWindow=3
RateLimiting__RegistrationWindowMinutes=5

# --- Dev Seeding (ignored when ASPNETCORE_ENVIRONMENT != Development) ---
DevSeed__Enabled=false
DevSeed__TenantSlug=demo
DevSeed__AdminEmail=admin@demo.local
DevSeed__MemberEmail=member@demo.local
DevSeed__PlanSlug=starter

# --- Port Overrides (infra services bound to 127.0.0.1) ---
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
SEQ_PORT=5341
SEQ_UI_PORT=8081
KUMA_PORT=3001
