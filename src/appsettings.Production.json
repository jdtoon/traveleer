{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "saas": "Information"
    }
  },
  "Email": {
    "Provider": "MailerSend"
  },
  "Billing": {
    "Provider": "Paystack",
    "Currency": "ZAR",
    "Tax": {
      "Rate": 0.15,
      "Label": "VAT",
      "Included": true
    },
    "Invoice": {
      "Prefix": "INV",
      "PaymentTermDays": 7
    },
    "GracePeriod": {
      "Days": 3,
      "DunningAttempts": 3,
      "DunningIntervalHours": 72
    },
    "Features": {
      "AnnualBilling": true,
      "PerSeatBilling": false,
      "UsageBilling": false,
      "AddOns": false,
      "Discounts": true,
      "SetupFees": false
    }
  },
  "Turnstile": {
    "Provider": "Cloudflare"
  },
  "Storage": {
    "Provider": "R2"
  },
  "Litestream": {
    "Enabled": true
  },
  "HealthCheck": {
    "AllowedIPs": ""
  },
  "Hangfire": {
    "Storage": "SQLite",
    "WorkerCount": 2
  },
  "Caching": {
    "MemoryCacheSizeLimit": 50000
  },
  "RateLimiting": {
    "GlobalPerMinute": 60,
    "StrictPerMinute": 3,
    "RegistrationPerWindow": 2,
    "RegistrationWindowMinutes": 10,
    "ContactPerWindow": 2,
    "ContactWindowMinutes": 10,
    "WebhookPerMinute": 100
  }
}
