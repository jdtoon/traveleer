{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "saas": "Information"
    }
  },
  "Email": {
    "Provider": "MailerSend"
  },
  "Billing": {
    "Provider": "Paystack"
  },
  "Turnstile": {
    "Provider": "Cloudflare"
  },
  "FeatureFlags": {
    "AllEnabledLocally": false
  },
  "Storage": {
    "Provider": "R2"
  },
  "Backup": {
    "Enabled": true
  },
  "HealthCheck": {
    "AllowedIPs": ""
  },
  "Hangfire": {
    "Storage": "InMemory",
    "WorkerCount": 2
  },
  "RateLimiting": {
    "GlobalPerMinute": 60,
    "StrictPerMinute": 3,
    "RegistrationPerWindow": 2,
    "RegistrationWindowMinutes": 10,
    "ContactPerWindow": 2,
    "ContactWindowMinutes": 10,
    "WebhookPerMinute": 100
  }
}
