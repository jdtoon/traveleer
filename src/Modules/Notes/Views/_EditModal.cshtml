@model Note

<dialog class="modal modal-open">
    <div class="modal-box">
        <form hx-post="@Url.Action("Edit", new { id = Model.Id })" hx-target="#modal-container">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">Edit Note</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">✕</button>
            </div>
            
            <div class="form-control w-full">
                <label class="label" for="Title">
                    <span class="label-text">Title</span>
                </label>
                <input type="text" id="Title" name="Title" 
                       class="input input-bordered w-full" 
                       value="@Model.Title" required autofocus />
            </div>
            
            <div class="form-control w-full mt-4">
                <label class="label" for="Content">
                    <span class="label-text">Content</span>
                </label>
                <textarea id="Content" name="Content" 
                          class="textarea textarea-bordered w-full" 
                          rows="4">@Model.Content</textarea>
            </div>
            
            <div class="modal-action">
                <button type="button" class="btn" onclick="this.closest('.modal').classList.remove('modal-open')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="this.closest('.modal').classList.remove('modal-open')">close</button>
    </form>
</dialog>
