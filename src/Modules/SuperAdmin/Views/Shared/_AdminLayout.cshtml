<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Super Admin</title>

    <!-- DaisyUI + Tailwind CSS -->
    <link rel="stylesheet" href="/css/styles.css" asp-append-version="true" />

    <!-- Swap.Htmx CSS -->
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
</head>
<body data-theme="business" class="min-h-screen bg-base-100 text-base-content">
    <!-- Drawer for mobile menu -->
    <div class="drawer lg:drawer-open">
        <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col">
            <!-- Navbar (mobile) -->
            <div class="navbar bg-base-100 border-b border-base-300 lg:hidden">
                <div class="flex-none">
                    <label for="mobile-drawer" class="btn btn-square btn-ghost drawer-button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </label>
                </div>
                <div class="flex-1">
                    <span class="text-xl font-bold">Super Admin</span>
                </div>
            </div>

            <!-- Main Content -->
            <main class="flex-1 p-4 md:p-6 overflow-auto" id="main-content">
                @RenderBody()
            </main>
        </div>

        <!-- Sidebar -->
        <div class="drawer-side z-40">
            <label for="mobile-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="bg-neutral text-neutral-content w-64 min-h-full flex flex-col">
                <!-- Brand -->
                <div class="p-4 border-b border-neutral-focus">
                    <span class="text-xl font-bold">🛡️ Super Admin</span>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 p-4">
                    <ul class="menu menu-md gap-1">
                        <li>
                            <swap-nav to="/super-admin" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                Dashboard
                            </swap-nav>
                        </li>
                        <li>
                            <swap-nav to="/super-admin/tenants" class="@(ViewContext.RouteData.Values["action"]?.ToString() is "Tenants" or "TenantDetail" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                                Tenants
                            </swap-nav>
                        </li>
                        <li>
                            <swap-nav to="/super-admin/plans" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Plans" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                                Plans
                            </swap-nav>
                        </li>
                        <li>
                            <swap-nav to="/super-admin/features" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Features" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Features
                            </swap-nav>
                        </li>
                        <li>
                            <swap-nav to="/super-admin/backups" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Backups" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" />
                                </svg>
                                Backups
                            </swap-nav>
                        </li>
                    </ul>
                </nav>

                <!-- Footer -->
                <div class="p-4 border-t border-neutral-focus">
                    <form asp-controller="SuperAdminAuth" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-ghost btn-sm w-full justify-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            Sign Out
                        </button>
                    </form>
                </div>
            </aside>
        </div>
    </div>

    <!-- Modal container -->
    <div id="modal-container"></div>

    <!-- Scripts -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
    <script src="/js/bundle.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
