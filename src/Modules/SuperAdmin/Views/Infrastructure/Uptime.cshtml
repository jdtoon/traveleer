@{
    ViewData["Title"] = "Uptime";
    var uptimeUrl = (string?)ViewBag.UptimeKumaUrl;
    var hasUptime = !string.IsNullOrEmpty(uptimeUrl);
    // Uptime Kuma is reverse-proxied through our app to bypass X-Frame-Options
    var proxyBase = "/super-admin/proxy/uptime";
}

<div class="flex flex-col gap-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold">Uptime Monitoring</h1>
            <p class="opacity-60">Service availability tracking via Uptime Kuma</p>
        </div>
        @if (hasUptime)
        {
            <a href="@proxyBase/" target="_blank" class="btn btn-ghost btn-sm gap-1">
                Open Uptime Kuma
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
            </a>
        }
    </div>

    @if (!hasUptime)
    {
        <div class="alert alert-info shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <div class="font-bold">Uptime Kuma Not Configured</div>
                <div class="text-sm">To enable the uptime dashboard, set <code class="text-xs bg-base-300 px-1 rounded">Infrastructure:UptimeKumaUrl</code> in your configuration (e.g. <code class="text-xs bg-base-300 px-1 rounded">http://uptime-kuma:3001</code>).</div>
            </div>
        </div>
    }
    else
    {
        <!-- Setup Guidance -->
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-4">
                <h2 class="card-title text-base mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                    Suggested Monitors
                </h2>
                <div class="text-sm opacity-70">Configure these monitors in Uptime Kuma for comprehensive coverage:</div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 mt-3">
                    <div class="flex items-center gap-2 text-sm">
                        <span class="badge badge-sm badge-success">HTTP</span>
                        <span>App Health (<code class="text-xs bg-base-300 px-1 rounded">/health</code>)</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm">
                        <span class="badge badge-sm badge-success">HTTP</span>
                        <span>Marketing Site (<code class="text-xs bg-base-300 px-1 rounded">/</code>)</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm">
                        <span class="badge badge-sm badge-info">TCP</span>
                        <span>Redis (<code class="text-xs bg-base-300 px-1 rounded">:6379</code>)</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm">
                        <span class="badge badge-sm badge-info">TCP</span>
                        <span>RabbitMQ (<code class="text-xs bg-base-300 px-1 rounded">:5672</code>)</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm">
                        <span class="badge badge-sm badge-success">HTTP</span>
                        <span>Seq (<code class="text-xs bg-base-300 px-1 rounded">:8081</code>)</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm">
                        <span class="badge badge-sm badge-success">HTTP</span>
                        <span>Hangfire (<code class="text-xs bg-base-300 px-1 rounded">/super-admin/hangfire</code>)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Embedded Uptime Kuma (proxied) -->
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-0">
                <iframe src="@(proxyBase)/" class="w-full rounded" style="height: 750px;" loading="lazy" title="Uptime Kuma Dashboard"></iframe>
            </div>
        </div>

        <div class="text-xs opacity-40 text-center">
            Live updates require WebSocket. For full interactivity, <a href="@proxyBase/" target="_blank" class="link">open in a new tab</a>.
        </div>
    }
</div>
