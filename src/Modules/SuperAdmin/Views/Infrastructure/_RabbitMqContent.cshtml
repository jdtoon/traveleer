@model RabbitMqStatusModel?
@{
    var mgmtUrl = (string?)ViewBag.ManagementUrl;
}

@if (Model is null || !Model.IsConfigured)
{
    <!-- InMemory transport fallback -->
    <div class="alert alert-info shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
            <div class="font-bold">In-Memory Transport Active</div>
            <div class="text-sm">RabbitMQ is not configured. The application is using the built-in in-memory transport. To enable RabbitMQ, set <code class="text-xs bg-base-300 px-1 rounded">Messaging:Transport</code> to <code class="text-xs bg-base-300 px-1 rounded">RabbitMQ</code> in your configuration.</div>
        </div>
    </div>
}
else
{
    <!-- Connection Status -->
    @if (Model.IsReachable)
    {
        <div class="alert alert-success shadow-sm mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <span class="font-bold">Connected</span>
                <span class="text-sm opacity-70 ml-2">@Model.Host:@Model.Port · vhost: @(Model.VirtualHost ?? "/") · Provider: @Model.Provider</span>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-error shadow-sm mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
                <div class="font-bold">RabbitMQ Unreachable</div>
                <div class="text-sm">Cannot connect to @Model.Host:@Model.Port. Check the RabbitMQ container status.</div>
            </div>
        </div>
    }

    @if (Model.Overview is not null)
    {
        <!-- Overview Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
            <div class="stat bg-base-100 shadow-sm border border-base-300 rounded-box p-4">
                <div class="stat-title text-xs">Queues</div>
                <div class="stat-value text-lg">@Model.Overview.QueueCount</div>
            </div>
            <div class="stat bg-base-100 shadow-sm border border-base-300 rounded-box p-4">
                <div class="stat-title text-xs">Connections</div>
                <div class="stat-value text-lg">@Model.Overview.ConnectionCount</div>
            </div>
            <div class="stat bg-base-100 shadow-sm border border-base-300 rounded-box p-4">
                <div class="stat-title text-xs">Channels</div>
                <div class="stat-value text-lg">@Model.Overview.ChannelCount</div>
            </div>
            <div class="stat bg-base-100 shadow-sm border border-base-300 rounded-box p-4">
                <div class="stat-title text-xs">Consumers</div>
                <div class="stat-value text-lg">@Model.Overview.ConsumerCount</div>
            </div>
        </div>

        <!-- Messages & Rates -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
            <div class="card bg-base-100 shadow-sm border border-base-300">
                <div class="card-body p-4">
                    <h2 class="card-title text-base mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        Messages
                    </h2>
                    <div class="grid grid-cols-2 gap-4 text-center">
                        <div>
                            <div class="text-2xl font-bold">@Model.Overview.MessagesReady.ToString("N0")</div>
                            <div class="text-xs opacity-50">Ready</div>
                        </div>
                        <div>
                            <div class="text-2xl font-bold @(Model.Overview.MessagesUnacknowledged > 0 ? "text-warning" : "")">@Model.Overview.MessagesUnacknowledged.ToString("N0")</div>
                            <div class="text-xs opacity-50">Unacknowledged</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card bg-base-100 shadow-sm border border-base-300">
                <div class="card-body p-4">
                    <h2 class="card-title text-base mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                        Message Rates
                    </h2>
                    <div class="grid grid-cols-2 gap-4 text-center">
                        <div>
                            <div class="text-2xl font-bold">@Model.Overview.PublishRate.ToString("F1")</div>
                            <div class="text-xs opacity-50">Publish/sec</div>
                        </div>
                        <div>
                            <div class="text-2xl font-bold">@Model.Overview.DeliverRate.ToString("F1")</div>
                            <div class="text-xs opacity-50">Deliver/sec</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Embedded Management UI -->
    @if (!string.IsNullOrEmpty(mgmtUrl))
    {
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-4">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="card-title text-base">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Management Console
                    </h2>
                    <a href="@mgmtUrl" target="_blank" class="btn btn-ghost btn-xs gap-1">
                        Open in new tab
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>
                </div>
                <iframe src="@mgmtUrl" class="w-full rounded border border-base-300" style="height: 600px;" loading="lazy" title="RabbitMQ Management"></iframe>
            </div>
        </div>
    }
}
