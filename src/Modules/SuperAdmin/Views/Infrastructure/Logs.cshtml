@{
    ViewData["Title"] = "Logs";
    var seqUrl = (string?)ViewBag.SeqUrl;
    var hasSeq = !string.IsNullOrEmpty(seqUrl);
}

<div class="flex flex-col gap-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold">Logs</h1>
            <p class="opacity-60">Centralized structured logging via Seq</p>
        </div>
        @if (hasSeq)
        {
            <a href="@seqUrl" target="_blank" class="btn btn-ghost btn-sm gap-1">
                Open Seq
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
            </a>
        }
    </div>

    @if (!hasSeq)
    {
        <div class="alert alert-info shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <div class="font-bold">Seq Not Configured</div>
                <div class="text-sm">To enable the log viewer, set <code class="text-xs bg-base-300 px-1 rounded">Infrastructure:SeqUrl</code> in your configuration to the Seq UI address (e.g. <code class="text-xs bg-base-300 px-1 rounded">http://seq:8081</code>).</div>
            </div>
        </div>
    }
    else
    {
        <!-- Quick Filter Bar -->
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-3">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="text-xs font-semibold opacity-60 mr-1">Quick filters:</span>
                    <button class="btn btn-xs btn-ghost" onclick="setSeqFilter('')">All Events</button>
                    <button class="btn btn-xs btn-error btn-outline" onclick="setSeqFilter('?filter=%40Level%3D%27Error%27%20or%20%40Level%3D%27Fatal%27')">Errors Only</button>
                    <button class="btn btn-xs btn-warning btn-outline" onclick="setSeqFilter('?filter=%40Level%3D%27Warning%27%20or%20%40Level%3D%27Error%27%20or%20%40Level%3D%27Fatal%27')">Warnings+</button>
                    <div class="divider divider-horizontal mx-0"></div>
                    <button class="btn btn-xs btn-ghost" onclick="setSeqFilter('?range=1h')">Last 1h</button>
                    <button class="btn btn-xs btn-ghost" onclick="setSeqFilter('?range=24h')">Last 24h</button>
                    <button class="btn btn-xs btn-ghost" onclick="setSeqFilter('?range=7d')">Last 7d</button>
                </div>
            </div>
        </div>

        <!-- Embedded Seq UI -->
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-0">
                <iframe id="seq-iframe" src="@(seqUrl)/#/events" class="w-full rounded" style="height: 750px;" loading="lazy" title="Seq Log Viewer"></iframe>
            </div>
        </div>

        <script>
            function setSeqFilter(query) {
                var baseUrl = '@(seqUrl)';
                var iframe = document.getElementById('seq-iframe');
                iframe.src = baseUrl + '/#/events' + query;
            }
        </script>
    }
</div>
