@{
    ViewData["Title"] = "Add Admin";
}

<dialog class="modal modal-open">
    <div class="modal-box">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-lg">Add Super Admin</h3>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">✕</button>
        </div>
        <form hx-post="/super-admin/admins/invite" hx-target="#modal-container">
            <div class="form-control mb-3">
                <label class="label"><span class="label-text">Email</span></label>
                <input type="email" name="email" class="input input-bordered w-full" required placeholder="admin@example.com" />
            </div>
            <div class="form-control mb-4">
                <label class="label"><span class="label-text">Display Name</span></label>
                <input type="text" name="displayName" class="input input-bordered w-full" required placeholder="Jane Admin" />
            </div>
            <div class="modal-action">
                <button type="button" class="btn" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add Admin</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
