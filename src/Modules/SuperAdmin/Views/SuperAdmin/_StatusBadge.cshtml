@model saas.Data.Core.TenantStatus

@{
    var (badgeClass, label) = Model switch
    {
        saas.Data.Core.TenantStatus.Active => ("badge-success", "Active"),
        saas.Data.Core.TenantStatus.Suspended => ("badge-error", "Suspended"),
        saas.Data.Core.TenantStatus.PendingSetup => ("badge-warning", "Pending"),
        saas.Data.Core.TenantStatus.Cancelled => ("badge-ghost", "Cancelled"),
        _ => ("badge-ghost", Model.ToString())
    };
}

<span class="badge @badgeClass badge-sm">@label</span>
