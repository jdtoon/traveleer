@model TenantStatus

@{
    var (badgeClass, label) = Model switch
    {
        TenantStatus.Active => ("badge-success", "Active"),
        TenantStatus.Suspended => ("badge-error", "Suspended"),
        TenantStatus.PendingSetup => ("badge-warning", "Pending"),
        TenantStatus.Cancelled => ("badge-ghost", "Cancelled"),
        _ => ("badge-ghost", Model.ToString())
    };
}

<span class="badge @badgeClass badge-sm">@label</span>
