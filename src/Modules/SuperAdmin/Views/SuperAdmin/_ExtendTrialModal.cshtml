@model saas.Modules.SuperAdmin.Services.TenantDetailModel
@{
    ViewData["Title"] = "Extend Trial";
}

<div class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Extend Trial — @Model.Name</h3>
        <form hx-post="/super-admin/tenants/@Model.Id/extend-trial" hx-target="#modal-container">
            <div class="form-control mb-4">
                <label class="label"><span class="label-text">Additional Days</span></label>
                <input type="number" name="days" class="input input-bordered w-full" value="14" min="1" max="365" required />
                <label class="label"><span class="label-text-alt">Days to add to the current trial end date</span></label>
            </div>
            <div class="modal-action">
                <button type="submit" class="btn btn-primary btn-sm">Extend Trial</button>
                <button type="button" class="btn btn-ghost btn-sm"
                        hx-get="about:blank" hx-target="#modal-container" hx-swap="innerHTML">Cancel</button>
            </div>
        </form>
    </div>
    <div class="modal-backdrop" hx-get="about:blank" hx-target="#modal-container" hx-swap="innerHTML"></div>
</div>
