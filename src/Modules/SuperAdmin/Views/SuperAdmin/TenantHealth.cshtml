@model saas.Modules.SuperAdmin.Services.TenantHealthOverviewModel
@{
    ViewData["Title"] = "Tenant Health";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold">Tenant Health</h1>
        <p class="text-base-content/70 mt-1">Aggregated health overview across all tenants — users, sessions, database sizes, and status.</p>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        <div class="stat bg-base-200 rounded-box p-3">
            <div class="stat-title text-xs">Total Tenants</div>
            <div class="stat-value text-lg">@Model.TotalTenants</div>
        </div>
        <div class="stat bg-base-200 rounded-box p-3">
            <div class="stat-title text-xs">Active</div>
            <div class="stat-value text-lg text-success">@Model.ActiveTenants</div>
        </div>
        <div class="stat bg-base-200 rounded-box p-3">
            <div class="stat-title text-xs">Suspended</div>
            <div class="stat-value text-lg @(Model.SuspendedTenants > 0 ? "text-error" : "")">@Model.SuspendedTenants</div>
        </div>
        <div class="stat bg-base-200 rounded-box p-3">
            <div class="stat-title text-xs">Trialing</div>
            <div class="stat-value text-lg text-info">@Model.TrialingTenants</div>
        </div>
        <div class="stat bg-base-200 rounded-box p-3">
            <div class="stat-title text-xs">Total Users</div>
            <div class="stat-value text-lg">@Model.TotalUsers</div>
        </div>
        <div class="stat bg-base-200 rounded-box p-3">
            <div class="stat-title text-xs">Total Sessions</div>
            <div class="stat-value text-lg">@Model.TotalActiveSessions</div>
        </div>
    </div>

    <!-- Tenant Table -->
    <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
            <h2 class="card-title text-lg mb-4">All Tenants</h2>
            @if (Model.Tenants.Count == 0)
            {
                <p class="text-base-content/60">No tenants found.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Tenant</th>
                                <th>Status</th>
                                <th>Plan</th>
                                <th class="text-right">Users</th>
                                <th class="text-right">DB Size</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Tenants)
                            {
                                var statusClass = t.Status switch
                                {
                                    TenantStatus.Active => "badge-success",
                                    TenantStatus.Suspended => "badge-error",
                                    TenantStatus.PendingSetup => "badge-warning",
                                    _ => "badge-ghost"
                                };
                                <tr>
                                    <td>
                                        <div class="font-medium">@t.Name</div>
                                        <div class="text-xs opacity-60">/@t.Slug</div>
                                    </td>
                                    <td><span class="badge badge-sm @statusClass">@t.Status</span></td>
                                    <td class="text-sm">@t.PlanName</td>
                                    <td class="text-right">@t.UserCount</td>
                                    <td class="text-right font-mono text-sm">@t.DatabaseSizeFormatted</td>
                                    <td>
                                        <swap-nav to="/super-admin/tenants/@t.Id" class="btn btn-ghost btn-xs">View</swap-nav>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
