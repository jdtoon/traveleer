@model List<saas.Modules.SuperAdmin.Services.TenantListItem>

<div class="overflow-x-auto">
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Slug</th>
                <th>Email</th>
                <th>Plan</th>
                <th>Status</th>
                <th>Registered</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center opacity-60 py-8">No tenants found</td>
                </tr>
            }
            @foreach (var tenant in Model)
            {
                <tr class="hover">
                    <td class="font-medium">@tenant.Name</td>
                    <td class="opacity-70">@tenant.Slug</td>
                    <td class="opacity-70">@tenant.ContactEmail</td>
                    <td>@tenant.PlanName</td>
                    <td>
                        <partial name="_StatusBadge" model="tenant.Status" />
                    </td>
                    <td class="opacity-70">@tenant.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <swap-nav to="/super-admin/tenants/@tenant.Id" class="btn btn-ghost btn-xs">
                            View →
                        </swap-nav>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
