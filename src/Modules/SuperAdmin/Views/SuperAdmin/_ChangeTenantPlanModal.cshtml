@model saas.Modules.SuperAdmin.Services.TenantDetailModel
@{
    var plans = (List<Plan>)ViewData["Plans"]!;
}

<dialog class="modal modal-open">
    <div class="modal-box">
        <form hx-post="/super-admin/tenants/@Model.Id/change-plan" hx-target="#modal-container">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">Change Plan</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">✕</button>
            </div>

            <p class="text-sm opacity-60 mb-4">
                Change the plan for <strong>@Model.Name</strong> (currently on <strong>@Model.PlanName</strong>).
            </p>

            <div class="form-control w-full mb-4">
                <label class="label" for="planId"><span class="label-text">New Plan</span></label>
                <select id="planId" name="planId" class="select select-bordered w-full">
                    @foreach (var plan in plans)
                    {
                        var isSelected = plan.Id == Model.PlanId;
                        <option value="@plan.Id" selected="@isSelected">
                            @plan.Name — @plan.MonthlyPrice.ToString("C")/mo
                        </option>
                    }
                </select>
            </div>

            <div class="alert alert-warning text-sm mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <span>This will immediately change which features are available to this tenant based on the new plan's feature matrix.</span>
            </div>

            <div class="modal-action">
                <button type="button" class="btn" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary">Change Plan</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
