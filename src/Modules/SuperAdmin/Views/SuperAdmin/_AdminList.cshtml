@model List<saas.Modules.SuperAdmin.Services.SuperAdminListItem>

<div class="card bg-base-100 shadow-sm border border-base-300">
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-base-content/60">No admins configured.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Admin</th>
                            <th>Status</th>
                            <th>Last Login</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var admin in Model)
                        {
                            <tr>
                                <td>
                                    <div class="font-medium">@admin.DisplayName</div>
                                    <div class="text-xs opacity-60">@admin.Email</div>
                                </td>
                                <td>
                                    @if (admin.IsActive)
                                    {
                                        <span class="badge badge-success badge-sm">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-error badge-sm">Inactive</span>
                                    }
                                </td>
                                <td class="text-sm">@(admin.LastLoginAt?.ToString("g") ?? "Never")</td>
                                <td class="text-sm">@admin.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <button class="btn btn-ghost btn-xs"
                                            hx-post="/super-admin/admins/@admin.Id/toggle"
                                            hx-target="#admin-list"
                                            hx-confirm="@(admin.IsActive ? "Deactivate this admin?" : "Activate this admin?")">
                                        @(admin.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
