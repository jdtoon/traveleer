@model saas.Modules.SuperAdmin.Services.PlanEditModel

<dialog class="modal modal-open">
    <div class="modal-box">
        <form hx-post="/super-admin/plans" hx-target="#modal-container">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">@(Model.Id.HasValue ? "Edit Plan" : "New Plan")</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">✕</button>
            </div>

            @if (Model.Id.HasValue)
            {
                <input type="hidden" name="Id" value="@Model.Id" />
            }

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="form-control w-full">
                    <label class="label" for="Name"><span class="label-text">Name</span></label>
                    <input type="text" id="Name" name="Name" class="input input-bordered w-full"
                           value="@Model.Name" required autofocus />
                    <span asp-validation-for="Name" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label" for="Slug"><span class="label-text">Slug</span></label>
                    <input type="text" id="Slug" name="Slug" class="input input-bordered w-full"
                           value="@Model.Slug" required />
                    <span asp-validation-for="Slug" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full sm:col-span-2">
                    <label class="label" for="Description"><span class="label-text">Description</span></label>
                    <textarea id="Description" name="Description" class="textarea textarea-bordered w-full"
                              rows="2">@Model.Description</textarea>
                </div>

                <div class="form-control w-full">
                    <label class="label" for="MonthlyPrice"><span class="label-text">Monthly Price (ZAR)</span></label>
                    <input type="number" id="MonthlyPrice" name="MonthlyPrice" class="input input-bordered w-full"
                           value="@Model.MonthlyPrice" step="0.01" min="0" required />
                </div>

                @* Annual billing deferred — field hidden for now *@
                <input type="hidden" name="AnnualPrice" value="@Model.AnnualPrice" />

                <div class="form-control w-full">
                    <label class="label" for="MaxUsers"><span class="label-text">Max Users</span></label>
                    <input type="number" id="MaxUsers" name="MaxUsers" class="input input-bordered w-full"
                           value="@Model.MaxUsers" min="0" placeholder="Unlimited" />
                </div>

                <div class="form-control w-full">
                    <label class="label" for="SortOrder"><span class="label-text">Sort Order</span></label>
                    <input type="number" id="SortOrder" name="SortOrder" class="input input-bordered w-full"
                           value="@Model.SortOrder" min="0" />
                </div>

                <div class="form-control w-full sm:col-span-2">
                    <label class="label cursor-pointer justify-start gap-3">
                        <input type="checkbox" name="IsActive" value="true" class="checkbox checkbox-sm"
                               @(Model.IsActive ? "checked" : "") />
                        <span class="label-text">Active</span>
                    </label>
                </div>
            </div>

            <div class="modal-action">
                <button type="button" class="btn" onclick="this.closest('.modal').classList.remove('modal-open')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Plan</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="this.closest('.modal').classList.remove('modal-open')">close</button>
    </form>
</dialog>
