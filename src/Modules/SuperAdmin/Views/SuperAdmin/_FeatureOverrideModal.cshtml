@model saas.Modules.SuperAdmin.Services.TenantFeatureOverrideModel

<dialog class="modal modal-open">
    <div class="modal-box">
        <form hx-post="/super-admin/features/override" hx-target="#modal-container">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">Feature Override</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">✕</button>
            </div>

            <input type="hidden" name="TenantId" value="@Model.TenantId" />
            <input type="hidden" name="FeatureId" value="@Model.FeatureId" />

            <div class="form-control w-full mb-4">
                <label class="label cursor-pointer justify-start gap-3">
                    <input type="checkbox" name="IsEnabled" value="true" class="checkbox checkbox-sm"
                           @(Model.IsEnabled ? "checked" : "") />
                    <span class="label-text">Enabled</span>
                </label>
            </div>

            <div class="form-control w-full mb-4">
                <label class="label" for="Reason"><span class="label-text">Reason</span></label>
                <textarea id="Reason" name="Reason" class="textarea textarea-bordered w-full"
                          rows="2" placeholder="Why is this override being applied?">@Model.Reason</textarea>
            </div>

            <div class="modal-action">
                <button type="button" class="btn" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Override</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
