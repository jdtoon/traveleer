@{
    ViewData["Title"] = "Announcements";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold">Announcements</h1>
            <p class="text-base-content/70 mt-1">Broadcast notifications to all tenant users.</p>
        </div>
        <button class="btn btn-primary btn-sm"
                hx-get="/super-admin/announcements/new"
                hx-target="#modal-container">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
            New Announcement
        </button>
    </div>

    <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
            <div class="alert alert-info">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Announcements are delivered as in-app notifications to every user in every active tenant. Use this sparingly for important platform-wide messages.</span>
            </div>
        </div>
    </div>
</div>
