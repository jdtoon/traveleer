@model List<saas.Modules.SuperAdmin.Controllers.ConfigSection>
@{
    ViewData["Title"] = "System Configuration";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold">System Configuration</h1>
        <p class="text-base-content/70 mt-1">Read-only view of application settings. Sensitive values are masked.</p>
    </div>

    <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
            @foreach (var section in Model)
            {
                @await Html.PartialAsync("_ConfigNode", section, new ViewDataDictionary(ViewData) { { "Depth", 0 } })
            }
        </div>
    </div>
</div>
