@model saas.Modules.SuperAdmin.Services.AllSessionsModel
@{
    ViewData["Title"] = "Active Sessions";
}

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold">Active Sessions</h1>
        <p class="text-base-content/70 mt-1">All active user sessions across tenants. Total: <span class="font-semibold">@Model.TotalSessions</span></p>
    </div>

    @if (Model.TenantSessions.Count == 0)
    {
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body">
                <p class="text-base-content/60">No active sessions found across any tenants.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var tenantGroup in Model.TenantSessions)
        {
            <div class="card bg-base-100 shadow-sm border border-base-300">
                <div class="card-body">
                    <h2 class="card-title text-lg mb-4">
                        <swap-nav to="/super-admin/tenants" class="link link-hover">@tenantGroup.TenantName</swap-nav>
                        <span class="badge badge-sm badge-outline">@tenantGroup.ActiveSessions sessions</span>
                    </h2>
                    <div class="overflow-x-auto">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Device</th>
                                    <th>IP Address</th>
                                    <th>Last Activity</th>
                                    <th>Expires</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in tenantGroup.Sessions)
                                {
                                    <tr class="@(session.IsExpired ? "opacity-40" : "")">
                                        <td class="text-sm">@session.UserEmail</td>
                                        <td class="text-sm">@(session.DeviceInfo ?? "—")</td>
                                        <td class="font-mono text-xs">@(session.IpAddress ?? "—")</td>
                                        <td class="text-sm">@session.LastActivityAt.ToString("g")</td>
                                        <td class="text-sm">@session.ExpiresAt.ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>
