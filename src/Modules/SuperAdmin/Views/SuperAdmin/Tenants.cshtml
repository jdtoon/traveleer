@model PaginatedList<saas.Modules.SuperAdmin.Services.TenantListItem>
@{
    ViewData["Title"] = "Tenants";
    var search = ViewData["Search"] as string;
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Tenants</h1>
            <p class="opacity-60">Manage all tenants</p>
        </div>
        <div>
            <input type="text"
                   name="search"
                   value="@search"
                   placeholder="Search tenants..."
                   class="input input-bordered input-sm w-64"
                   hx-get="/super-admin/tenants/list"
                   hx-target="#tenant-list"
                   hx-trigger="keyup changed delay:300ms" />
        </div>
    </div>

    <div id="tenant-list">
        <partial name="_TenantList" model="Model" />
    </div>
</div>
