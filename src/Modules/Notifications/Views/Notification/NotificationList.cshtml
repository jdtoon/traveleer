@model List<saas.Modules.Notifications.Entities.Notification>
@{
    ViewData["Title"] = "Notifications";
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="max-w-2xl mx-auto space-y-4">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Notifications</h1>
        <form method="post" action="/@slug/notifications/read-all">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-ghost btn-sm">Mark all as read</button>
        </form>
    </div>

    @if (Model.Count == 0)
    {
        <div class="card bg-base-200">
            <div class="card-body text-center">
                <p class="text-base-content/60">No notifications yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var n in Model)
            {
                <div class="card bg-base-200 @(n.IsRead ? "opacity-60" : "")">
                    <div class="card-body p-4">
                        <div class="flex items-start gap-3">
                            @{
                                var badgeClass = n.Type switch {
                                    saas.Modules.Notifications.Entities.NotificationType.Success => "badge-success",
                                    saas.Modules.Notifications.Entities.NotificationType.Warning => "badge-warning",
                                    saas.Modules.Notifications.Entities.NotificationType.Error => "badge-error",
                                    _ => "badge-info"
                                };
                            }
                            <span class="badge @badgeClass badge-xs mt-1.5"></span>
                            <div class="flex-1">
                                <div class="flex items-center justify-between">
                                    <p class="font-semibold text-sm">@n.Title</p>
                                    <span class="text-xs text-base-content/40">@n.CreatedAt.ToString("MMM d, yyyy HH:mm")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(n.Message))
                                {
                                    <p class="text-sm text-base-content/70 mt-1">@n.Message</p>
                                }
                                @if (!string.IsNullOrEmpty(n.Url))
                                {
                                    <a href="@n.Url" class="link link-primary text-xs mt-1 inline-block">View →</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
