@inject saas.Shared.ITenantContext TenantContext
@{
    var slug = TenantContext.Slug;
}

<div class="dropdown dropdown-end" id="notification-bell">
    <div tabindex="0" role="button" class="btn btn-ghost btn-sm btn-circle relative"
         hx-get="/@slug/notifications/dropdown"
         hx-trigger="click"
         hx-target="#notification-panel"
         hx-swap="innerHTML"
         aria-label="Notifications">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
        </svg>
        <span id="notification-badge" class="badge badge-primary badge-xs absolute -top-1 -right-1 hidden"
              hx-get="/@slug/notifications/count"
              hx-trigger="load, every 30s"
              hx-swap="innerHTML"></span>
    </div>
    <div id="notification-panel" tabindex="0"
         class="dropdown-content z-50 card card-compact w-80 bg-base-200 shadow-lg">
        <div class="card-body">
            <p class="text-center text-base-content/50 text-sm py-4">Click bell to load</p>
        </div>
    </div>
</div>

<script>
    (function () {
        var badge = document.getElementById("notification-badge");
        if (!badge || badge.dataset.cspBound === "true") {
            return;
        }

        badge.dataset.cspBound = "true";
        badge.addEventListener("htmx:afterRequest", function () {
            badge.classList.toggle("hidden", badge.textContent.trim() === "0");
        });
    })();
</script>
