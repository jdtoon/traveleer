@model saas.Data.PaginatedList<saas.Modules.Quotes.DTOs.QuoteListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();

    string statusClass(QuoteStatus status) => status switch
    {
        QuoteStatus.Draft => "badge-warning",
        QuoteStatus.Sent => "badge-primary",
        QuoteStatus.Accepted => "badge-success",
        QuoteStatus.Expired => "badge-neutral",
        _ => "badge-outline"
    };
}

@if (Model.Items.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No quotes yet</h3>
        <p class="mt-2 opacity-70">Create your first quote from saved rate cards once client details and travel dates are known.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead>
                <tr>
                    <th>Quote</th>
                    <th>Client</th>
                    <th>Travel Window</th>
                    <th>Status</th>
                    <th>Output</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr class="hover">
                        <td>
                            <div class="font-medium">@item.ReferenceNumber</div>
                            <div class="text-sm opacity-70">@item.RateCardCount rate card@(item.RateCardCount == 1 ? string.Empty : "s")</div>
                            @if (!string.IsNullOrWhiteSpace(item.PrimaryHotelName))
                            {
                                <div class="text-sm opacity-70">@item.PrimaryHotelName</div>
                            }
                        </td>
                        <td>
                            <div>
                                @if (item.ClientId.HasValue)
                                {
                                    <a href="@Url.Action("Index", "Client", new { slug })"
                                       class="link link-hover"
                                       hx-get="@Url.Action("Details", "Client", new { slug, id = item.ClientId })"
                                       hx-target="#modal-container">
                                        @item.ClientName
                                    </a>
                                }
                                else
                                {
                                    @item.ClientName
                                }
                            </div>
                            <div class="text-sm opacity-70">@(string.IsNullOrWhiteSpace(item.ClientEmail) ? "Email not set" : item.ClientEmail)</div>
                        </td>
                        <td>
                            @if (item.TravelStartDate.HasValue || item.TravelEndDate.HasValue)
                            {
                                <span>@(item.TravelStartDate?.ToString("dd MMM yyyy") ?? "Open") - @(item.TravelEndDate?.ToString("dd MMM yyyy") ?? "Open")</span>
                            }
                            else
                            {
                                <span class="opacity-60">All configured seasons</span>
                            }
                        </td>
                        <td><span class="badge badge-sm @statusClass(item.Status)">@item.Status</span></td>
                        <td>@item.OutputCurrencyCode</td>
                        <td>
                            <a class="btn btn-ghost btn-sm" href="@Url.Action("Details", "Quote", new { slug, id = item.Id })">Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
