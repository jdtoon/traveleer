@model saas.Modules.RateCards.DTOs.RateSeasonFormDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var isEdit = Model.Id != Guid.Empty;
    var title = isEdit ? "Edit Season" : "Add Season";
    var action = isEdit
        ? Url.Action("UpdateSeason", "RateCard", new { slug, rateCardId = Model.RateCardId, seasonId = Model.Id })
        : Url.Action("CreateSeason", "RateCard", new { slug, id = Model.RateCardId });
}

<dialog class="modal modal-open modal-middle">
    <div class="modal-box max-w-xl">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h3 class="text-lg font-bold">@title</h3>
                <p class="text-sm opacity-70">Season date windows cannot overlap on the same rate card.</p>
            </div>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">x</button>
        </div>

        <form hx-post="@action" hx-target="#modal-container">
            @Html.AntiForgeryToken()
            <div class="grid gap-4 md:grid-cols-2">
                <div class="form-control w-full md:col-span-2">
                    <label class="label" for="Name"><span class="label-text">Season name</span></label>
                    <input id="Name" name="Name" value="@Model.Name" class="input input-bordered w-full" />
                    <span asp-validation-for="Name" class="text-error text-sm mt-1"></span>
                </div>
                <div class="form-control w-full">
                    <label class="label" for="StartDate"><span class="label-text">Start date</span></label>
                    <input id="StartDate" type="date" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="input input-bordered w-full" />
                </div>
                <div class="form-control w-full">
                    <label class="label" for="EndDate"><span class="label-text">End date</span></label>
                    <input id="EndDate" type="date" name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" class="input input-bordered w-full" />
                </div>
                <div class="form-control w-full md:col-span-2">
                    <label class="label cursor-pointer justify-start gap-3">
                        <input type="hidden" name="IsBlackout" value="false" />
                        <input type="checkbox" name="IsBlackout" value="true" class="checkbox" checked="@Model.IsBlackout" />
                        <span class="label-text">Blackout season</span>
                    </label>
                </div>
                <div class="form-control w-full md:col-span-2">
                    <label class="label" for="Notes"><span class="label-text">Notes</span></label>
                    <textarea id="Notes" name="Notes" class="textarea textarea-bordered w-full" rows="3">@Model.Notes</textarea>
                    <span asp-validation-for="Notes" class="text-error text-sm mt-1"></span>
                </div>
            </div>

            <div class="modal-action mt-6">
                <button type="button" class="btn btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Season</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
