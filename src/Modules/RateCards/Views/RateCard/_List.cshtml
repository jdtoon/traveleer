@model saas.Data.PaginatedList<saas.Modules.RateCards.DTOs.RateCardListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

@if (Model.Items.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No rate cards yet</h3>
        <p class="mt-2 opacity-70">Create a supplier rate card once contract dates, pricing dimensions, and currency are known.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead>
                <tr>
                    <th>Rate Card</th>
                    <th>Inventory</th>
                    <th>Validity</th>
                    <th>Status</th>
                    <th>Currency</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr class="hover">
                        <td>
                            <div class="font-medium">@item.Name</div>
                            <div class="text-sm opacity-70">@item.InventoryKind · @item.SeasonCount season@(item.SeasonCount == 1 ? string.Empty : "s")</div>
                        </td>
                        <td>
                            <div>@item.InventoryItemName</div>
                            @if (!string.IsNullOrWhiteSpace(item.DestinationName))
                            {
                                <div class="text-sm opacity-70">@item.DestinationName</div>
                            }
                        </td>
                        <td>
                            @if (item.ValidFrom.HasValue)
                            {
                                <span>@item.ValidFrom.Value.ToString("dd MMM yyyy")</span>
                            }
                            else
                            {
                                <span class="opacity-60">Open start</span>
                            }
                            <span> - </span>
                            @if (item.ValidTo.HasValue)
                            {
                                <span>@item.ValidTo.Value.ToString("dd MMM yyyy")</span>
                            }
                            else
                            {
                                <span class="opacity-60">Open end</span>
                            }
                        </td>
                        <td><span class="badge badge-outline badge-sm">@item.Status</span></td>
                        <td>@item.ContractCurrencyCode</td>
                        <td>
                            <a class="btn btn-ghost btn-sm" href="@Url.Action("Details", "RateCard", new { slug, id = item.Id })">Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
