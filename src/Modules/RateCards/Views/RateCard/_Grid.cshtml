@model saas.Modules.RateCards.DTOs.RateCardDetailsDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="card border border-base-300 bg-base-100 shadow-sm">
    <div class="card-body gap-4">
        <div class="flex items-center justify-between gap-3">
            <div>
                <h2 class="card-title">Seasonal Rate Grid</h2>
                <p class="text-sm opacity-70">Maintain weekday and weekend contract rates by room type for each season.</p>
            </div>
            <div class="text-sm opacity-60">@Model.Seasons.Count season@(Model.Seasons.Count == 1 ? string.Empty : "s")</div>
        </div>

        @if (Model.Seasons.Count == 0)
        {
            <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
                <h3 class="text-lg font-semibold">No seasons configured</h3>
                <p class="mt-2 opacity-70">Add your first season to unlock the room-rate grid and activate this contract.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-pin-rows table-zebra min-w-225">
                    <thead>
                        <tr>
                            <th class="min-w-56">Season</th>
                            @foreach (var roomType in Model.RoomTypes)
                            {
                                <th class="min-w-56">@roomType.Code</th>
                            }
                            <th class="min-w-36 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var season in Model.Seasons)
                        {
                            <tr>
                                <td class="align-top">
                                    <div class="space-y-1">
                                        <div class="font-semibold">@season.Name</div>
                                        <div class="text-sm opacity-70">@season.StartDate.ToString("dd MMM yyyy") - @season.EndDate.ToString("dd MMM yyyy")</div>
                                        @if (season.IsBlackout)
                                        {
                                            <span class="badge badge-ghost badge-sm">Blackout</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(season.Notes))
                                        {
                                            <div class="text-sm opacity-70">@season.Notes</div>
                                        }
                                    </div>
                                </td>
                                @foreach (var rate in season.Rates)
                                {
                                    <td class="align-top">
                                        <form class="space-y-2"
                                              hx-post="@Url.Action("UpdateRate", "RateCard", new { slug })"
                                              hx-target="#toast-container"
                                              hx-swap="beforeend">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="RateCardId" value="@Model.Id" />
                                            <input type="hidden" name="RateSeasonId" value="@season.Id" />
                                            <input type="hidden" name="RoomTypeId" value="@rate.RoomTypeId" />
                                            <label class="label py-0"><span class="label-text text-xs">Weekday</span></label>
                                            <input type="number" step="0.01" min="0" name="WeekdayRate" value="@rate.WeekdayRate.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" class="input input-bordered input-sm w-full" />
                                            <label class="label py-0"><span class="label-text text-xs">Weekend</span></label>
                                            <input type="number" step="0.01" min="0" name="WeekendRate" value="@(rate.WeekendRate.HasValue ? rate.WeekendRate.Value.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) : string.Empty)" class="input input-bordered input-sm w-full" placeholder="Same as weekday" />
                                            <label class="label cursor-pointer justify-start gap-2">
                                                <input type="hidden" name="IsIncluded" value="false" />
                                                <input type="checkbox" name="IsIncluded" value="true" class="checkbox checkbox-sm" checked="@rate.IsIncluded" />
                                                <span class="label-text text-xs">Included in quotes</span>
                                            </label>
                                            <button type="submit" class="btn btn-primary btn-xs w-full">Save</button>
                                        </form>
                                    </td>
                                }
                                <td class="align-top">
                                    <div class="flex flex-col gap-2 items-end">
                                        <has-permission name="ratecards.edit">
                                            <button class="btn btn-ghost btn-xs" hx-get="@Url.Action("EditSeason", "RateCard", new { slug, rateCardId = Model.Id, seasonId = season.Id })" hx-target="#modal-container">Edit</button>
                                        </has-permission>
                                        <has-permission name="ratecards.delete">
                                            <button class="btn btn-ghost btn-xs text-error" hx-get="@Url.Action("ConfirmDeleteSeason", "RateCard", new { slug, rateCardId = Model.Id, seasonId = season.Id })" hx-target="#modal-container">Delete</button>
                                        </has-permission>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
