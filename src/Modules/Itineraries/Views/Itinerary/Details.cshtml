@model ItineraryDetailsDto
@{
    ViewData["Title"] = Model.Title;
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="flex flex-col gap-6">

    <div id="itinerary-summary"
         hx-get="@Url.Action("Summary", "Itinerary", new { slug, id = Model.Id })"
         hx-trigger="@saas.Modules.Itineraries.Events.ItineraryEvents.DetailsRefresh from:body"
         hx-swap="innerHTML">
        @await Html.PartialAsync("_Summary", Model)
    </div>

    @* ── Day Builder ── *@
    <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body gap-4">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-bold">Day-by-Day Plan</h2>
                <has-permission name="itineraries.edit">
                    <button class="btn btn-primary btn-sm"
                            hx-get="@Url.Action("NewDay", "Itinerary", new { slug, itineraryId = Model.Id })"
                            hx-target="#modal-container">
                        + Add Day
                    </button>
                </has-permission>
            </div>

            <div id="itinerary-days"
                 hx-get="@Url.Action("Days", "Itinerary", new { slug, itineraryId = Model.Id })"
                 hx-trigger="load, @saas.Modules.Itineraries.Events.ItineraryEvents.DaysRefresh from:body"
                 hx-swap="innerHTML show:none">
                <span class="loading loading-spinner loading-lg"></span>
            </div>
        </div>
    </div>
</div>
