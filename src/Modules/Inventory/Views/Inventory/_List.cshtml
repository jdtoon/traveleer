@model saas.Data.PaginatedList<saas.Modules.Inventory.DTOs.InventoryListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var type = ViewData["Type"]?.ToString();
    var search = ViewData["Search"]?.ToString();

    string ItemUrl(int page)
    {
        var routeValues = new Dictionary<string, object?>
        {
            ["slug"] = slug,
            ["page"] = page
        };
        if (!string.IsNullOrWhiteSpace(type)) routeValues["type"] = type;
        if (!string.IsNullOrWhiteSpace(search)) routeValues["search"] = search;
        return Url.Action("List", "Inventory", routeValues)!;
    }

    string Icon(InventoryItemKind kind) => kind switch
    {
        InventoryItemKind.Hotel => "H",
        InventoryItemKind.Flight => "F",
        InventoryItemKind.Excursion => "E",
        InventoryItemKind.Transfer => "T",
        InventoryItemKind.Visa => "V",
        _ => "O"
    };
}
@if (Model.Items.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No inventory items found</h3>
        <p class="mt-2 opacity-70">
            @if (!string.IsNullOrWhiteSpace(type) || !string.IsNullOrWhiteSpace(search))
            {
                <text>No items match this filter. Try a broader search or switch to a different type.</text>
            }
            else
            {
                <text>Start by adding hotels, excursions, visas, or other sellable items for this tenant.</text>
            }
        </p>
    </div>
}
else
{
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        @foreach (var item in Model.Items)
        {
            <article class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-4">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-start gap-3">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10 font-semibold text-primary">@Icon(item.Kind)</div>
                            <div>
                                <h3 class="font-semibold leading-tight">@item.Name</h3>
                                <div class="mt-1 flex flex-wrap gap-2 text-xs">
                                    <span class="badge badge-outline badge-sm">@item.Kind</span>
                                    @if (item.Rating.HasValue)
                                    {
                                        <span class="badge badge-warning badge-sm">@item.Rating.Value star</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <has-permission name="inventory.edit">
                            <div class="dropdown dropdown-end">
                                <label tabindex="0" class="btn btn-ghost btn-xs">...</label>
                                <ul tabindex="0" class="dropdown-content menu menu-sm z-10 w-40 rounded-box bg-base-200 shadow-lg">
                                    <li><button hx-get="@Url.Action("Edit", "Inventory", new { slug, id = item.Id })" hx-target="#modal-container">Edit</button></li>
                                    <has-permission name="inventory.delete">
                                        <li><button class="text-error" hx-get="@Url.Action("DeleteConfirm", "Inventory", new { slug, id = item.Id })" hx-target="#modal-container">Delete</button></li>
                                    </has-permission>
                                </ul>
                            </div>
                        </has-permission>
                    </div>

                    <div class="grid gap-3 text-sm">
                        <div>
                            <div class="text-xs uppercase tracking-wide opacity-60">Base Cost</div>
                            <div class="font-medium">@item.BaseCost.ToString("C")</div>
                        </div>
                        <div>
                            <div class="text-xs uppercase tracking-wide opacity-60">Destination</div>
                            <div>@(item.DestinationName ?? "Unassigned")</div>
                        </div>
                        <div>
                            <div class="text-xs uppercase tracking-wide opacity-60">Supplier</div>
                            <div>@(item.SupplierName ?? "Unassigned")</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Address))
                        {
                            <div>
                                <div class="text-xs uppercase tracking-wide opacity-60">Address</div>
                                <div>@item.Address</div>
                            </div>
                        }
                        @if (item.Kind == InventoryItemKind.Transfer && (!string.IsNullOrWhiteSpace(item.PickupLocation) || !string.IsNullOrWhiteSpace(item.DropoffLocation)))
                        {
                            <div>
                                <div class="text-xs uppercase tracking-wide opacity-60">Route</div>
                                <div>@(item.PickupLocation ?? "—") → @(item.DropoffLocation ?? "—")</div>
                            </div>
                        }
                        @if (item.Kind == InventoryItemKind.Transfer && !string.IsNullOrWhiteSpace(item.VehicleType))
                        {
                            <div>
                                <div class="text-xs uppercase tracking-wide opacity-60">Vehicle</div>
                                <div>
                                    @item.VehicleType
                                    @if (item.MaxPassengers.HasValue) { <text> · max @item.MaxPassengers pax</text> }
                                    @if (item.IncludesMeetAndGreet) { <text> · Meet &amp; Greet</text> }
                                </div>
                            </div>
                        }
                        @if (item.Kind == InventoryItemKind.Transfer && item.TransferDurationMinutes.HasValue)
                        {
                            <div>
                                <div class="text-xs uppercase tracking-wide opacity-60">Est. Duration</div>
                                <div>@item.TransferDurationMinutes min</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p class="line-clamp-3 opacity-70">@item.Description</p>
                        }
                    </div>
                </div>
            </article>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="mt-6 flex items-center justify-between gap-3 rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm">
            <div class="opacity-70">Page @Model.PageIndex of @Model.TotalPages</div>
            <div class="join">
                @if (Model.HasPreviousPage)
                {
                    <button class="join-item btn btn-sm"
                            hx-get="@ItemUrl(Model.PageIndex - 1)"
                            hx-target="#inventory-list">
                        Previous
                    </button>
                }
                else
                {
                    <button class="join-item btn btn-sm btn-disabled">Previous</button>
                }

                @if (Model.HasNextPage)
                {
                    <button class="join-item btn btn-sm"
                            hx-get="@ItemUrl(Model.PageIndex + 1)"
                            hx-target="#inventory-list">
                        Next
                    </button>
                }
                else
                {
                    <button class="join-item btn btn-sm btn-disabled">Next</button>
                }
            </div>
        </div>
    }
}
