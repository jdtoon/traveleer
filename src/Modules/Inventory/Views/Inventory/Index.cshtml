@{
    ViewData["Title"] = "Inventory";
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var search = ViewData["Search"]?.ToString();
    var type = ViewData["Type"]?.ToString();

    string tabClass(string? current) => string.Equals(type, current, StringComparison.OrdinalIgnoreCase)
        ? "tab tab-active"
        : "tab";

    string? QueryFor(string? nextType)
    {
        var pairs = new List<string>();
        if (!string.IsNullOrWhiteSpace(nextType)) pairs.Add($"type={Uri.EscapeDataString(nextType)}");
        if (!string.IsNullOrWhiteSpace(search)) pairs.Add($"search={Uri.EscapeDataString(search)}");
        return pairs.Count == 0 ? null : string.Join("&", pairs);
    }

    string TabUrl(string? nextType)
    {
        var query = QueryFor(nextType);
        return query is null ? $"/{slug}/inventory" : $"/{slug}/inventory?{query}";
    }

    string TabListUrl(string? nextType)
    {
        var query = QueryFor(nextType);
        return query is null ? $"/{slug}/inventory/list" : $"/{slug}/inventory/list?{query}";
    }
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <h1 class="text-2xl font-bold">Inventory</h1>
            <p class="opacity-70">Build the product catalogue your team sells, grouped by travel type and linked to shared destinations and suppliers.</p>
        </div>
        <has-permission name="inventory.create">
            <button class="btn btn-primary btn-sm" hx-get="@Url.Action("New", "Inventory", new { slug })" hx-target="#modal-container">+ New Item</button>
        </has-permission>
    </div>

    <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-6">
            <div role="tablist" class="tabs tabs-bordered flex-wrap gap-2">
                <a href="@TabUrl(null)" hx-get="@TabListUrl(null)" hx-target="#inventory-list" hx-push-url="@TabUrl(null)" class="@tabClass(null)">All Items</a>
                <a href="@TabUrl(nameof(InventoryItemKind.Hotel))" hx-get="@TabListUrl(nameof(InventoryItemKind.Hotel))" hx-target="#inventory-list" hx-push-url="@TabUrl(nameof(InventoryItemKind.Hotel))" class="@tabClass(nameof(InventoryItemKind.Hotel))">Hotels</a>
                <a href="@TabUrl(nameof(InventoryItemKind.Flight))" hx-get="@TabListUrl(nameof(InventoryItemKind.Flight))" hx-target="#inventory-list" hx-push-url="@TabUrl(nameof(InventoryItemKind.Flight))" class="@tabClass(nameof(InventoryItemKind.Flight))">Flights</a>
                <a href="@TabUrl(nameof(InventoryItemKind.Excursion))" hx-get="@TabListUrl(nameof(InventoryItemKind.Excursion))" hx-target="#inventory-list" hx-push-url="@TabUrl(nameof(InventoryItemKind.Excursion))" class="@tabClass(nameof(InventoryItemKind.Excursion))">Excursions</a>
                <a href="@TabUrl(nameof(InventoryItemKind.Transfer))" hx-get="@TabListUrl(nameof(InventoryItemKind.Transfer))" hx-target="#inventory-list" hx-push-url="@TabUrl(nameof(InventoryItemKind.Transfer))" class="@tabClass(nameof(InventoryItemKind.Transfer))">Transfers</a>
                <a href="@TabUrl(nameof(InventoryItemKind.Visa))" hx-get="@TabListUrl(nameof(InventoryItemKind.Visa))" hx-target="#inventory-list" hx-push-url="@TabUrl(nameof(InventoryItemKind.Visa))" class="@tabClass(nameof(InventoryItemKind.Visa))">Visas</a>
                <a href="@TabUrl(nameof(InventoryItemKind.Other))" hx-get="@TabListUrl(nameof(InventoryItemKind.Other))" hx-target="#inventory-list" hx-push-url="@TabUrl(nameof(InventoryItemKind.Other))" class="@tabClass(nameof(InventoryItemKind.Other))">Other</a>
            </div>

            <form class="grid gap-3 md:grid-cols-[minmax(0,1fr)_auto_auto] md:items-end"
                  hx-get="@Url.Action("List", "Inventory", new { slug })"
                  hx-target="#inventory-list"
                  hx-swap="innerHTML">
                <input type="hidden" name="type" value="@type" />
                <input type="hidden" name="page" value="1" />
                <div class="form-control w-full">
                    <label class="label" for="inventory-search">
                        <span class="label-text">Search inventory</span>
                    </label>
                    <input id="inventory-search" name="search" value="@search" class="input input-bordered w-full" placeholder="Search by item, supplier, destination, or address" />
                </div>
                <button type="submit" class="btn btn-primary">Apply</button>
                <a href="@TabUrl(type)" class="btn btn-ghost">Clear</a>
            </form>

            <div id="inventory-list"
                 hx-get="@Url.Action("List", "Inventory", new { slug, type, search })"
                 hx-trigger="load, @saas.Modules.Inventory.Events.InventoryEvents.Refresh from:body"
                 hx-swap="innerHTML show:none">
                <span class="loading loading-spinner loading-lg"></span>
            </div>
        </div>
    </div>
</div>
