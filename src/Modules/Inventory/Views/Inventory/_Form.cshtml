@model saas.Modules.Inventory.DTOs.InventoryDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var isEdit = Model.Id != Guid.Empty;
    var title = isEdit ? "Edit Inventory Item" : "New Inventory Item";
    var action = isEdit
        ? Url.Action("Update", "Inventory", new { slug, id = Model.Id })
        : Url.Action("Create", "Inventory", new { slug });
}
<dialog class="modal modal-open modal-middle">
    <div class="modal-box max-w-3xl">
        <form hx-post="@action" hx-target="#modal-container">
            @Html.AntiForgeryToken()
            <div class="mb-4 flex items-center justify-between gap-3">
                <div>
                    <h3 class="text-lg font-bold">@title</h3>
                    <p class="text-sm opacity-70">Capture the destination, supplier, and pricing baseline your team will work from.</p>
                </div>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">x</button>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div class="form-control w-full md:col-span-2">
                    <label class="label"><span class="label-text">Name</span></label>
                    <input asp-for="Name" class="input input-bordered w-full" />
                    <span asp-validation-for="Name" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Type</span></label>
                    <select asp-for="Kind" asp-items="Html.GetEnumSelectList<saas.Modules.Inventory.Entities.InventoryItemKind>()" class="select select-bordered w-full"
                            onchange="document.getElementById('transfer-fields').classList.toggle('hidden', this.value !== '@((int)saas.Modules.Inventory.Entities.InventoryItemKind.Transfer)')"></select>
                    <span asp-validation-for="Kind" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Base cost</span></label>
                    <input asp-for="BaseCost" class="input input-bordered w-full" />
                    <span asp-validation-for="BaseCost" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Destination</span></label>
                    <select asp-for="DestinationId" class="select select-bordered w-full">
                        <option value="">No destination</option>
                        @foreach (var option in Model.DestinationOptions)
                        {
                            <option value="@option.Id" selected="@(Model.DestinationId == option.Id)">@option.Label</option>
                        }
                    </select>
                    <span asp-validation-for="DestinationId" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Supplier</span></label>
                    <select asp-for="SupplierId" class="select select-bordered w-full">
                        <option value="">No supplier</option>
                        @foreach (var option in Model.SupplierOptions)
                        {
                            <option value="@option.Id" selected="@(Model.SupplierId == option.Id)">@option.Label</option>
                        }
                    </select>
                    <span asp-validation-for="SupplierId" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Rating (hotels only)</span></label>
                    <select asp-for="Rating" class="select select-bordered w-full">
                        <option value="">No rating</option>
                        <option value="1" selected="@(Model.Rating == 1)">1 star</option>
                        <option value="2" selected="@(Model.Rating == 2)">2 stars</option>
                        <option value="3" selected="@(Model.Rating == 3)">3 stars</option>
                        <option value="4" selected="@(Model.Rating == 4)">4 stars</option>
                        <option value="5" selected="@(Model.Rating == 5)">5 stars</option>
                    </select>
                    <span asp-validation-for="Rating" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full md:col-span-2">
                    <label class="label"><span class="label-text">Image URL</span></label>
                    <input asp-for="ImageUrl"
                           class="input input-bordered w-full"
                           placeholder="https://..."
                           oninput="const preview = document.getElementById('image-preview'); preview.src = this.value.trim(); if (!this.value.trim()) preview.classList.add('hidden');"
                           onblur="const preview = document.getElementById('image-preview'); preview.src = this.value.trim(); if (!this.value.trim()) preview.classList.add('hidden');" />
                    <img id="image-preview"
                         src="@Model.ImageUrl"
                         alt="Inventory preview"
                         class="mt-3 max-h-40 rounded-box border border-base-300 object-cover @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "hidden" : string.Empty)"
                         onerror="this.classList.add('hidden')"
                         onload="this.classList.remove('hidden')" />
                    <span asp-validation-for="ImageUrl" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full md:col-span-2">
                    <label class="label"><span class="label-text">Address</span></label>
                    <input asp-for="Address" class="input input-bordered w-full" />
                    <span asp-validation-for="Address" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full md:col-span-2">
                    <label class="label"><span class="label-text">Description</span></label>
                    <textarea asp-for="Description" class="textarea textarea-bordered w-full" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-error text-sm mt-1"></span>
                </div>
            </div>

            <!-- Transport-specific fields (shown when Kind == Transfer) -->
            <div id="transfer-fields" class="mt-4 rounded-box border border-base-300 bg-base-200/30 p-4 @(Model.Kind != saas.Modules.Inventory.Entities.InventoryItemKind.Transfer ? "hidden" : "")">
                <h4 class="mb-3 text-sm font-semibold uppercase tracking-wide opacity-60">Transfer Details</h4>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div class="form-control w-full">
                        <label class="label"><span class="label-text">Pickup Location</span></label>
                        <input asp-for="PickupLocation" class="input input-bordered w-full" placeholder="e.g. OR Tambo International Airport" />
                        <span asp-validation-for="PickupLocation" class="text-error text-sm mt-1"></span>
                    </div>
                    <div class="form-control w-full">
                        <label class="label"><span class="label-text">Dropoff Location</span></label>
                        <input asp-for="DropoffLocation" class="input input-bordered w-full" placeholder="e.g. Sandton City Hotel" />
                        <span asp-validation-for="DropoffLocation" class="text-error text-sm mt-1"></span>
                    </div>
                    <div class="form-control w-full">
                        <label class="label"><span class="label-text">Vehicle Type</span></label>
                        <select asp-for="VehicleType" class="select select-bordered w-full">
                            <option value="">Not specified</option>
                            <option value="Sedan" selected="@(Model.VehicleType == "Sedan")">Sedan</option>
                            <option value="Minibus" selected="@(Model.VehicleType == "Minibus")">Minibus</option>
                            <option value="Luxury SUV" selected="@(Model.VehicleType == "Luxury SUV")">Luxury SUV</option>
                            <option value="Coach" selected="@(Model.VehicleType == "Coach")">Coach</option>
                            <option value="Van" selected="@(Model.VehicleType == "Van")">Van</option>
                        </select>
                        <span asp-validation-for="VehicleType" class="text-error text-sm mt-1"></span>
                    </div>
                    <div class="form-control w-full">
                        <label class="label"><span class="label-text">Max Passengers</span></label>
                        <input asp-for="MaxPassengers" type="number" min="1" max="100" class="input input-bordered w-full" />
                        <span asp-validation-for="MaxPassengers" class="text-error text-sm mt-1"></span>
                    </div>
                    <div class="form-control w-full">
                        <label class="label"><span class="label-text">Est. Duration (minutes)</span></label>
                        <input asp-for="TransferDurationMinutes" type="number" min="1" max="1440" class="input input-bordered w-full" />
                        <span asp-validation-for="TransferDurationMinutes" class="text-error text-sm mt-1"></span>
                    </div>
                    <div class="form-control w-full">
                        <label class="label cursor-pointer justify-start gap-3">
                            <input asp-for="IncludesMeetAndGreet" type="checkbox" class="checkbox checkbox-primary" />
                            <span class="label-text">Includes Meet & Greet</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="modal-action">
                <button type="button" class="btn btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
