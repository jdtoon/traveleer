@model List<PortalLinkListItemDto>

@if (Model.Count == 0)
{
    <div class="text-center text-base-content/60 py-6">
        <p>No portal links created yet.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Scope</th>
                    <th>Expires</th>
                    <th>Last Accessed</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var link in Model)
                {
                    <tr>
                        <td class="font-medium">@link.ClientName</td>
                        <td>@link.Scope</td>
                        <td>@link.ExpiresAt.ToString("dd MMM yyyy")</td>
                        <td>@(link.LastAccessedAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                        <td>
                            @if (link.IsRevoked)
                            {
                                <span class="badge badge-error badge-sm">Revoked</span>
                            }
                            else if (link.IsExpired)
                            {
                                <span class="badge badge-warning badge-sm">Expired</span>
                            }
                            else
                            {
                                <span class="badge badge-success badge-sm">Active</span>
                            }
                        </td>
                        <td class="flex gap-1">
                            @if (link.IsActive)
                            {
                                <button class="btn btn-ghost btn-xs"
                                        onclick="navigator.clipboard.writeText('@(Context.Request.Scheme)://@(Context.Request.Host)/portal/@(ViewContext.RouteData.Values["slug"])/@link.Token'); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy Link', 1500);">
                                    Copy Link
                                </button>
                                <form method="post"
                                      action="@Url.Action("Revoke", "PortalLink", new { slug = ViewContext.RouteData.Values["slug"], id = link.Id })">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost btn-xs text-error"
                                            hx-post="@Url.Action("Revoke", "PortalLink", new { slug = ViewContext.RouteData.Values["slug"], id = link.Id })"
                                            hx-target="#portal-link-list"
                                            hx-swap="innerHTML"
                                            hx-confirm="Revoke this portal link?">
                                        Revoke
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
