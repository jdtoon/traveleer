@{
    Layout = "_PortalLayout";
    ViewData["Title"] = "Link Expired";
}

<div class="flex items-center justify-center min-h-[50vh]">
    <div class="card bg-base-100 shadow-sm max-w-md w-full">
        <div class="card-body text-center">
            <div class="text-5xl mb-4">🔒</div>
            <h1 class="text-2xl font-bold">Link Unavailable</h1>
            <p class="text-base-content/60 mt-2">
                This portal link has expired or has been revoked.
                Please contact your travel agency for a new link.
            </p>
        </div>
    </div>
</div>
