@model List<PortalDocumentListItemDto>
@{
    ViewData["Title"] = "Documents";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold">Your Documents</h1>
</div>

@if (Model.Count == 0)
{
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center text-base-content/60">
            <p>No documents yet.</p>
        </div>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table bg-base-100 shadow-sm">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Type</th>
                    <th>Size</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td class="font-medium">@doc.FileName</td>
                        <td>@doc.DocumentType</td>
                        <td>@FormatFileSize(doc.FileSize)</td>
                        <td>@doc.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="/portal/@ViewBag.TenantSlug/@ViewBag.Token/documents/download/@doc.Id"
                               class="btn btn-ghost btn-xs">
                                Download
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
