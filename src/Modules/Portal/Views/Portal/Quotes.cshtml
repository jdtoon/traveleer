@model List<PortalQuoteListItemDto>
@{
    ViewData["Title"] = "Quotes";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold">Your Quotes</h1>
</div>

@if (Model.Count == 0)
{
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center text-base-content/60">
            <p>No quotes yet.</p>
        </div>
    </div>
}
else
{
    <div class="flex flex-col gap-4">
        @foreach (var quote in Model)
        {
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                        <div>
                            <h3 class="font-semibold text-lg">@quote.Reference</h3>
                            <p class="text-sm text-base-content/60">Created @quote.CreatedAt.ToString("dd MMM yyyy")</p>
                        </div>
                        <span class="badge @(quote.Status == "Accepted" ? "badge-success" : quote.Status == "Expired" ? "badge-error" : "badge-info") badge-sm">
                            @quote.Status
                        </span>
                    </div>
                    @if (quote.Status == "Sent" || quote.Status == "Draft")
                    {
                        <div class="flex flex-wrap gap-2 mt-3 border-t border-base-300 pt-3">
                            <form method="post" action="/portal/@ViewBag.TenantSlug/@ViewBag.Token/quotes/@quote.Id/accept">
                                <button type="submit" class="btn btn-success btn-sm">Accept Quote</button>
                            </form>
                            <form method="post" action="/portal/@ViewBag.TenantSlug/@ViewBag.Token/quotes/@quote.Id/decline">
                                <button type="submit" class="btn btn-error btn-sm btn-outline">Decline</button>
                            </form>
                            <a href="/portal/@ViewBag.TenantSlug/@ViewBag.Token/quotes/@quote.Id/change" class="btn btn-ghost btn-sm">
                                Request Change
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
