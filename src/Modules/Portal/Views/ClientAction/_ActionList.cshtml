@model List<ClientActionListItemDto>

@if (Model.Count == 0)
{
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center text-base-content/60">
            <p>No client actions to display.</p>
        </div>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table bg-base-100 shadow-sm">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Client</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Notes</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var action in Model)
                {
                    <tr>
                        <td class="text-sm">@action.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="font-medium">@action.ClientName</td>
                        <td>@action.ActionLabel</td>
                        <td class="text-sm">@action.EntityType @action.EntityId.ToString()[..8]</td>
                        <td class="text-sm max-w-xs truncate">@(action.Notes ?? "—")</td>
                        <td>
                            <span class="badge @action.StatusBadge badge-sm">@action.Status</span>
                        </td>
                        <td>
                            @if (action.Status == ClientActionStatus.Pending)
                            {
                                <div class="flex gap-1">
                                    <form method="post"
                                          action="/@ViewContext.RouteData.Values["slug"]/portal/actions/acknowledge/@action.Id"
                                          hx-post="/@ViewContext.RouteData.Values["slug"]/portal/actions/acknowledge/@action.Id"
                                          hx-target="#action-list">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-success">Acknowledge</button>
                                    </form>
                                    <form method="post"
                                          action="/@ViewContext.RouteData.Values["slug"]/portal/actions/dismiss/@action.Id"
                                          hx-post="/@ViewContext.RouteData.Values["slug"]/portal/actions/dismiss/@action.Id"
                                          hx-target="#action-list">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-ghost">Dismiss</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

