@model List<RecentBookingDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No recent bookings.</p>
}
else
{
    <div class="overflow-x-auto mt-2">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Ref</th>
                    <th>Client</th>
                    <th>Status</th>
                    <th class="text-right">Selling</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td class="font-mono text-xs">
                            <a href="@Url.Action("Details", "Booking", new { slug, id = b.Id })" class="link link-hover">
                                @b.BookingRef
                            </a>
                        </td>
                        <td>
                            @if (b.ClientId.HasValue && !string.IsNullOrWhiteSpace(b.ClientName))
                            {
                                <a href="@Url.Action("Index", "Client", new { slug })"
                                   class="link link-hover"
                                   hx-get="@Url.Action("Details", "Client", new { slug, id = b.ClientId })"
                                   hx-target="#modal-container">
                                    @b.ClientName
                                </a>
                            }
                            else
                            {
                                @:—
                            }
                        </td>
                        <td><span class="badge badge-ghost badge-xs">@b.Status</span></td>
                        <td class="text-right font-mono text-xs">@b.TotalSelling.ToString("N0")</td>
                        <td class="text-xs text-base-content/60">@b.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
