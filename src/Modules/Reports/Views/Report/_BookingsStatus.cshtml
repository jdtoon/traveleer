@model List<BookingStatusDto>

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No bookings for this period.</p>
}
else
{
    var total = Model.Sum(b => b.Count);
    var labels = System.Text.Json.JsonSerializer.Serialize(Model.Select(b => b.Status).ToList());
    var values = System.Text.Json.JsonSerializer.Serialize(Model.Select(b => b.Count).ToList());
    var colors = System.Text.Json.JsonSerializer.Serialize(Model.Select(b => b.Status switch
    {
        "Confirmed"  => "oklch(0.7231 0.2 142.5 / 0.85)",
        "Completed"  => "oklch(0.6232 0.1883 259.81 / 0.85)",
        "Cancelled"  => "oklch(0.6368 0.2078 25.33 / 0.85)",
        "InProgress" => "oklch(0.7686 0.1647 70.08 / 0.85)",
        _            => "oklch(0.7 0 0 / 0.5)"
    }).ToList());
    var chartConfig = $$"""
        {
            "type": "doughnut",
            "data": {
                "labels": {{labels}},
                "datasets": [{
                    "data": {{values}},
                    "backgroundColor": {{colors}},
                    "borderWidth": 1,
                    "hoverOffset": 6
                }]
            },
            "options": {
                "responsive": true,
                "maintainAspectRatio": false,
                "cutout": "60%",
                "plugins": {
                    "legend": {
                        "position": "right",
                        "labels": { "boxWidth": 12, "font": { "size": 11 } }
                    }
                }
            }
        }
    """;
    <div class="mt-2" style="height:160px; position:relative;">
        <canvas data-chart-type="doughnut" data-chart-config='@Html.Raw(chartConfig)'></canvas>
    </div>
    <div class="text-xs text-base-content/40 text-right mt-1">Total: @total</div>
}
