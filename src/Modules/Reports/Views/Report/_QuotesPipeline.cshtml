@model List<QuotePipelineDto>

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No quotes for this period.</p>
}
else
{
    var max = Model.Max(q => q.Count);
    <div class="flex flex-col gap-2 mt-2">
        @foreach (var item in Model)
        {
            var pct = max > 0 ? (int)((double)item.Count / max * 100) : 0;
            <div class="flex items-center gap-2">
                <span class="text-xs w-16 text-base-content/60">@item.Status</span>
                <div class="flex-1 bg-base-200 rounded-full h-3 overflow-hidden">
                    <div class="bg-accent h-full rounded-full" style="width: @(pct)%"></div>
                </div>
                <span class="text-xs font-mono w-8 text-right">@item.Count</span>
            </div>
        }
    </div>
}
