@model List<QuotePipelineDto>

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No quotes for this period.</p>
}
else
{
    var labels = System.Text.Json.JsonSerializer.Serialize(Model.Select(q => q.Status).ToList());
    var values = System.Text.Json.JsonSerializer.Serialize(Model.Select(q => q.Count).ToList());
    var chartConfig = $$"""
        {
            "type": "bar",
            "data": {
                "labels": {{labels}},
                "datasets": [{
                    "label": "Quotes",
                    "data": {{values}},
                    "backgroundColor": "oklch(0.7154 0.1932 316.0 / 0.7)",
                    "borderColor": "oklch(0.7154 0.1932 316.0)",
                    "borderWidth": 1,
                    "borderRadius": 4
                }]
            },
            "options": {
                "indexAxis": "y",
                "responsive": true,
                "maintainAspectRatio": false,
                "plugins": { "legend": { "display": false } },
                "scales": {
                    "x": { "beginAtZero": true, "ticks": { "precision": 0, "maxTicksLimit": 5 } },
                    "y": { "grid": { "display": false } }
                }
            }
        }
    """;
    <div class="mt-2" style="height:@(Math.Max(100, Model.Count * 36))px; position:relative;">
        <canvas data-chart-type="bar" data-chart-config='@Html.Raw(chartConfig)'></canvas>
    </div>
}
