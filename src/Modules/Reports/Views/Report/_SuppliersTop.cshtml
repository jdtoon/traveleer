@model List<TopSupplierDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No supplier data for this period.</p>
}
else
{
    <div class="overflow-x-auto mt-2">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Supplier</th>
                    <th class="text-right">Items</th>
                    <th class="text-right">Total Cost</th>
                </tr>
            </thead>
            <tbody>
                @{ var rank = 1; }
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="text-base-content/40">@(rank++)</td>
                        <td>
                            <a href="@Url.Action("Details", "Supplier", new { slug, id = s.Id })" class="link link-hover">
                                @s.Name
                            </a>
                        </td>
                        <td class="text-right font-mono text-xs">@s.BookingItemCount</td>
                        <td class="text-right font-mono text-xs">@s.TotalCost.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
