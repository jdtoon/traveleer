@model List<RevenueMonthlyDto>

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No revenue data for this period.</p>
}
else
{
    var max = Model.Max(r => r.Total);
    <div class="flex flex-col gap-2 mt-2">
        @foreach (var item in Model)
        {
            var pct = max > 0 ? (int)(item.Total / max * 100) : 0;
            <div class="flex items-center gap-2">
                <span class="text-xs w-16 text-base-content/60">@item.Month</span>
                <div class="flex-1 bg-base-200 rounded-full h-4 overflow-hidden">
                    <div class="bg-primary h-full rounded-full" style="width: @(pct)%"></div>
                </div>
                <span class="text-xs font-mono w-20 text-right">@item.Total.ToString("N0")</span>
            </div>
        }
    </div>
}
