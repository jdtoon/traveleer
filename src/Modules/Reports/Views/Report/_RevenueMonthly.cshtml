@model List<RevenueMonthlyDto>

@if (!Model.Any())
{
    <p class="text-sm text-base-content/40 py-4 text-center">No revenue data for this period.</p>
}
else
{
    var labels = System.Text.Json.JsonSerializer.Serialize(Model.Select(r => r.Month).ToList());
    var values = System.Text.Json.JsonSerializer.Serialize(Model.Select(r => (double)r.Total).ToList());
    var chartConfig = $$"""
        {
            "type": "bar",
            "data": {
                "labels": {{labels}},
                "datasets": [{
                    "label": "Revenue",
                    "data": {{values}},
                    "backgroundColor": "oklch(0.6232 0.1883 259.81 / 0.7)",
                    "borderColor": "oklch(0.6232 0.1883 259.81)",
                    "borderWidth": 1,
                    "borderRadius": 4
                }]
            },
            "options": {
                "responsive": true,
                "maintainAspectRatio": false,
                "plugins": { "legend": { "display": false } },
                "scales": {
                    "y": { "beginAtZero": true, "ticks": { "maxTicksLimit": 5 } },
                    "x": { "grid": { "display": false } }
                }
            }
        }
    """;
    <div class="mt-2" style="height:180px; position:relative;">
        <canvas data-chart-type="bar" data-chart-config='@Html.Raw(chartConfig)'></canvas>
    </div>
}
