@model saas.Modules.Clients.DTOs.ClientDetailsDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<dialog class="modal modal-open modal-middle">
    <div class="modal-box max-w-2xl">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h3 class="text-lg font-bold">@Model.Name</h3>
                <p class="opacity-60">Client profile</p>
            </div>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">x</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div class="card bg-base-200">
                <div class="card-body p-4">
                    <div class="text-xs uppercase tracking-wide opacity-60">Company</div>
                    <div class="font-medium">@(Model.Company ?? "-")</div>
                </div>
            </div>
            <div class="card bg-base-200">
                <div class="card-body p-4">
                    <div class="text-xs uppercase tracking-wide opacity-60">Country</div>
                    <div class="font-medium">@(Model.Country ?? "-")</div>
                </div>
            </div>
            <div class="card bg-base-200">
                <div class="card-body p-4">
                    <div class="text-xs uppercase tracking-wide opacity-60">Email</div>
                    <div class="font-medium">@(Model.Email ?? "-")</div>
                </div>
            </div>
            <div class="card bg-base-200">
                <div class="card-body p-4">
                    <div class="text-xs uppercase tracking-wide opacity-60">Phone</div>
                    <div class="font-medium">@(Model.Phone ?? "-")</div>
                </div>
            </div>
            <div class="card bg-base-200 md:col-span-2">
                <div class="card-body p-4">
                    <div class="text-xs uppercase tracking-wide opacity-60">Address</div>
                    <div class="font-medium whitespace-pre-line">@(Model.Address ?? "-")</div>
                </div>
            </div>
            <div class="card bg-base-200 md:col-span-2">
                <div class="card-body p-4">
                    <div class="text-xs uppercase tracking-wide opacity-60">Notes</div>
                    <div class="whitespace-pre-line">@(Model.Notes ?? "No notes recorded.")</div>
                </div>
            </div>
        </div>

        <div class="divider my-2"></div>
        <div id="client-recent-bookings"
             hx-get="@Url.Action("RecentBookings", "Client", new { slug, id = Model.Id })"
             hx-trigger="load, @saas.Modules.Bookings.Events.BookingEvents.Refresh from:body"
             hx-swap="innerHTML">
            <span class="loading loading-spinner loading-lg"></span>
        </div>

        <div class="divider my-2"></div>
        <div id="client-recent-quotes"
             hx-get="@Url.Action("RecentQuotes", "Client", new { slug, id = Model.Id })"
             hx-trigger="load, @saas.Modules.Quotes.Events.QuoteEvents.Refresh from:body"
             hx-swap="innerHTML">
            <span class="loading loading-spinner loading-lg"></span>
        </div>

        <div class="divider my-2"></div>
        <div id="client-documents"
             hx-get="@Url.Action("ClientDocuments", "Document", new { slug, clientId = Model.Id })"
             hx-trigger="load, @saas.Modules.Bookings.Events.BookingEvents.ClientDocumentsRefresh from:body"
             hx-swap="innerHTML">
            <span class="loading loading-spinner loading-lg"></span>
        </div>

        <div class="divider my-2"></div>
        <div id="client-communications"
             hx-get="@Url.Action("ClientComms", "Communication", new { slug, clientId = Model.Id })"
             hx-trigger="load, @saas.Modules.Communications.Events.CommunicationEvents.Refresh from:body"
             hx-swap="innerHTML">
            <span class="loading loading-spinner loading-lg"></span>
        </div>

        <div class="modal-action">
            <button type="button" class="btn btn-primary" hx-get="/ui/modal-close" hx-target="#modal-container">Close</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>