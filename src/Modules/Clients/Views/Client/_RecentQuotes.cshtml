@model List<saas.Modules.Clients.DTOs.ClientRecentQuoteDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="space-y-3">
    <div class="flex items-center justify-between gap-2">
        <h4 class="font-semibold">Recent Quotes</h4>
        <a href="/@slug/quotes" class="btn btn-ghost btn-xs">View all</a>
    </div>

    @if (Model.Count == 0)
    {
        <p class="text-sm opacity-60">No quotes linked to this client yet.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Ref</th>
                        <th>Status</th>
                        <th>Currency</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quote in Model)
                    {
                        <tr>
                            <td>
                                <a href="@Url.Action("Details", "Quote", new { slug, id = quote.Id })" class="link link-hover">
                                    @quote.ReferenceNumber
                                </a>
                            </td>
                            <td><span class="badge badge-ghost badge-xs">@quote.Status</span></td>
                            <td class="text-xs">@quote.OutputCurrencyCode</td>
                            <td class="text-xs opacity-60">@quote.CreatedAt.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
