@{
    ViewData["Title"] = "Clients";
    var search = ViewData["Search"]?.ToString();
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Clients</h1>
            <p class="opacity-60">Manage client records for your tenant.</p>
        </div>
        <has-permission name="clients.create">
            <button class="btn btn-primary btn-sm"
                    hx-get="@Url.Action("New", "Client", new { slug = ViewContext.RouteData.Values["slug"] })"
                    hx-target="#modal-container">
                + New Client
            </button>
        </has-permission>
    </div>

    <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body gap-4">
            <form id="client-filters" class="flex flex-col md:flex-row gap-3">
                <label class="input input-bordered flex items-center gap-2 w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text"
                           name="search"
                           value="@search"
                           placeholder="Search by name, company, email, phone, or country"
                           class="grow"
                           hx-get="@Url.Action("List", "Client", new { slug = ViewContext.RouteData.Values["slug"] })"
                           hx-target="#client-list"
                           hx-trigger="keyup changed delay:300ms, search"
                           hx-include="#client-filters" />
                </label>
            </form>

            <div id="client-list"
                 hx-get="@Url.Action("List", "Client", new { slug = ViewContext.RouteData.Values["slug"], search })"
                 hx-trigger="load, @saas.Modules.Clients.Events.ClientEvents.Refresh from:body"
                 hx-swap="innerHTML show:none">
                <span class="loading loading-spinner loading-lg"></span>
            </div>
        </div>
    </div>
</div>