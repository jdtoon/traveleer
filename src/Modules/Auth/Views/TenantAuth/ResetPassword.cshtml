@model string
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Reset Password";
    var slug = ViewData["TenantSlug"]?.ToString() ?? "";
    var email = ViewData["Email"]?.ToString() ?? "";
    var token = ViewData["Token"]?.ToString() ?? "";
}

<div class="flex items-center justify-center p-4 py-12">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
        <div class="card-body">
            <h1 class="card-title text-2xl mb-2">Reset your password</h1>
            <p class="text-base-content/70 mb-4">Choose a new password for your account.</p>

            @if (!string.IsNullOrEmpty(Model))
            {
                <div class="alert alert-error mb-4">@Model</div>
            }

            <form method="post" action="/@slug/reset-password" class="space-y-3">
                <input type="hidden" name="email" value="@email" />
                <input type="hidden" name="token" value="@token" />

                <label class="form-control w-full">
                    <span class="label-text">New Password</span>
                    <input type="password" name="newPassword" class="input input-bordered w-full" required
                           autocomplete="new-password" minlength="8" />
                    <span class="label-text-alt mt-1 text-base-content/60">At least 8 characters</span>
                </label>

                <label class="form-control w-full">
                    <span class="label-text">Confirm Password</span>
                    <input type="password" name="confirmPassword" class="input input-bordered w-full" required
                           autocomplete="new-password" minlength="8" />
                </label>

                <button class="btn btn-primary w-full" type="submit">Reset Password</button>
            </form>
        </div>
    </div>
</div>
