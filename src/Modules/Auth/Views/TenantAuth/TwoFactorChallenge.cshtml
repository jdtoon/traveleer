@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Two-Factor Authentication";
    var slug = ViewData["TenantSlug"]?.ToString() ?? "";
    var error = ViewData["Error"]?.ToString();
}

<div class="flex items-center justify-center p-4 py-12">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
        <div class="card-body">
            <h1 class="card-title text-2xl mb-2">Two-Factor Authentication</h1>
            <p class="text-sm opacity-70 mb-4">Enter the 6-digit code from your authenticator app to complete sign-in.</p>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-error mb-4">@error</div>
            }

            <form method="post" action="/@slug/two-factor-challenge" class="space-y-4">
                <div class="form-control w-full">
                    <label class="label" for="code">
                        <span class="label-text">Authentication Code</span>
                    </label>
                    <input type="text" id="code" name="code"
                           class="input input-bordered w-full text-center tracking-widest text-lg"
                           placeholder="000000"
                           maxlength="6"
                           inputmode="numeric"
                           pattern="[0-9]*"
                           autocomplete="one-time-code"
                           autofocus />
                </div>

                <button class="btn btn-primary w-full" type="submit">Verify</button>
            </form>

            <div class="divider text-xs opacity-50">OR</div>

            <form method="post" action="/@slug/two-factor-challenge" class="space-y-4">
                <div class="form-control w-full">
                    <label class="label" for="recoveryCode">
                        <span class="label-text">Recovery Code</span>
                    </label>
                    <input type="text" id="recoveryCode" name="recoveryCode"
                           class="input input-bordered w-full"
                           placeholder="Enter a recovery code" />
                </div>

                <button class="btn btn-outline w-full" type="submit">Use Recovery Code</button>
            </form>

            <div class="text-center mt-4">
                <a href="/@slug/login" class="link link-hover text-sm opacity-60">Back to login</a>
            </div>
        </div>
    </div>
</div>
