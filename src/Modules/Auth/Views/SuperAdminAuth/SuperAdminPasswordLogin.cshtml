@model string
@inject Microsoft.Extensions.Options.IOptions<saas.Shared.TurnstileOptions> TurnstileOptions
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Super Admin Login";
    var turnstile = TurnstileOptions.Value;
    var useTurnstile = string.Equals(turnstile.Provider, "Cloudflare", StringComparison.OrdinalIgnoreCase)
        && !string.IsNullOrWhiteSpace(turnstile.SiteKey);
    var passwordReset = Context.Request.Query["passwordReset"].ToString() == "true";
}

<div class="flex items-center justify-center p-4 py-12">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
        <div class="card-body">
            <h1 class="card-title text-2xl mb-4">Super Admin Login</h1>

            @if (passwordReset)
            {
                <div class="alert alert-success mb-4">Your password has been reset. You can now sign in.</div>
            }

            @if (!string.IsNullOrEmpty(Model))
            {
                <div class="alert alert-error mb-4">@Model</div>
            }

            <form method="post" action="/super-admin/login/password" class="space-y-3">
                <label class="form-control w-full">
                    <span class="label-text">Email</span>
                    <input type="email" name="email" class="input input-bordered w-full" required autocomplete="email" />
                </label>

                <label class="form-control w-full">
                    <span class="label-text">Password</span>
                    <input type="password" name="password" class="input input-bordered w-full" required autocomplete="current-password" />
                </label>

                <!-- Bot protection -->
                <input type="hidden" name="captchaToken" id="sa-pw-login-captcha-token"
                       value="@(useTurnstile ? string.Empty : "mock-captcha-token")">
                @if (useTurnstile)
                {
                    <div class="cf-turnstile" data-sitekey="@turnstile.SiteKey"
                         data-callback="onSaPwLoginTurnstile"
                         data-expired-callback="onSaPwLoginTurnstileExpired"></div>
                }

                <button class="btn btn-primary w-full" type="submit">Sign In</button>
            </form>

            <div class="text-center mt-2">
                <a href="/super-admin/forgot-password" class="link link-hover text-sm">Forgot your password?</a>
            </div>
        </div>
    </div>
</div>

@if (useTurnstile)
{
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script>
        function onSaPwLoginTurnstile(token) {
            document.getElementById("sa-pw-login-captcha-token").value = token;
        }
        function onSaPwLoginTurnstileExpired() {
            document.getElementById("sa-pw-login-captcha-token").value = "";
        }
    </script>
}
