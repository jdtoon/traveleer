@model string
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="flex items-center justify-center p-4 py-12">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
        <div class="card-body">
            <h1 class="card-title text-2xl mb-2">Forgot your password?</h1>
            <p class="text-base-content/70 mb-4">Enter your email and we'll send you a reset link.</p>

            @if (!string.IsNullOrEmpty(Model))
            {
                <div class="alert alert-error mb-4">@Model</div>
            }

            <form method="post" action="/super-admin/forgot-password" class="space-y-3">
                <label class="form-control w-full">
                    <span class="label-text">Email</span>
                    <input type="email" name="email" class="input input-bordered w-full" required autocomplete="email" />
                </label>

                <button class="btn btn-primary w-full" type="submit">Send Reset Link</button>
            </form>

            <div class="text-center mt-2">
                <a href="/super-admin/login" class="link link-hover text-sm">Back to sign in</a>
            </div>
        </div>
    </div>
</div>
