@model saas.Modules.Auth.Entities.AppUser
@inject saas.Shared.ITenantContext TenantContext
@{
    ViewData["Title"] = "Recovery Codes";
    var slug = TenantContext.Slug;
    var codes = ViewData["RecoveryCodes"] as List<string>;
}

<div class="max-w-lg mx-auto space-y-6">
    <h1 class="text-2xl font-bold">Two-Factor Authentication Enabled!</h1>

    <div class="alert alert-warning">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <div>
            <h3 class="font-bold">Save your recovery codes!</h3>
            <p class="text-sm">These codes can be used to access your account if you lose your authenticator. Each code can only be used once.</p>
        </div>
    </div>

    <div class="card bg-base-200">
        <div class="card-body">
            <div class="grid grid-cols-2 gap-2">
                @if (codes is not null)
                {
                    @foreach (var code in codes)
                    {
                        <div class="font-mono text-sm bg-base-300 px-3 py-2 rounded text-center">@code</div>
                    }
                }
            </div>

            <div class="card-actions justify-center mt-4">
                <button type="button" class="btn btn-outline btn-sm"
                        onclick="navigator.clipboard.writeText('@(codes is not null ? string.Join("\n", codes) : "")')">
                    Copy All
                </button>
            </div>
        </div>
    </div>

    <a href="/@slug/profile" class="btn btn-primary w-full">Done</a>
</div>
