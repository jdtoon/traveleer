@model saas.Data.PaginatedList<TaskListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"];
    var status = ViewBag.StatusFilter;
    var assignee = ViewBag.AssigneeFilter;
    var priority = ViewBag.PriorityFilter;
    var entityType = ViewBag.EntityTypeFilter;
    var listUrl = Url.Action("List", "Task", new { slug, status, assignee, priority, entityType, pageSize = Model.PageSize })!;

    string? linkedEntityUrl(TaskListItemDto task) => task.LinkedEntityType switch
    {
        "Booking" when task.LinkedEntityId.HasValue => Url.Action("Details", "Booking", new { slug, id = task.LinkedEntityId }),
        "Quote" when task.LinkedEntityId.HasValue => Url.Action("Details", "Quote", new { slug, id = task.LinkedEntityId }),
        "Client" when task.LinkedEntityId.HasValue => Url.Action("Index", "Client", new { slug }),
        _ => null
    };
}

@if (Model.Items.Count == 0)
{
    <div class="text-center text-base-content/60 py-6">
        <p>No tasks found.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Due Date</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Assignee</th>
                    <th>Linked To</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model.Items)
                {
                    <tr>
                        <td class="font-medium max-w-xs truncate">@task.Title</td>
                        <td>
                            @if (task.DueDate.HasValue)
                            {
                                <span class="@(task.IsOverdue ? "text-error font-semibold" : task.IsDueToday ? "text-warning font-semibold" : "")">
                                    @task.DueDate.Value.ToString("dd MMM yyyy")
                                </span>
                            }
                            else
                            {
                                <span class="opacity-40">—</span>
                            }
                        </td>
                        <td>
                            @switch (task.Priority)
                            {
                                case TaskPriority.Low:
                                    <span class="badge badge-ghost badge-sm">Low</span>
                                    break;
                                case TaskPriority.Normal:
                                    <span class="badge badge-info badge-sm">Normal</span>
                                    break;
                                case TaskPriority.High:
                                    <span class="badge badge-warning badge-sm">High</span>
                                    break;
                                case TaskPriority.Urgent:
                                    <span class="badge badge-error badge-sm">Urgent</span>
                                    break;
                            }
                        </td>
                        <td>
                            @switch (task.Status)
                            {
                                case AgentTaskStatus.Open:
                                    <span class="badge badge-outline badge-sm">Open</span>
                                    break;
                                case AgentTaskStatus.InProgress:
                                    <span class="badge badge-info badge-sm">In Progress</span>
                                    break;
                                case AgentTaskStatus.Completed:
                                    <span class="badge badge-success badge-sm">Completed</span>
                                    break;
                                case AgentTaskStatus.Cancelled:
                                    <span class="badge badge-ghost badge-sm">Cancelled</span>
                                    break;
                            }
                        </td>
                        <td>@(task.AssigneeName ?? task.AssigneeUserId ?? "Unassigned")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(task.LinkedEntityType))
                            {
                                var url = linkedEntityUrl(task);
                                var label = string.IsNullOrWhiteSpace(task.LinkedEntityLabel) ? task.LinkedEntityType : task.LinkedEntityLabel;

                                if (!string.IsNullOrWhiteSpace(url))
                                {
                                    <a href="@url"
                                       class="badge badge-ghost badge-sm gap-1 link-hover"
                                       hx-get="@(task.LinkedEntityType == "Client" ? Url.Action("Details", "Client", new { slug, id = task.LinkedEntityId }) : null)"
                                       hx-target="@(task.LinkedEntityType == "Client" ? "#modal-container" : null)">
                                        <span>@task.LinkedEntityType</span>
                                        <span>@label</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="badge badge-ghost badge-sm">@task.LinkedEntityType</span>
                                }
                            }
                        </td>
                        <td class="flex gap-1">
                            @if (task.Status is AgentTaskStatus.Open or AgentTaskStatus.InProgress)
                            {
                                <form method="post"
                                      action="@Url.Action("Complete", "Task", new { slug, id = task.Id })">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost btn-xs text-success"
                                            hx-post="@Url.Action("Complete", "Task", new { slug, id = task.Id })"
                                            hx-target="#task-list"
                                            hx-swap="innerHTML"
                                            title="Mark complete">
                                        ✓
                                    </button>
                                </form>
                            }
                            <button class="btn btn-ghost btn-xs"
                                    hx-get="@Url.Action("Edit", "Task", new { slug, id = task.Id })"
                                    hx-target="#modal-container">
                                Edit
                            </button>
                            <form method="post"
                                  action="@Url.Action("Delete", "Task", new { slug, id = task.Id })">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-xs text-error"
                                        hx-post="@Url.Action("Delete", "Task", new { slug, id = task.Id })"
                                        hx-target="#task-list"
                                        hx-swap="innerHTML"
                                        hx-confirm="Delete this task?">
                                    ✕
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="@Model.ToPagination(listUrl, "#task-list", true)" />
}
