@model TaskWidgetDto
@{
    var slug = ViewContext.RouteData.Values["slug"];
    
    string RelativeDateText(TaskListItemDto task)
    {
        if (!task.DueDate.HasValue) return "—";
        var due = task.DueDate.Value;
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        var days = due.DayNumber - today.DayNumber;
        
        if (days == 0) return "Today";
        if (days == 1) return "Tomorrow";
        if (days == -1) return "1d overdue";
        if (days < 0) return $"{Math.Abs(days)}d overdue";
        return $"In {days}d";
    }
}

<div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body gap-3">
        <div class="flex items-center justify-between">
            <h3 class="card-title text-base">Tasks</h3>
            @if (Model.OverdueCount > 0)
            {
                <span class="badge badge-error badge-sm">@Model.OverdueCount overdue</span>
            }
        </div>
        @if (Model.UpcomingTasks.Count == 0)
        {
            <p class="text-sm opacity-60">No pending tasks.</p>
        }
        else
        {
            <div class="flex flex-col gap-2">
                @foreach (var task in Model.UpcomingTasks)
                {
                    <div class="flex items-center justify-between text-sm">
                        <div class="flex items-center gap-2 min-w-0">
                            @switch (task.Priority)
                            {
                                case TaskPriority.High:
                                    <span class="w-2 h-2 rounded-full bg-warning shrink-0"></span>
                                    break;
                                case TaskPriority.Urgent:
                                    <span class="w-2 h-2 rounded-full bg-error shrink-0"></span>
                                    break;
                                default:
                                    <span class="w-2 h-2 rounded-full bg-base-300 shrink-0"></span>
                                    break;
                            }
                            <span class="truncate">@task.Title</span>
                        </div>
                        @if (task.DueDate.HasValue)
                        {
                            <span class="text-xs shrink-0 ml-2 font-medium @(task.IsOverdue ? "text-error" : task.IsDueToday ? "text-warning" : "text-base-content/60")" title="@task.DueDate.Value.ToString("dd MMM yyyy")">
                                @RelativeDateText(task)
                            </span>
                        }
                    </div>
                }
            </div>
        }
        <a href="/@slug/tasks" class="btn btn-ghost btn-xs btn-block mt-1">View all tasks</a>
    </div>
</div>
