@model dynamic
@{
    ViewData["Title"] = "Plan Change";
    var success = (bool)Model.Success;
    var slug = (string?)Model.Slug;
    var errorMessage = (string?)Model.ErrorMessage;
}

<div class="flex items-center justify-center p-4 py-12">
    <div class="card w-full max-w-2xl bg-base-100 shadow-xl">
        <div class="card-body">
            @if (success)
            {
                <div class="alert alert-success">
                    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        <h3 class="font-bold">Plan Changed Successfully!</h3>
                        <div class="text-sm mt-2">
                            <p>Your plan has been updated and payment confirmed.</p>
                            <p class="mt-2">
                                <a href="/@slug/billing" class="btn btn-sm btn-primary mt-2">
                                    Go to Billing →
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-error">
                    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        <h3 class="font-bold">Payment Issue</h3>
                        <p class="text-sm mt-1">@errorMessage</p>
                        <p class="mt-2">
                            <a href="/@slug/billing" class="btn btn-sm btn-outline mt-2">
                                ← Back to Billing
                            </a>
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
