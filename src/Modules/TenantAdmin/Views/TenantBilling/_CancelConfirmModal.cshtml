@model CancelConfirmViewModel

<dialog class="modal modal-open">
    <div class="modal-box max-w-md">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold text-error">Cancel Subscription</h3>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">✕</button>
        </div>

        <div class="space-y-4">
            <div class="alert alert-warning">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <div>
                    <p class="font-semibold">This action cannot be undone.</p>
                    <p class="text-sm mt-1">Your subscription will be cancelled immediately. You will lose access to paid features at the end of your current billing period.</p>
                </div>
            </div>

            <div>
                <p class="text-sm mb-2">To confirm, type <strong class="select-all">@Model.TenantName</strong> below:</p>
                <input type="text"
                       id="cancel-confirm-input"
                       name="confirmName"
                       class="input input-bordered w-full"
                       placeholder="@Model.TenantName"
                       autocomplete="off"
                       oninput="document.getElementById('cancel-confirm-btn').disabled = this.value.trim().toLowerCase() !== '@Model.TenantName.ToLowerInvariant()'" />
            </div>
        </div>

        <div class="modal-action">
            <button type="button" class="btn" hx-get="/ui/modal-close" hx-target="#modal-container">Go back</button>
            <button id="cancel-confirm-btn"
                    class="btn btn-error"
                    disabled
                    hx-post="@Url.Action("Cancel", "TenantBilling", new { slug = ViewContext.RouteData.Values["slug"] })"
                    hx-include="#cancel-confirm-input"
                    hx-target="#modal-container"
                    hx-disabled-elt="this">
                <span class="htmx-indicator loading loading-spinner loading-sm"></span>
                Cancel Subscription
            </button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
