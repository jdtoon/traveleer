@model saas.Modules.TenantAdmin.Models.PlanChangeConfirmViewModel
@{
    var p = Model.Preview;
}

<dialog class="modal modal-open">
    <div class="modal-box max-w-lg">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold">Confirm Plan Change</h3>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">✕</button>
        </div>

        <div class="space-y-3">
            <!-- Plan change summary -->
            <div class="flex items-center gap-2 text-sm">
                <span class="badge badge-outline">@p.CurrentPlanName</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
                <span class="badge @(p.IsUpgrade ? "badge-success" : "badge-warning")">@p.NewPlanName</span>
            </div>

            <!-- Proration breakdown -->
            <div class="bg-base-200 rounded-lg p-4 space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="opacity-70">Current plan (@p.CurrentPlanName)</span>
                    <span>R @p.CurrentPlanPrice.ToString("N2")/mo</span>
                </div>
                <div class="flex justify-between">
                    <span class="opacity-70">New plan (@p.NewPlanName)</span>
                    <span>R @p.NewPlanPrice.ToString("N2")/mo</span>
                </div>
                <div class="divider my-1"></div>
                <div class="flex justify-between">
                    <span class="opacity-70">Remaining days in cycle</span>
                    <span>@p.RemainingDays of @p.TotalCycleDays days</span>
                </div>
                <div class="flex justify-between">
                    <span class="opacity-70">Unused credit from @p.CurrentPlanName</span>
                    <span class="text-success">−R @p.UnusedCredit.ToString("N2")</span>
                </div>
                <div class="flex justify-between">
                    <span class="opacity-70">Pro-rated cost for @p.NewPlanName</span>
                    <span>R @p.ProratedNewCost.ToString("N2")</span>
                </div>

                <div class="divider my-1"></div>

                @if (p.AmountDue > 0)
                {
                    <div class="flex justify-between font-bold text-lg">
                        <span>Amount due now</span>
                        <span>R @p.AmountDue.ToString("N2")</span>
                    </div>
                }
                else if (p.CreditForNextCycle > 0)
                {
                    <div class="flex justify-between font-bold text-lg">
                        <span>Credit towards next cycle</span>
                        <span class="text-success">R @p.CreditForNextCycle.ToString("N2")</span>
                    </div>
                }
                else
                {
                    <div class="flex justify-between font-bold text-lg">
                        <span>Amount due now</span>
                        <span>R 0.00</span>
                    </div>
                }
            </div>

            @if (p.IsUpgrade)
            {
                <div class="alert alert-info text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>You'll be charged a pro-rated amount for the remaining @p.RemainingDays days. Your new plan starts immediately.</span>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                    </svg>
                    @if (p.CreditForNextCycle > 0)
                    {
                        <span>Downgrade takes effect immediately. R @p.CreditForNextCycle.ToString("N2") credit will apply to your next billing cycle.</span>
                    }
                    else
                    {
                        <span>Downgrade takes effect immediately. Some features may no longer be available.</span>
                    }
                </div>
            }
        </div>

        <div class="modal-action">
            <button type="button" class="btn" onclick="this.closest('.modal').classList.remove('modal-open')">Cancel</button>
            <button class="btn btn-primary"
                    hx-post="@Url.Action("ChangePlan", "TenantBilling", new { slug = ViewContext.RouteData.Values["slug"] })"
                    hx-vals='{"planId": "@Model.NewPlanId"}'
                    hx-target="#modal-container">
                @(p.IsUpgrade ? "Upgrade Now" : "Confirm Downgrade")
            </button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="this.closest('.modal').classList.remove('modal-open')">close</button>
    </form>
</dialog>
