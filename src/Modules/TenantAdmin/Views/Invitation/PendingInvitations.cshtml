@model List<saas.Modules.TenantAdmin.Entities.TeamInvitation>
@inject saas.Shared.ITenantContext TenantContext
@{
    ViewData["Title"] = "Pending Invitations";
    var slug = TenantContext.Slug;
}

<div class="max-w-3xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold">Pending Invitations</h1>
            <p class="text-base-content/60 text-sm mt-1">Team invitations awaiting acceptance.</p>
        </div>
        <a href="/@slug/admin/users" class="btn btn-ghost btn-sm">&larr; Back to Users</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="card bg-base-200">
            <div class="card-body text-center">
                <p class="text-base-content/60">No pending invitations.</p>
            </div>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Invited By</th>
                        <th>Expires</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model)
                    {
                        <tr>
                            <td>@inv.Email</td>
                            <td>
                                @if (!string.IsNullOrEmpty(inv.RoleName))
                                {
                                    <span class="badge badge-sm">@inv.RoleName</span>
                                }
                                else
                                {
                                    <span class="text-base-content/40">—</span>
                                }
                            </td>
                            <td class="text-sm text-base-content/60">@inv.InvitedByEmail</td>
                            <td class="text-sm">@inv.ExpiresAt.ToString("MMM dd, yyyy")</td>
                            <td class="space-x-1">
                                <form method="post" action="/@slug/admin/invitation/resend/@inv.Id" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-ghost">Resend</button>
                                </form>
                                <form method="post" action="/@slug/admin/invitation/revoke/@inv.Id" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-error btn-outline"
                                            onclick="return confirm('Revoke this invitation?')">Revoke</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
