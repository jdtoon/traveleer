@model saas.Modules.TenantAdmin.Models.TenantSettingsViewModel
@inject saas.Shared.ITenantContext TenantContext
@{
    ViewData["Title"] = "Organization Settings";
    var slug = TenantContext.Slug;
}

<div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-2xl font-bold">Organization Settings</h1>

    @if (ViewData["Success"] is string success)
    {
        <div class="alert alert-success">
            <span>@success</span>
        </div>
    }
    @if (ViewData["Error"] is string error)
    {
        <div class="alert alert-error">
            <span>@error</span>
        </div>
    }

    <!-- General Settings -->
    <div class="card bg-base-200">
        <div class="card-body">
            <h2 class="card-title">General</h2>
            <form hx-post="/@slug/admin/settings/update-general" hx-target="#main-content">
                <div class="form-control w-full mb-4">
                    <label class="label"><span class="label-text">Organization Name</span></label>
                    <input type="text" name="Name" value="@Model.Name" class="input input-bordered w-full" required />
                </div>
                <div class="form-control w-full mb-4">
                    <label class="label"><span class="label-text">Contact Email</span></label>
                    <input type="email" name="ContactEmail" value="@Model.ContactEmail" class="input input-bordered w-full" />
                    <label class="label"><span class="label-text-alt">Primary contact email for this organization</span></label>
                </div>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
        </div>
    </div>

    <!-- Organization Info (Read-only) -->
    <div class="card bg-base-200">
        <div class="card-body">
            <h2 class="card-title">Organization Info</h2>
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <span class="text-base-content/60">Slug</span>
                    <p class="font-mono font-medium">@Model.Slug</p>
                </div>
                <div>
                    <span class="text-base-content/60">Status</span>
                    <p>
                        @if (Model.Status == "Active")
                        {
                            <span class="badge badge-success badge-sm">@Model.Status</span>
                        }
                        else
                        {
                            <span class="badge badge-warning badge-sm">@Model.Status</span>
                        }
                    </p>
                </div>
                <div>
                    <span class="text-base-content/60">Current Plan</span>
                    <p class="font-medium">@Model.PlanName</p>
                </div>
                <div>
                    <span class="text-base-content/60">Created</span>
                    <p class="font-medium">@Model.CreatedAt.ToString("MMMM d, yyyy")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Danger Zone -->
    <div class="card bg-base-200 border border-error/30">
        <div class="card-body">
            <h2 class="card-title text-error">Danger Zone</h2>
            @if (Model.IsDeleted)
            {
                <div class="alert alert-warning">
                    <div>
                        <p class="font-semibold">Deletion Scheduled</p>
                        <p class="text-sm">This organization is scheduled for permanent deletion on
                            <strong>@Model.ScheduledDeletionAt?.ToString("MMMM d, yyyy")</strong>.
                            All data will be permanently removed after this date.
                        </p>
                    </div>
                </div>
                <button hx-post="/@slug/admin/settings/cancel-deletion" hx-target="#main-content"
                        class="btn btn-success btn-sm mt-2">Cancel Deletion</button>
            }
            else
            {
                <p class="text-sm text-base-content/60 mb-4">
                    Once you delete an organization, there is a 30-day grace period before data is permanently removed.
                    You can cancel the deletion during this period.
                </p>
                <button hx-post="/@slug/admin/settings/request-deletion" hx-target="#main-content"
                        hx-confirm="Are you sure you want to delete this organization? You have 30 days to cancel."
                        class="btn btn-error btn-sm">
                    Delete Organization
                </button>
            }
        </div>
    </div>
</div>
