@model ManageUserRolesViewModel

<dialog class="modal modal-open">
    <div class="modal-box">
        <form hx-post="@Url.Action("SaveUserRoles", "TenantAdmin", new { slug = ViewContext.RouteData.Values["slug"] })" hx-target="#modal-container">
            <input type="hidden" name="userId" value="@Model.UserId" />
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">Manage Roles</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">✕</button>
            </div>

            <p class="text-sm opacity-70 mb-4">Assign roles to <span class="font-medium">@Model.UserEmail</span></p>

            <div class="space-y-2">
                @foreach (var role in Model.AllRoles)
                {
                    var isChecked = Model.AssignedRoleIds.Contains(role.Id);
                    <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-base-200 cursor-pointer">
                        <input type="checkbox" name="roleIds" value="@role.Id"
                               class="checkbox checkbox-sm checkbox-primary"
                               @(isChecked ? "checked" : "") />
                        <div>
                            <span class="font-medium text-sm">@role.Name</span>
                            @if (role.IsSystemRole)
                            {
                                <span class="badge badge-neutral badge-xs ml-1">System</span>
                            }
                            @if (!string.IsNullOrEmpty(role.Description))
                            {
                                <p class="text-xs opacity-60">@role.Description</p>
                            }
                        </div>
                    </label>
                }
            </div>

            <div class="modal-action">
                <button type="button" class="btn" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Roles</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
