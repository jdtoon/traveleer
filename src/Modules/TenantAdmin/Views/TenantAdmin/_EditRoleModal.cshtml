@model RoleListItem

<dialog class="modal modal-open">
    <div class="modal-box">
        <form hx-post="@Url.Action("EditRole", "TenantAdmin", new { slug = ViewContext.RouteData.Values["slug"] })" hx-target="#modal-container">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">Edit Role</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" hx-get="/ui/modal-close" hx-target="#modal-container">✕</button>
            </div>

            <div class="form-control w-full mb-4">
                <label class="label" for="name"><span class="label-text">Role Name</span></label>
                <input type="text" id="name" name="name"
                       class="input input-bordered w-full"
                       value="@Model.Name" required autofocus />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label" for="description"><span class="label-text">Description</span></label>
                <textarea id="description" name="description"
                          class="textarea textarea-bordered w-full" rows="2">@Model.Description</textarea>
            </div>

            <div class="modal-action">
                <button type="button" class="btn" hx-get="/ui/modal-close" hx-target="#modal-container">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button hx-get="/ui/modal-close" hx-target="#modal-container">close</button>
    </form>
</dialog>
