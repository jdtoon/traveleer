@model List<RoleListItem>
@inject ITenantContext TenantContext
@{
    ViewData["Title"] = "Roles";
    var slug = TenantContext.Slug;
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold">Roles</h1>
            <p class="opacity-60">Manage roles and permissions</p>
        </div>
        <has-permission name="roles.create">
            <button class="btn btn-primary btn-sm"
                    hx-get="@Url.Action("CreateRole", "TenantAdmin", new { slug })"
                    hx-target="#modal-container">
                + New Role
            </button>
        </has-permission>
    </div>

    <div id="role-list">
        <partial name="_RoleList" model="Model" />
    </div>
</div>
