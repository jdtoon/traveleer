@model saas.Modules.Onboarding.DTOs.OnboardingDefaultsStepDto
@using saas.Modules.Onboarding.DTOs
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="card border border-base-300 bg-base-100 shadow-sm">
    <div class="card-body gap-6">
        <div>
            <p class="text-xs uppercase tracking-[0.25em] opacity-60">Step 2</p>
            <h2 class="mt-2 text-2xl font-semibold">Choose the defaults your team should start from.</h2>
            <p class="mt-2 text-sm opacity-70">These values feed the quote builder immediately, so the first quote feels intentional instead of generic.</p>
        </div>

        <form method="post" action="@Url.Action("SaveDefaults", "Onboarding", new { slug })" class="space-y-5">
            @Html.AntiForgeryToken()
            <div class="grid gap-4 md:grid-cols-2">
                <div class="form-control w-full">
                    <label class="label" for="QuotePrefix"><span class="label-text">Quote prefix</span></label>
                    <input id="QuotePrefix" name="QuotePrefix" value="@Model.QuotePrefix" class="input input-bordered w-full" />
                    <span asp-validation-for="QuotePrefix" class="text-error text-sm mt-1"></span>
                </div>
                <div class="form-control w-full">
                    <label class="label" for="DefaultQuoteValidityDays"><span class="label-text">Default validity days</span></label>
                    <input id="DefaultQuoteValidityDays" type="number" min="1" max="365" name="DefaultQuoteValidityDays" value="@Model.DefaultQuoteValidityDays" class="input input-bordered w-full" />
                    <span asp-validation-for="DefaultQuoteValidityDays" class="text-error text-sm mt-1"></span>
                </div>
                <div class="form-control w-full">
                    <label class="label" for="DefaultQuoteMarkupPercentage"><span class="label-text">Default markup %</span></label>
                    <input id="DefaultQuoteMarkupPercentage" type="number" step="0.01" min="0" name="DefaultQuoteMarkupPercentage" value="@(Model.DefaultQuoteMarkupPercentage?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))" class="input input-bordered w-full" placeholder="Leave blank to follow the base currency" />
                    <span asp-validation-for="DefaultQuoteMarkupPercentage" class="text-error text-sm mt-1"></span>
                </div>
                <div class="form-control w-full justify-end">
                    <label class="label cursor-pointer justify-start gap-3 pt-8">
                        <input type="checkbox" name="QuoteResetSequenceYearly" value="true" class="checkbox" checked="@Model.QuoteResetSequenceYearly" />
                        <span class="label-text">Reset numbering each year</span>
                    </label>
                </div>
            </div>

            <div class="space-y-3">
                <div>
                    <h3 class="text-lg font-semibold">Where should your team jump next?</h3>
                    <p class="text-sm opacity-70">Pick the workspace that matters most for the first week of use.</p>
                </div>
                <div class="grid gap-3 md:grid-cols-3">
                    @foreach (var option in new[]
                    {
                        new { Value = OnboardingWorkspaceOptions.Quotes, Title = "Quotes", Copy = "Start selling with a saved quote builder flow." },
                        new { Value = OnboardingWorkspaceOptions.RateCards, Title = "Rate Cards", Copy = "Load supplier contracts and seasons first." },
                        new { Value = OnboardingWorkspaceOptions.Bookings, Title = "Bookings", Copy = "Track live trips and supplier confirmations." }
                    })
                    {
                        var isSelected = string.Equals(Model.PreferredWorkspace, option.Value, StringComparison.OrdinalIgnoreCase);
                        <label class="cursor-pointer rounded-box border p-4 transition @((isSelected ? "border-primary bg-primary/10" : "border-base-300 bg-base-100"))">
                            <input type="radio" name="PreferredWorkspace" value="@option.Value" class="sr-only" checked="@isSelected" />
                            <div class="font-semibold">@option.Title</div>
                            <div class="mt-2 text-sm opacity-70">@option.Copy</div>
                        </label>
                    }
                </div>
                <span asp-validation-for="PreferredWorkspace" class="text-error text-sm mt-1"></span>
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="btn btn-primary">Save and continue</button>
                <a class="btn btn-ghost" href="@Url.Action("Index", "Onboarding", new { slug, step = 1 })">Back to identity</a>
            </div>
        </form>
    </div>
</div>
