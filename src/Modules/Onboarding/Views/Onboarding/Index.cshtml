@model saas.Modules.Onboarding.DTOs.OnboardingPageDto
@{
    ViewData["Title"] = "Onboarding";
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="space-y-6">
        <div class="overflow-hidden rounded-[2rem] border border-base-300 bg-base-100 shadow-sm">
            <div class="px-6 py-6" style="background: linear-gradient(135deg, @Model.Preview.SecondaryColor 0%, @Model.Preview.PrimaryColor 100%); color: @Model.Preview.SecondaryTextColor;">
                <p class="text-xs uppercase tracking-[0.25em] opacity-70">First-use setup</p>
                <h1 class="mt-3 text-3xl font-semibold">Launch @Model.TenantName with confidence.</h1>
                <p class="mt-3 max-w-xl text-sm opacity-80">Set the public identity, default quote behavior, and the workspace your team should land in first.</p>
            </div>
            <div class="space-y-4 p-6">
                @foreach (var item in Model.Steps)
                {
                    var isInteractive = item.IsAvailable || item.IsComplete;
                    var itemClasses = item.IsCurrent
                        ? "border-primary bg-primary/10"
                        : item.IsComplete
                            ? "border-success/30 bg-success/10"
                            : "border-base-300 bg-base-100";

                    <div class="rounded-box border p-4 @itemClasses">
                        <div class="flex items-start gap-4">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full border border-current/20 text-sm font-semibold">@item.Number</div>
                            <div class="min-w-0 flex-1">
                                <div class="flex items-center justify-between gap-3">
                                    <div>
                                        <h2 class="font-semibold">@item.Title</h2>
                                        <p class="text-sm opacity-70">@item.Description</p>
                                    </div>
                                    @if (item.IsComplete)
                                    {
                                        <span class="badge badge-success badge-sm">Done</span>
                                    }
                                    else if (item.IsCurrent)
                                    {
                                        <span class="badge badge-primary badge-sm">Current</span>
                                    }
                                </div>
                                @if (isInteractive)
                                {
                                    <div class="mt-3">
                                        <button type="button"
                                                class="btn btn-ghost btn-sm"
                                                hx-get="@Url.Action("Step", "Onboarding", new { slug, step = item.Number })"
                                                hx-target="#onboarding-step"
                                                hx-swap="innerHTML">
                                            View step
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (Model.CanSkip && !Model.IsCompleted)
                {
                    <form method="post" action="@Url.Action("Skip", "Onboarding", new { slug })" class="pt-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-ghost btn-sm">Skip for now</button>
                    </form>
                }
            </div>
        </div>

        <div class="card overflow-hidden border border-base-300 bg-base-100 shadow-sm">
            <div class="px-6 py-5" style="background: linear-gradient(135deg, @Model.Preview.SecondaryColor 0%, @Model.Preview.PrimaryColor 100%); color: @Model.Preview.SecondaryTextColor;">
                <div class="flex items-center gap-4">
                    @if (!string.IsNullOrWhiteSpace(Model.Preview.LogoUrl))
                    {
                        <div class="flex h-14 w-14 items-center justify-center overflow-hidden rounded-2xl bg-white/90 p-2 shadow-sm">
                            <img src="@Model.Preview.LogoUrl" alt="@Model.Preview.EffectiveAgencyName logo" class="max-h-full max-w-full object-contain" />
                        </div>
                    }
                    else
                    {
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/15 text-lg font-semibold uppercase">@Model.Preview.EffectiveAgencyName[..1]</div>
                    }
                    <div>
                        <p class="text-xs uppercase tracking-[0.2em] opacity-70">Live preview</p>
                        <h2 class="mt-2 text-xl font-semibold">@Model.Preview.EffectiveAgencyName</h2>
                        <p class="text-sm opacity-80">@Model.Preview.EffectiveContactEmail</p>
                    </div>
                </div>
            </div>
            <div class="card-body gap-4">
                <div class="rounded-box border border-base-300 bg-base-200/40 p-4">
                    <div class="text-xs uppercase tracking-[0.2em] opacity-60">Next quote reference</div>
                    <div class="mt-2 text-2xl font-semibold">@Model.Preview.PreviewReferenceNumber</div>
                </div>
                <div class="grid gap-3 md:grid-cols-2">
                    <div class="rounded-box p-4 text-sm" style="background-color: @Model.Preview.PrimaryColor; color: @Model.Preview.PrimaryTextColor;">
                        <div class="text-xs uppercase tracking-[0.2em] opacity-70">Primary</div>
                        <div class="mt-2 font-semibold">Buttons and highlights</div>
                        <div class="mt-1 opacity-80">@Model.Preview.PrimaryColor</div>
                    </div>
                    <div class="rounded-box p-4 text-sm" style="background-color: @Model.Preview.SecondaryColor; color: @Model.Preview.SecondaryTextColor;">
                        <div class="text-xs uppercase tracking-[0.2em] opacity-70">Secondary</div>
                        <div class="mt-2 font-semibold">Sidebar and depth</div>
                        <div class="mt-1 opacity-80">@Model.Preview.SecondaryColor</div>
                    </div>
                </div>
                <div class="rounded-box border border-dashed border-base-300 bg-base-200/30 p-4 text-sm opacity-80">
                    <div>Preferred launch workspace</div>
                    <div class="mt-2 text-lg font-semibold">@Model.Preview.PreferredWorkspaceLabel</div>
                    <div class="mt-2">After setup, your team can jump straight here.</div>
                </div>
            </div>
        </div>
    </section>

    <section id="onboarding-step" class="space-y-6">
        @if (Model.CurrentStep == 1)
        {
            <partial name="_IdentityStep" model="Model.IdentityStep" />
        }
        else if (Model.CurrentStep == 2)
        {
            <partial name="_DefaultsStep" model="Model.DefaultsStep" />
        }
        else
        {
            <partial name="_CompletionStep" model="Model.CompletionStep" />
        }
    </section>
</div>
