@model saas.Modules.Settings.DTOs.SettingsDeleteConfirmDto

<dialog class="modal modal-open modal-middle">
    <div class="modal-box max-w-md">
        <h3 class="text-lg font-bold">@Model.Title</h3>
        <p class="py-4 text-sm opacity-70">@Model.Message</p>
        <form hx-post="@Model.DeleteUrl" hx-target="#modal-container">
            @Html.AntiForgeryToken()
            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">Cancel</button>
                <button type="submit" class="btn btn-error">Delete</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="this.closest('.modal').classList.remove('modal-open')">close</button>
    </form>
</dialog>
