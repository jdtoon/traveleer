@model IReadOnlyList<saas.Modules.Settings.DTOs.CurrencyListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}
@if (Model.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No currencies yet</h3>
        <p class="mt-2 opacity-70">Define a base currency and the markup defaults your pricing needs.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead><tr><th>Currency</th><th>Rate</th><th>Markup</th><th>Rounding</th><th>Base</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr class="hover">
                    <td>
                        <div class="font-medium">@item.Name</div>
                        <div class="text-xs opacity-60">@item.Code @if (!string.IsNullOrWhiteSpace(item.Symbol)) { <text>· @item.Symbol</text> }</div>
                    </td>
                    <td>@item.ExchangeRate.ToString("0.######")</td>
                    <td>@item.DefaultMarkup.ToString("0.##")%</td>
                    <td>@item.RoundingRule</td>
                    <td>
                        @if (item.IsBaseCurrency)
                        {
                            <span class="badge badge-success badge-sm">Base</span>
                        }
                        else
                        {
                            <span class="badge badge-ghost badge-sm">Standard</span>
                        }
                    </td>
                    <td class="text-right">
                        <has-permission name="masterdata.edit">
                            <div class="flex justify-end gap-2">
                                @if (!item.IsBaseCurrency)
                                {
                                    <form hx-post="@Url.Action("SetBaseCurrency", "Settings", new { slug, id = item.Id })" hx-target="#toast-container">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-ghost btn-xs">Set base</button>
                                    </form>
                                }
                                <div class="dropdown dropdown-end">
                                    <label tabindex="0" class="btn btn-ghost btn-xs">...</label>
                                    <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow-lg z-10 w-40">
                                        <li><button hx-get="@Url.Action("EditCurrency", "Settings", new { slug, id = item.Id })" hx-target="#modal-container">Edit</button></li>
                                        <li><button class="text-error" hx-get="@Url.Action("DeleteCurrencyConfirm", "Settings", new { slug, id = item.Id })" hx-target="#modal-container">Delete</button></li>
                                    </ul>
                                </div>
                            </div>
                        </has-permission>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
