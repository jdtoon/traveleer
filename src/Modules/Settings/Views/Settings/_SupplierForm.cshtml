@model saas.Modules.Settings.DTOs.SupplierDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var isEdit = Model.Id != Guid.Empty;
    var title = isEdit ? "Edit Supplier" : "New Supplier";
    var action = isEdit ? Url.Action("UpdateSupplier", "Settings", new { slug, id = Model.Id }) : Url.Action("CreateSupplier", "Settings", new { slug });
}
<dialog class="modal modal-open modal-middle">
    <div class="modal-box max-w-2xl">
        <form hx-post="@action" hx-target="#modal-container">
            @Html.AntiForgeryToken()
            <div class="flex items-center justify-between mb-4"><h3 class="text-lg font-bold">@title</h3><button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">x</button></div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control w-full md:col-span-2"><label class="label"><span class="label-text">Name</span></label><input asp-for="Name" class="input input-bordered w-full" /><span asp-validation-for="Name" class="text-error text-sm mt-1"></span></div>
                <div class="form-control w-full"><label class="label"><span class="label-text">Contact name</span></label><input asp-for="ContactName" class="input input-bordered w-full" /><span asp-validation-for="ContactName" class="text-error text-sm mt-1"></span></div>
                <div class="form-control w-full"><label class="label"><span class="label-text">Contact phone</span></label><input asp-for="ContactPhone" class="input input-bordered w-full" /><span asp-validation-for="ContactPhone" class="text-error text-sm mt-1"></span></div>
                <div class="form-control w-full md:col-span-2"><label class="label"><span class="label-text">Contact email</span></label><input asp-for="ContactEmail" class="input input-bordered w-full" /><span asp-validation-for="ContactEmail" class="text-error text-sm mt-1"></span></div>
                <div class="form-control w-full md:col-span-2"><label class="label"><span class="label-text">Notes</span></label><textarea asp-for="Notes" class="textarea textarea-bordered w-full" rows="4"></textarea><span asp-validation-for="Notes" class="text-error text-sm mt-1"></span></div>
                <label class="label cursor-pointer md:col-span-2 justify-start gap-3"><input asp-for="IsActive" class="toggle toggle-primary" /><span class="label-text">Active</span></label>
            </div>
            <div class="modal-action"><button type="button" class="btn btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">Cancel</button><button type="submit" class="btn btn-primary">Save</button></div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button onclick="this.closest('.modal').classList.remove('modal-open')">close</button></form>
</dialog>
