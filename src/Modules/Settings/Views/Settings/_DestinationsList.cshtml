@model saas.Data.PaginatedList<saas.Modules.Settings.DTOs.DestinationListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var listUrl = Url.Action("Destinations", "Settings", new { slug, pageSize = Model.PageSize })!;
}
@if (Model.Items.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No destinations yet</h3>
        <p class="mt-2 opacity-70">Add the places your agency actually sells so inventory can attach to them later.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead><tr><th>Name</th><th>Country</th><th>Region</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="hover">
                    <td class="font-medium">@item.Name</td>
                    <td>@(item.CountryName ?? "-") @if (!string.IsNullOrWhiteSpace(item.CountryCode)) { <span class="opacity-60">(@item.CountryCode)</span> }</td>
                    <td>@(item.Region ?? "-")</td>
                    <td><span class="badge @(item.IsActive ? "badge-success" : "badge-ghost") badge-sm">@(item.IsActive ? "Active" : "Inactive")</span></td>
                    <td class="text-right">
                        <has-permission name="masterdata.edit">
                            <div class="dropdown dropdown-end">
                                <label tabindex="0" class="btn btn-ghost btn-xs">...</label>
                                <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow-lg z-10 w-40">
                                    <li><button hx-get="@Url.Action("EditDestination", "Settings", new { slug, id = item.Id })" hx-target="#modal-container">Edit</button></li>
                                    <li><button class="text-error" hx-get="@Url.Action("DeleteDestinationConfirm", "Settings", new { slug, id = item.Id })" hx-target="#modal-container">Delete</button></li>
                                </ul>
                            </div>
                        </has-permission>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="@Model.ToPagination(listUrl, "#destinations-list")" />
}
