@{
    ViewData["Title"] = "Settings";
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var activeTab = ViewData["ActiveTab"]?.ToString() ?? "room-types";
    string tabClass(string tab) => activeTab == tab ? "tab tab-active" : "tab";
    string panelClass(string tab) => activeTab == tab ? "space-y-4" : "hidden space-y-4";
    string tabUrl(string tab) => Url.Action("Index", "Settings", new { slug, tab })!;
    string tabTrigger(string tab, string refreshEvent) => activeTab == tab ? $"load, {refreshEvent} from:body" : $"{refreshEvent} from:body";
}

<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-bold">Settings</h1>
        <p class="opacity-60">Manage the shared travel reference data your agency will use for inventory, rates, quotes, and bookings.</p>
    </div>

    <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body gap-6">
            <div role="tablist" class="tabs tabs-bordered flex-wrap gap-2">
                <a role="tab" href="@tabUrl("room-types")" class="@tabClass("room-types")">Room Types</a>
                <a role="tab" href="@tabUrl("meal-plans")" class="@tabClass("meal-plans")">Meal Plans</a>
                <a role="tab" href="@tabUrl("currencies")" class="@tabClass("currencies")">Currencies</a>
                <a role="tab" href="@tabUrl("destinations")" class="@tabClass("destinations")">Destinations</a>
                <a role="tab" href="@tabUrl("suppliers")" class="@tabClass("suppliers")">Suppliers</a>
                <a role="tab" href="@tabUrl("rate-categories")" class="@tabClass("rate-categories")">Rate Categories</a>
                <a role="tab" href="@tabUrl("users")" class="@tabClass("users")">Users</a>
            </div>

            <section id="tab-room-types" class="@panelClass("room-types")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Room Types</h2>
                        <p class="text-sm opacity-70">Define the room labels used by hotels and rate entry.</p>
                    </div>
                    <has-permission name="masterdata.edit">
                        <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewRoomType", "Settings", new { slug })" hx-target="#modal-container">+ New Room Type</button>
                    </has-permission>
                </div>
                <div id="room-types-list" hx-get="@Url.Action("RoomTypes", "Settings", new { slug })" hx-trigger="@tabTrigger("room-types", saas.Modules.Settings.Events.SettingsEvents.RoomTypesRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>

            <section id="tab-meal-plans" class="@panelClass("meal-plans")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Meal Plans</h2>
                        <p class="text-sm opacity-70">Keep accommodation board basis options consistent across rate cards.</p>
                    </div>
                    <has-permission name="masterdata.edit">
                        <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewMealPlan", "Settings", new { slug })" hx-target="#modal-container">+ New Meal Plan</button>
                    </has-permission>
                </div>
                <div id="meal-plans-list" hx-get="@Url.Action("MealPlans", "Settings", new { slug })" hx-trigger="@tabTrigger("meal-plans", saas.Modules.Settings.Events.SettingsEvents.MealPlansRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>

            <section id="tab-currencies" class="@panelClass("currencies")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Currencies</h2>
                        <p class="text-sm opacity-70">Manage exchange rates, base currency, markup defaults, and rounding rules.</p>
                    </div>
                    <has-permission name="masterdata.edit">
                        <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewCurrency", "Settings", new { slug })" hx-target="#modal-container">+ New Currency</button>
                    </has-permission>
                </div>
                <div id="currencies-list" hx-get="@Url.Action("Currencies", "Settings", new { slug })" hx-trigger="@tabTrigger("currencies", saas.Modules.Settings.Events.SettingsEvents.CurrenciesRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>

            <section id="tab-destinations" class="@panelClass("destinations")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Destinations</h2>
                        <p class="text-sm opacity-70">Store your core places once so inventory and quotes stay consistent.</p>
                    </div>
                      <div class="flex gap-2 items-center">
                          <input type="search" id="destinations-search" placeholder="Search destinations..." class="input input-sm input-bordered w-full max-w-xs" />
                          <has-permission name="masterdata.edit">
                              <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewDestination", "Settings", new { slug })" hx-target="#modal-container">+ New Destination</button>
                          </has-permission>
                      </div>
                </div>
                <div id="destinations-list" hx-get="@Url.Action("Destinations", "Settings", new { slug })" hx-trigger="@tabTrigger("destinations", saas.Modules.Settings.Events.SettingsEvents.DestinationsRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>

            <section id="tab-suppliers" class="@panelClass("suppliers")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Suppliers</h2>
                        <p class="text-sm opacity-70">Track hotel, transport, visa, and experience providers for your tenant.</p>
                    </div>
                      <div class="flex gap-2 items-center">
                          <input type="search" id="suppliers-search" placeholder="Search suppliers..." class="input input-sm input-bordered w-full max-w-xs" />
                          <has-permission name="masterdata.edit">
                              <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewSupplier", "Settings", new { slug })" hx-target="#modal-container">+ New Supplier</button>
                          </has-permission>
                      </div>
                </div>
                <div id="suppliers-list" hx-get="@Url.Action("Suppliers", "Settings", new { slug })" hx-trigger="@tabTrigger("suppliers", saas.Modules.Settings.Events.SettingsEvents.SuppliersRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>

            <section id="tab-rate-categories" class="@panelClass("rate-categories")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Rate Categories</h2>
                        <p class="text-sm opacity-70">Classify flights, excursions, transfers, and visa pricing in one place.</p>
                    </div>
                    <has-permission name="masterdata.edit">
                        <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewRateCategory", "Settings", new { slug })" hx-target="#modal-container">+ New Rate Category</button>
                    </has-permission>
                </div>
                <div id="rate-categories-list" hx-get="@Url.Action("RateCategories", "Settings", new { slug })" hx-trigger="@tabTrigger("rate-categories", saas.Modules.Settings.Events.SettingsEvents.RateCategoriesRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>

            <section id="tab-users" class="@panelClass("users")">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold">Users</h2>
                        <p class="text-sm opacity-70">See who has access. Full role and invitation management stays in Admin.</p>
                    </div>
                    <a href="/@slug/admin/users" class="btn btn-outline btn-sm">Manage Users & Roles</a>
                </div>
                <div id="settings-users-list" hx-get="@Url.Action("Users", "Settings", new { slug })" hx-trigger="@tabTrigger("users", saas.Modules.Settings.Events.SettingsEvents.UsersRefresh)" hx-swap="innerHTML show:none">
                    <span class="loading loading-spinner loading-lg"></span>
                </div>
            </section>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const destSearch = document.getElementById("destinations-search");
        if (destSearch) {
            destSearch.addEventListener("input", (e) => {
                const term = e.target.value.trim().toLowerCase();
                document.querySelectorAll(".destination-row").forEach(row => {
                    const searchable = row.getAttribute("data-search") || "";
                    row.classList.toggle("hidden", term.length > 0 && !searchable.includes(term));
                });
            });
        }

        const suppSearch = document.getElementById("suppliers-search");
        if (suppSearch) {
            suppSearch.addEventListener("input", (e) => {
                const term = e.target.value.trim().toLowerCase();
                document.querySelectorAll(".supplier-row").forEach(row => {
                    const searchable = row.getAttribute("data-search") || "";
                    row.classList.toggle("hidden", term.length > 0 && !searchable.includes(term));
                });
            });
        }
    });

    // Re-apply filters after HTMX dynamically loads the partial
    document.body.addEventListener('htmx:afterSwap', function(evt) {
        if (evt.detail.target.id === 'destinations-list') {
            const destSearch = document.getElementById("destinations-search");
            if (destSearch && destSearch.value) {
                const event = new Event('input', { bubbles: true });
                destSearch.dispatchEvent(event);
            }
        }
        if (evt.detail.target.id === 'suppliers-list') {
            const suppSearch = document.getElementById("suppliers-search");
            if (suppSearch && suppSearch.value) {
                const event = new Event('input', { bubbles: true });
                suppSearch.dispatchEvent(event);
            }
        }
    });
</script>
