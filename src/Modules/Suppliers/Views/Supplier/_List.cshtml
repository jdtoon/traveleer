@model saas.Data.PaginatedList<saas.Modules.Suppliers.DTOs.SupplierListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var search = ViewData["Search"]?.ToString();
    var listUrl = Url.Action("List", "Supplier", new { slug, search, pageSize = Model.PageSize })!;
}

@if (Model.Items.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No suppliers found</h3>
        <p class="mt-2 opacity-70">Add your hotel, transport, and excursion partners to start building bookings.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr class="hover cursor-pointer"
                        hx-get="@Url.Action("Details", "Supplier", new { slug, id = item.Id })"
                        hx-push-url="true"
                        hx-target="#main-content"
                        hx-swap="innerHTML show:top">
                        <td class="font-medium">@item.Name</td>
                        <td>@(item.ContactName ?? "-")</td>
                        <td>@(item.ContactEmail ?? "-")</td>
                        <td>@(item.ContactPhone ?? "-")</td>
                        <td>
                            @if (item.Rating.HasValue)
                            {
                                <div class="flex gap-0.5">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <span class="text-sm @(i <= item.Rating ? "text-warning" : "text-base-300")">&#9733;</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="opacity-40">—</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(item.IsActive ? "badge-success" : "badge-ghost") badge-sm">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-right" onclick="event.stopPropagation()">
                            <has-permission name="suppliers.edit">
                                <div class="dropdown dropdown-end">
                                    <label tabindex="0" class="btn btn-ghost btn-xs">...</label>
                                    <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow-lg z-10 w-40">
                                        <li><button hx-get="@Url.Action("Edit", "Supplier", new { slug, id = item.Id })" hx-target="#modal-container">Edit</button></li>
                                        <li><button class="text-error" hx-get="@Url.Action("DeleteConfirm", "Supplier", new { slug, id = item.Id })" hx-target="#modal-container">Delete</button></li>
                                    </ul>
                                </div>
                            </has-permission>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="@Model.ToPagination(listUrl, "#supplier-list", true)" />
}
