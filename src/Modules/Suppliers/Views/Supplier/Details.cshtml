@model saas.Modules.Suppliers.DTOs.SupplierDetailsDto
@{
    ViewData["Title"] = Model.Name;
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="flex flex-col gap-6">
    <div class="flex items-center gap-3">
        <a href="@Url.Action("Index", "Supplier", new { slug })" class="btn btn-ghost btn-sm">← Back</a>
        <div class="flex-1">
            <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold">@Model.Name</h1>
                <span class="badge @(Model.IsActive ? "badge-success" : "badge-ghost") badge-sm">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
                @if (Model.Rating.HasValue)
                {
                    <div class="flex gap-0.5">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <span class="text-sm @(i <= Model.Rating ? "text-warning" : "text-base-300")">&#9733;</span>
                        }
                    </div>
                }
            </div>
            <p class="text-sm opacity-60">Supplier since @Model.CreatedAt.ToString("dd MMM yyyy") · @Model.BookingItemCount booking item(s)</p>
        </div>
        <has-permission name="suppliers.edit">
            <button class="btn btn-primary btn-sm"
                    hx-get="@Url.Action("Edit", "Supplier", new { slug, id = Model.Id })"
                    hx-target="#modal-container">
                Edit
            </button>
        </has-permission>
    </div>

    <div id="supplier-summary"
         hx-get="@Url.Action("Summary", "Supplier", new { slug, id = Model.Id })"
         hx-trigger="@saas.Modules.Suppliers.Events.SupplierEvents.DetailsRefresh from:body"
         hx-swap="innerHTML">
        @await Html.PartialAsync("_Summary", Model)
    </div>
</div>
