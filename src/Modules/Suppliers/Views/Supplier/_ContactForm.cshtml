@model saas.Modules.Suppliers.DTOs.SupplierContactFormDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var isEdit = Model.Id != Guid.Empty;
    var title = isEdit ? "Edit Contact" : "New Contact";
    var action = isEdit
        ? Url.Action("UpdateContact", "Supplier", new { slug, contactId = Model.Id })
        : Url.Action("CreateContact", "Supplier", new { slug, supplierId = Model.SupplierId });
}

<dialog class="modal modal-open modal-middle">
    <div class="modal-box max-w-lg">
        <form hx-post="@action" hx-target="#modal-container">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SupplierId" />
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold">@title</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">x</button>
            </div>

            <div class="space-y-4">
                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Name</span></label>
                    <input asp-for="Name" class="input input-bordered w-full" />
                    <span asp-validation-for="Name" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Role</span></label>
                    <input asp-for="Role" class="input input-bordered w-full" placeholder="Reservations Manager, Accounts, etc." />
                    <span asp-validation-for="Role" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Email</span></label>
                    <input asp-for="Email" class="input input-bordered w-full" />
                    <span asp-validation-for="Email" class="text-error text-sm mt-1"></span>
                </div>

                <div class="form-control w-full">
                    <label class="label"><span class="label-text">Phone</span></label>
                    <input asp-for="Phone" class="input input-bordered w-full" />
                    <span asp-validation-for="Phone" class="text-error text-sm mt-1"></span>
                </div>

                <label class="label cursor-pointer justify-start gap-3">
                    <input asp-for="IsPrimary" class="toggle toggle-primary" />
                    <span class="label-text">Primary contact</span>
                </label>
            </div>

            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="this.closest('.modal').classList.remove('modal-open')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="this.closest('.modal').classList.remove('modal-open')">close</button>
    </form>
</dialog>
