@model IReadOnlyList<saas.Modules.Suppliers.DTOs.SupplierContactListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

@if (Model.Count == 0)
{
    <p class="text-sm opacity-60">No contacts yet. Add a contact person for this supplier.</p>
}
else
{
    <div class="space-y-3">
        @foreach (var contact in Model)
        {
            <div class="flex items-start justify-between gap-2 p-3 rounded-lg bg-base-200/50">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                        <span class="font-medium text-sm">@contact.Name</span>
                        @if (contact.IsPrimary)
                        {
                            <span class="badge badge-primary badge-xs">Primary</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(contact.Role))
                    {
                        <p class="text-xs opacity-60">@contact.Role</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(contact.Email))
                    {
                        <p class="text-xs">@contact.Email</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(contact.Phone))
                    {
                        <p class="text-xs">@contact.Phone</p>
                    }
                </div>
                <has-permission name="suppliers.edit">
                    <div class="dropdown dropdown-end">
                        <label tabindex="0" class="btn btn-ghost btn-xs">...</label>
                        <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow-lg z-10 w-36">
                            <li><button hx-get="@Url.Action("EditContact", "Supplier", new { slug, contactId = contact.Id })" hx-target="#modal-container">Edit</button></li>
                            <li><button class="text-error" hx-get="@Url.Action("DeleteContactConfirm", "Supplier", new { slug, contactId = contact.Id })" hx-target="#modal-container">Delete</button></li>
                        </ul>
                    </div>
                </has-permission>
            </div>
        }
    </div>
}
