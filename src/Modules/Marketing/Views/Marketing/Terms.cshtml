@{
    ViewData["Title"] = "Terms";
}

<section class="mx-auto max-w-4xl px-4 py-16">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-10 md:p-12">
        <h1 class="text-4xl md:text-5xl font-bold">Terms of service</h1>
        <p class="mt-4 text-sm opacity-70">Last updated: @DateTime.UtcNow.ToString("yyyy-MM-dd")</p>
        <div class="mt-8 space-y-4 text-sm leading-6 opacity-80">
            <p>By using this service, you agree to use it responsibly and comply with all applicable laws.</p>
            <p>We may update these terms as the platform evolves. Continued use indicates acceptance of changes.</p>
            <p>If you have questions, contact us at the support address listed on the contact page.</p>
        </div>
    </div>
</section>
