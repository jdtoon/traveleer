@{
    ViewData["Title"] = "About";
}

<section class="mx-auto max-w-5xl px-4 py-16">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-10 md:p-12">
        <h1 class="text-4xl md:text-5xl font-bold">Built for builders.</h1>
        <p class="mt-4 text-lg opacity-70">
            This starter kit focuses on multi-tenant foundations: tenants, roles, billing hooks, audit trails, and clean admin surfaces.
        </p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
            <div>
                <h3 class="text-xl font-semibold">Opinionated architecture</h3>
                <p class="mt-2 text-sm opacity-70">Clear module boundaries and consistent infrastructure patterns for long-term maintainability.</p>
            </div>
            <div>
                <h3 class="text-xl font-semibold">Production-ready workflows</h3>
                <p class="mt-2 text-sm opacity-70">Magic link auth, feature flags, provisioning, and audit logging are ready to extend.</p>
            </div>
            <div>
                <h3 class="text-xl font-semibold">UX that respects time</h3>
                <p class="mt-2 text-sm opacity-70">Simple flows for admins and tenants, with HTMX enhancements where it matters.</p>
            </div>
            <div>
                <h3 class="text-xl font-semibold">Designed for growth</h3>
                <p class="mt-2 text-sm opacity-70">Start with a single region and scale to more tenants without rewrites.</p>
            </div>
        </div>
    </div>
</section>
