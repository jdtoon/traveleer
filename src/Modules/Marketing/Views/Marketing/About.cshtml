@{
    ViewData["Title"] = "About";
}

<section class="mx-auto max-w-5xl px-4 py-16">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-10 md:p-12">
        <h1 class="text-4xl md:text-5xl font-bold">Built for travel operations that have outgrown ad-hoc tools.</h1>
        <p class="mt-4 text-lg opacity-70">
            Traveleer keeps the strong SaaS foundations under the hood, but the product story is about agency execution: supplier contracts, quotes, bookings, approvals, and clean handoffs across the team.
        </p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
            <div>
                <h3 class="text-xl font-semibold">Travel workflow first</h3>
                <p class="mt-2 text-sm opacity-70">Rate cards, quote builder depth, booking follow-up, and voucher delivery are treated as connected agency operations, not isolated screens.</p>
            </div>
            <div>
                <h3 class="text-xl font-semibold">SaaS foundations retained</h3>
                <p class="mt-2 text-sm opacity-70">Tenant isolation, authentication, billing hooks, feature flags, and audit logging remain intact so the platform can serve multiple agencies cleanly.</p>
            </div>
            <div>
                <h3 class="text-xl font-semibold">UX that respects quote pressure</h3>
                <p class="mt-2 text-sm opacity-70">The interface aims to reduce switching costs during busy selling windows, with fast HTMX flows and less modal clutter.</p>
            </div>
            <div>
                <h3 class="text-xl font-semibold">Designed for agency growth</h3>
                <p class="mt-2 text-sm opacity-70">Start with one team, one brand, and one operating rhythm, then grow without rebuilding the underlying system each time the business matures.</p>
            </div>
        </div>
    </div>
</section>
