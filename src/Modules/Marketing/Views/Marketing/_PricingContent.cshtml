@model saas.Modules.Marketing.Models.MarketingPricingViewModel
@{
    var mode = Model.BillingCycle;
}

<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
    <div>
        <h1 class="text-4xl md:text-5xl font-bold">Choose a plan that scales with you.</h1>
        <p class="mt-3 text-lg opacity-70">Simple pricing with clear limits and optional upgrades.</p>
    </div>
    <div class="join">
        <button type="button"
                class="btn join-item btn-outline @(mode == "monthly" ? "btn-active" : "")"
                hx-get="/pricing/content?mode=monthly"
                hx-target="#pricing-content"
                hx-swap="innerHTML">
            Monthly
        </button>
        <button type="button"
                class="btn join-item btn-outline @(mode == "annual" ? "btn-active" : "")"
                hx-get="/pricing/content?mode=annual"
                hx-target="#pricing-content"
                hx-swap="innerHTML">
            Annual
        </button>
    </div>
</div>

<div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
    @foreach (var plan in Model.Plans)
    {
        var isFree = plan.MonthlyPrice == 0;
        var annualPrice = plan.AnnualPrice ?? plan.MonthlyPrice * 12;
        var price = mode == "annual" ? annualPrice : plan.MonthlyPrice;
        var suffix = mode == "annual" ? "per year" : "per month";
        <div class="rounded-3xl border border-black/5 bg-white/80 p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-semibold">@plan.Name</h3>
                @if (isFree)
                {
                    <span class="badge badge-success">Free</span>
                }
            </div>
            <p class="mt-3 text-sm opacity-70">@plan.Description</p>
            <div class="mt-6">
                <div class="text-3xl font-bold">
                    @if (price == 0)
                    {
                        <span>Free</span>
                    }
                    else
                    {
                        <span>@plan.Currency @price.ToString("N0")</span>
                    }
                </div>
                <div class="text-sm opacity-70">@suffix</div>
            </div>
            <div class="mt-6">
                <a class="btn btn-primary w-full" href="/register?plan=@plan.Id">Get started</a>
            </div>
            <div class="mt-4 text-xs opacity-60">@plan.MaxUsers users included</div>
        </div>
    }
</div>
