@model saas.Modules.Marketing.Models.MarketingPricingViewModel
@{
    ViewData["Title"] = "Pricing";
}

<section class="mx-auto max-w-6xl px-4 py-16">
    <div id="pricing-content">
        <partial name="_PricingContent" model="Model" />
    </div>
</section>

<section class="mx-auto max-w-6xl px-4 pb-20">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-bold">FAQ</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" checked="checked" />
                <div class="collapse-title font-semibold">Can I change plans later?</div>
                <div class="collapse-content text-sm opacity-70">Yes. Tenant admins can upgrade or downgrade anytime.</div>
            </div>
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" />
                <div class="collapse-title font-semibold">Do you offer yearly discounts?</div>
                <div class="collapse-content text-sm opacity-70">Annual billing is discounted and billed upfront.</div>
            </div>
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" />
                <div class="collapse-title font-semibold">Is there a free trial?</div>
                <div class="collapse-content text-sm opacity-70">Free plans are available, and paid plans include a trial period.</div>
            </div>
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" />
                <div class="collapse-title font-semibold">Can I bring my own domain?</div>
                <div class="collapse-content text-sm opacity-70">Custom domains are supported in the enterprise plan.</div>
            </div>
        </div>
    </div>
</section>

