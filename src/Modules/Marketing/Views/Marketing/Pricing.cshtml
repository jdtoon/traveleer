@model IEnumerable<saas.Data.Core.Plan>
@{
    ViewData["Title"] = "Pricing";
}

<section class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
            <h1 class="text-4xl md:text-5xl font-bold">Choose a plan that scales with you.</h1>
            <p class="mt-3 text-lg opacity-70">Simple pricing with clear limits and optional upgrades.</p>
        </div>
        <div class="join">
            <button type="button" class="btn join-item btn-outline" data-billing="monthly">Monthly</button>
            <button type="button" class="btn join-item btn-outline" data-billing="annual">Annual</button>
        </div>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        @foreach (var plan in Model)
        {
            var isFree = plan.MonthlyPrice == 0;
            <div class="rounded-3xl border border-black/5 bg-white/80 p-6 shadow-sm price-card"
                 data-monthly="@plan.MonthlyPrice"
                 data-annual="@plan.AnnualPrice"
                 data-currency="@plan.Currency">
                <div class="flex items-center justify-between">
                    <h3 class="text-xl font-semibold">@plan.Name</h3>
                    @if (isFree)
                    {
                        <span class="badge badge-success">Free</span>
                    }
                </div>
                <p class="mt-3 text-sm opacity-70">@plan.Description</p>
                <div class="mt-6">
                    <div class="text-3xl font-bold price-value">
                        @if (isFree)
                        {
                            <span>Free</span>
                        }
                        else
                        {
                            <span>R @plan.MonthlyPrice.ToString("N0")</span>
                        }
                    </div>
                    <div class="text-sm opacity-70 price-suffix">per month</div>
                </div>
                <div class="mt-6">
                    <a class="btn btn-primary w-full" href="/register?plan=@plan.Id">Get started</a>
                </div>
                <div class="mt-4 text-xs opacity-60">@plan.MaxUsers users included</div>
            </div>
        }
    </div>
</section>

<section class="mx-auto max-w-6xl px-4 pb-20">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-bold">FAQ</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" checked="checked" />
                <div class="collapse-title font-semibold">Can I change plans later?</div>
                <div class="collapse-content text-sm opacity-70">Yes. Tenant admins can upgrade or downgrade anytime.</div>
            </div>
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" />
                <div class="collapse-title font-semibold">Do you offer yearly discounts?</div>
                <div class="collapse-content text-sm opacity-70">Annual billing is discounted and billed upfront.</div>
            </div>
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" />
                <div class="collapse-title font-semibold">Is there a free trial?</div>
                <div class="collapse-content text-sm opacity-70">Free plans are available, and paid plans include a trial period.</div>
            </div>
            <div class="collapse collapse-arrow bg-white/70">
                <input type="radio" name="faq" />
                <div class="collapse-title font-semibold">Can I bring my own domain?</div>
                <div class="collapse-content text-sm opacity-70">Custom domains are supported in the enterprise plan.</div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            var buttons = document.querySelectorAll('[data-billing]');
            var cards = document.querySelectorAll('.price-card');

            function setActive(mode) {
                buttons.forEach(function (btn) {
                    var isActive = btn.getAttribute('data-billing') === mode;
                    btn.classList.toggle('btn-active', isActive);
                });

                cards.forEach(function (card) {
                    var monthly = parseFloat(card.getAttribute('data-monthly'));
                    var annual = parseFloat(card.getAttribute('data-annual'));
                    var currency = card.getAttribute('data-currency') || 'R';
                    var price = mode === 'annual' ? annual : monthly;
                    var valueEl = card.querySelector('.price-value');
                    var suffixEl = card.querySelector('.price-suffix');

                    if (price === 0) {
                        valueEl.textContent = 'Free';
                        suffixEl.textContent = 'forever';
                    } else {
                        valueEl.textContent = currency + ' ' + price.toLocaleString();
                        suffixEl.textContent = mode === 'annual' ? 'per year' : 'per month';
                    }
                });
            }

            buttons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    setActive(btn.getAttribute('data-billing'));
                });
            });

            setActive('monthly');
        })();
    </script>
}
