@{
    ViewData["Title"] = "Privacy";
}

<section class="mx-auto max-w-4xl px-4 py-16">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-10 md:p-12">
        <h1 class="text-4xl md:text-5xl font-bold">Privacy policy</h1>
        <p class="mt-4 text-sm opacity-70">Last updated: @DateTime.UtcNow.ToString("yyyy-MM-dd")</p>
        <div class="mt-8 space-y-4 text-sm leading-6 opacity-80">
            <p>We collect only the information required to provide the service and keep your data isolated per tenant.</p>
            <p>We do not sell personal information. Data access is limited to authorized staff and automated processes.</p>
            <p>Contact us if you want your data removed or exported.</p>
        </div>
    </div>
</section>
