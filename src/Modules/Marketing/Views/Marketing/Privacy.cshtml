@{
    ViewData["Title"] = "Privacy";
}

<section class="mx-auto max-w-4xl px-4 py-16">
    <div class="rounded-3xl border border-black/5 bg-white/80 p-10 md:p-12">
        <h1 class="text-4xl md:text-5xl font-bold">Privacy policy</h1>
        <p class="mt-4 text-sm opacity-70">Last updated: @DateTime.UtcNow.ToString("yyyy-MM-dd")</p>
        <div class="mt-8 space-y-6 text-sm leading-6 opacity-80">
            <div>
                <h2 class="text-xl font-semibold">What we collect</h2>
                <p class="mt-2">We collect the information needed to operate each agency workspace, including user accounts, client records, supplier contracts, quotes, bookings, and security telemetry.</p>
            </div>
            <div>
                <h2 class="text-xl font-semibold">How we use it</h2>
                <p class="mt-2">Data is used to run the product, support agencies, protect the platform, and improve workflow reliability. We do not sell personal data.</p>
            </div>
            <div>
                <h2 class="text-xl font-semibold">Storage and access</h2>
                <p class="mt-2">Agency data is isolated per tenant. Access is limited to authorized personnel and service processes with a legitimate operational reason.</p>
            </div>
            <div>
                <h2 class="text-xl font-semibold">Retention and export</h2>
                <p class="mt-2">We retain data while your workspace is active and for any required operational retention period afterward. Export requests can be handled before account closure.</p>
            </div>
            <div>
                <h2 class="text-xl font-semibold">Compliance note</h2>
                <p class="mt-2">If your agency operates under POPIA or other regional privacy obligations, review your internal obligations and seek legal review before treating this page as a final legal document.</p>
            </div>
        </div>
    </div>
</section>
