@inject Microsoft.Extensions.Options.IOptions<saas.Shared.SiteSettings> SiteOptions
@{
    var site = SiteOptions.Value;
    var title = ViewData["Title"]?.ToString() ?? site.Name;
    var ogTitle = ViewData["OgTitle"]?.ToString() ?? title;
    var ogDescription = ViewData["OgDescription"]?.ToString() ?? "Travel agencies use Traveleer to manage supplier rates, build polished quotes, and keep bookings moving.";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - @site.Name</title>

    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@ogDescription" />
    <meta property="og:type" content="website" />

    <link rel="stylesheet" href="/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
    <style>
        :root {
            --brand-ink: #10212b;
            --brand-sand: #fffaf1;
            --brand-mist: #eef8f7;
            --brand-accent: #0f766e;
            --brand-warm: #d97706;
            --brand-deep: #12354a;
            --brand-rose: #f97316;
        }
        body {
            font-family: "Trebuchet MS", "Lucida Sans Unicode", "Segoe UI", sans-serif;
            background: var(--brand-sand);
            color: var(--brand-ink);
        }
        h1, h2, h3, .display-font {
            font-family: "Franklin Gothic Medium", "Arial Narrow", "Aptos Narrow", sans-serif;
            letter-spacing: -0.03em;
        }
        .marketing-surface {
            background: radial-gradient(circle at 18% 0%, rgba(15, 118, 110, 0.18), transparent 48%),
                        radial-gradient(circle at 82% 10%, rgba(249, 115, 22, 0.16), transparent 45%),
                        linear-gradient(135deg, #fffaf1 0%, #f2fbfb 55%, #fef3e2 100%);
        }
        .reveal-up {
            animation: rise 0.6s ease-out both;
        }
        .reveal-delay-1 { animation-delay: 0.08s; }
        .reveal-delay-2 { animation-delay: 0.16s; }
        .reveal-delay-3 { animation-delay: 0.24s; }
        @@keyframes rise {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .nav-link {
            color: rgba(31, 41, 55, 0.8);
        }
        .nav-link:hover {
            color: var(--brand-ink);
        }
        .hero-chip {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(16, 33, 43, 0.08);
            border-radius: 999px;
            padding: 0.45rem 0.85rem;
        }
        .floating-wa {
            position: fixed;
            right: 1rem;
            bottom: 1rem;
            z-index: 40;
            box-shadow: 0 18px 40px rgba(16, 33, 43, 0.2);
        }
    </style>
</head>
<body class="min-h-screen">
    <div class="relative min-h-screen overflow-hidden marketing-surface">
        <div class="absolute -top-28 right-10 h-72 w-72 rounded-full bg-amber-200/60 blur-3xl"></div>
        <div class="absolute top-56 -left-20 h-80 w-80 rounded-full bg-teal-200/60 blur-3xl"></div>
        <div class="absolute bottom-10 right-1/3 h-64 w-64 rounded-full bg-cyan-200/60 blur-3xl"></div>

        <header class="relative z-10 border-b border-black/5 bg-white/70 backdrop-blur">
            <div class="navbar mx-auto max-w-6xl px-4">
                <div class="flex-1">
                    <swap-nav to="/" class="text-xl font-bold tracking-tight">@site.Name</swap-nav>
                </div>
                <div class="hidden lg:flex items-center gap-6">
                    <swap-nav class="nav-link" to="/">Home</swap-nav>
                    <swap-nav class="nav-link" to="/pricing">Pricing</swap-nav>
                    <swap-nav class="nav-link" to="/about">About</swap-nav>
                    <swap-nav class="nav-link" to="/contact">Contact</swap-nav>
                    <swap-nav class="nav-link" to="/legal/terms">Terms</swap-nav>
                    <swap-nav class="btn btn-sm btn-ghost" to="/register">Get Started</swap-nav>
                    <a class="btn btn-sm btn-outline"
                       href="/login-redirect"
                       hx-get="/login-modal"
                       hx-target="#modal-container"
                       hx-swap="innerHTML">
                        Sign In
                    </a>
                </div>
                <div class="lg:hidden">
                    <div class="dropdown dropdown-end">
                        <label tabindex="0" class="btn btn-ghost">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                        </label>
                        <ul tabindex="0" class="menu dropdown-content mt-3 z-1 w-52 rounded-box bg-base-100 p-2 shadow">
                            <li><swap-nav to="/">Home</swap-nav></li>
                            <li><swap-nav to="/pricing">Pricing</swap-nav></li>
                            <li><swap-nav to="/about">About</swap-nav></li>
                            <li><swap-nav to="/contact">Contact</swap-nav></li>
                            <li><swap-nav to="/legal/terms">Terms</swap-nav></li>
                            <li><swap-nav to="/register">Get Started</swap-nav></li>
                            <li>
                                <a href="/login-redirect"
                                   hx-get="/login-modal"
                                   hx-target="#modal-container"
                                   hx-swap="innerHTML">
                                    Sign In
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        <main class="relative z-10" id="main-content">
            @RenderBody()
        </main>

        <footer class="relative z-10 border-t border-black/5 bg-white/70 backdrop-blur">
            <div class="mx-auto max-w-6xl px-4 py-10 grid gap-8 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
                <div>
                    <div class="text-lg font-bold">@site.Name</div>
                    <p class="text-sm opacity-70 mt-2">Travel agencies use Traveleer to manage supplier contracts, produce faster quotes, and keep bookings moving without spreadsheet chaos.</p>
                </div>
                <div class="grid gap-2 text-sm">
                    <div class="text-xs font-semibold uppercase tracking-[0.2em] opacity-50">Product</div>
                    <swap-nav class="nav-link" to="/pricing">Pricing</swap-nav>
                    <swap-nav class="nav-link" to="/about">About</swap-nav>
                    <swap-nav class="nav-link" to="/contact">Contact</swap-nav>
                </div>
                <div class="grid gap-2 text-sm">
                    <div class="text-xs font-semibold uppercase tracking-[0.2em] opacity-50">Workflows</div>
                    <span class="opacity-70">Rate cards and seasons</span>
                    <span class="opacity-70">Quote builder and PDFs</span>
                    <span class="opacity-70">Bookings and supplier follow-up</span>
                </div>
                <div class="grid gap-2 text-sm">
                    <div class="text-xs font-semibold uppercase tracking-[0.2em] opacity-50">Legal</div>
                    <swap-nav class="nav-link" to="/legal/terms">Terms</swap-nav>
                    <swap-nav class="nav-link" to="/legal/privacy">Privacy</swap-nav>
                    <span class="opacity-60">Copyright @DateTime.UtcNow.Year</span>
                </div>
            </div>
        </footer>
    </div>

    <a class="btn btn-success rounded-full floating-wa" href="https://wa.me/27836616366?text=Hi!%20I%27m%20interested%20in%20Traveleer" target="_blank" rel="noopener">WhatsApp</a>

    <div id="toast-container" class="toast toast-end"></div>
    <div id="modal-container"></div>

    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
