@inject saas.Shared.ITenantContext TenantContext
@inject saas.Shared.IFeatureService FeatureService
@inject saas.Shared.ICurrentUser CurrentUser
@{
    ViewData["Title"] = "Dashboard";
    var slug = TenantContext.Slug;
    var tasksEnabled = await FeatureService.IsEnabledAsync("tasks");
    var reportsEnabled = await FeatureService.IsEnabledAsync("reports");
    var dashboardRange = ViewData["DashboardRange"]?.ToString() ?? "month";
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-end">
        <form method="get" action="/@slug" class="flex items-center gap-2 self-start sm:self-auto">
            <label for="dashboard-range" class="text-sm font-medium opacity-70">Date range</label>
            <select id="dashboard-range" name="range" class="select select-bordered select-sm w-40">
                <option value="month" selected="@(dashboardRange == "month" ? "selected" : null)">This Month</option>
                <option value="quarter" selected="@(dashboardRange == "quarter" ? "selected" : null)">This Quarter</option>
                <option value="year" selected="@(dashboardRange == "year" ? "selected" : null)">This Year</option>
            </select>
            <button type="submit" class="btn btn-outline btn-sm">Apply</button>
        </form>
    </div>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1.7fr)_minmax(18rem,0.9fr)]">
        <section class="card border border-base-300 bg-base-100 shadow-sm">
            <div class="card-body gap-4">
                <div>
                    <h1 class="text-2xl font-bold">Dashboard</h1>
                    <p class="opacity-60">Welcome to <span class="font-semibold">@TenantContext.TenantName</span></p>
                </div>

                <div class="flex flex-wrap gap-2">
                    <has-permission name="bookings.create">
                        <button class="btn btn-primary btn-sm"
                                hx-get="@Url.Action("New", "Booking", new { slug })"
                                hx-target="#modal-container">
                            + New Booking
                        </button>
                    </has-permission>
                    <has-permission name="quotes.create">
                        <a href="/@slug/quotes/new" class="btn btn-outline btn-sm">+ New Quote</a>
                    </has-permission>
                    <has-permission name="clients.create">
                        <button class="btn btn-outline btn-sm"
                                hx-get="@Url.Action("New", "Client", new { slug })"
                                hx-target="#modal-container">
                            + New Client
                        </button>
                    </has-permission>
                </div>

                <div class="rounded-box border border-dashed border-base-300 bg-base-50 p-4 text-sm opacity-70">
                    Start with the work that needs attention now: recent bookings, quote pipeline, financial performance, and outstanding tasks all load below as separate widgets so the page stays responsive.
                </div>
            </div>
        </section>

        @if (tasksEnabled && CurrentUser.HasPermission("tasks.read"))
        {
            <section id="dashboard-tasks-widget"
                     hx-get="@Url.Action("Widget", "Task", new { slug })"
                     hx-trigger="load, @saas.Modules.Tasks.Events.TaskEvents.Refresh from:body"
                     hx-swap="innerHTML show:none">
                <div class="card bg-base-100 border border-base-300 shadow-sm">
                    <div class="card-body items-center justify-center min-h-48">
                        <span class="loading loading-spinner loading-lg"></span>
                    </div>
                </div>
            </section>
        }
    </div>

    @if (reportsEnabled && CurrentUser.HasPermission("reports.read"))
    {
        <div class="grid gap-6 xl:grid-cols-4">
            <section class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-4">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="card-title text-base">Active Bookings</h2>
                            <p class="text-sm opacity-60">Current booking status mix.</p>
                        </div>
                        <a href="/@slug/bookings" class="btn btn-ghost btn-xs">View all</a>
                    </div>
                    <div id="dashboard-bookings-status"
                         hx-get="@Url.Action("BookingsStatus", "Report", new { slug, range = dashboardRange })"
                         hx-trigger="load"
                         hx-swap="innerHTML show:none">
                        <span class="loading loading-spinner loading-lg"></span>
                    </div>
                </div>
            </section>

            <section class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-4">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="card-title text-base">Quote Pipeline</h2>
                            <p class="text-sm opacity-60">Draft to accepted flow for the current period.</p>
                        </div>
                        <a href="/@slug/quotes" class="btn btn-ghost btn-xs">View all</a>
                    </div>
                    <div id="dashboard-quotes-pipeline"
                         hx-get="@Url.Action("QuotesPipeline", "Report", new { slug, range = dashboardRange })"
                         hx-trigger="load"
                         hx-swap="innerHTML show:none">
                        <span class="loading loading-spinner loading-lg"></span>
                    </div>
                </div>
            </section>

            <section class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-4">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="card-title text-base">Revenue This Month</h2>
                            <p class="text-sm opacity-60">Top-line revenue, cost, and profit.</p>
                        </div>
                        <a href="/@slug/reports" class="btn btn-ghost btn-xs">View all</a>
                    </div>
                    <div id="dashboard-profitability-summary"
                         hx-get="@Url.Action("ProfitabilitySummary", "Report", new { slug, range = dashboardRange })"
                         hx-trigger="load"
                         hx-swap="innerHTML show:none">
                        <span class="loading loading-spinner loading-lg"></span>
                    </div>
                </div>
            </section>

            @if (!(tasksEnabled && CurrentUser.HasPermission("tasks.read")))
            {
                <section class="card border border-base-300 bg-base-100 shadow-sm">
                    <div class="card-body gap-4">
                        <div>
                            <h2 class="card-title text-base">Tasks</h2>
                            <p class="text-sm opacity-60">Enable the Tasks module to surface due work here.</p>
                        </div>
                        <a href="/@slug/tasks" class="btn btn-outline btn-sm self-start">Open Tasks</a>
                    </div>
                </section>
            }

            <section class="card border border-base-300 bg-base-100 shadow-sm xl:col-span-4">
                <div class="card-body gap-4">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="card-title text-base">Recent Bookings</h2>
                            <p class="text-sm opacity-60">Latest bookings created in your tenant workspace.</p>
                        </div>
                        <a href="/@slug/bookings" class="btn btn-ghost btn-xs">View all</a>
                    </div>
                    <div id="dashboard-recent-bookings"
                         hx-get="@Url.Action("BookingsRecent", "Report", new { slug })"
                         hx-trigger="load"
                         hx-swap="innerHTML show:none">
                        <span class="loading loading-spinner loading-lg"></span>
                    </div>
                </div>
            </section>
        </div>
    }
</div>
