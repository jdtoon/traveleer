@model saas.Modules.Bookings.DTOs.SupplierPaymentFormDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}
<dialog class="modal modal-open">
    <div class="modal-box">
        <h3 class="text-lg font-bold">Record Supplier Payment</h3>
        <form hx-post="@Url.Action("CreateSupplierPayment", "Payment", new { slug, bookingItemId = Model.BookingItemId })" hx-target="#modal-container" hx-swap="innerHTML">
            @Html.AntiForgeryToken()
            <div class="form-control mt-4">
                <label class="label"><span class="label-text">Amount</span></label>
                <input type="number" name="Amount" value="@Model.Amount" step="0.01" min="0.01" class="input input-bordered" required />
                <span asp-validation-for="Amount" class="text-error text-sm"></span>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Payment Date</span></label>
                <input type="date" name="PaymentDate" value="@Model.PaymentDate?.ToString("yyyy-MM-dd")" class="input input-bordered" required />
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Direction</span></label>
                <select name="Direction" class="select select-bordered">
                    <option value="@((int)saas.Modules.Bookings.Entities.PaymentDirection.Paid)" selected>Paid to Supplier</option>
                    <option value="@((int)saas.Modules.Bookings.Entities.PaymentDirection.Received)">Received from Supplier (refund/credit)</option>
                </select>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Payment Method</span></label>
                <select name="PaymentMethod" class="select select-bordered">
                    @foreach (var method in Enum.GetValues<saas.Modules.Bookings.Entities.PaymentMethod>())
                    {
                        if (method == Model.PaymentMethod)
                        {
                            <option value="@((int)method)" selected>@method</option>
                        }
                        else
                        {
                            <option value="@((int)method)">@method</option>
                        }
                    }
                </select>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Reference</span></label>
                <input type="text" name="Reference" value="@Model.Reference" class="input input-bordered" maxlength="100" />
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Notes</span></label>
                <textarea name="Notes" class="textarea textarea-bordered" maxlength="500">@Model.Notes</textarea>
            </div>
            <input type="hidden" name="CurrencyCode" value="@Model.CurrencyCode" />
            <input type="hidden" name="SupplierId" value="@Model.SupplierId" />
            <div class="modal-action">
                <button type="button" class="btn" onclick="this.closest('dialog').close()">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Payment</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button hx-get="/ui/modal-close" hx-target="#modal-container">close</button></form>
</dialog>
