@model saas.Data.PaginatedList<saas.Modules.Bookings.DTOs.BookingListItemDto>
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var timelineItems = Model.Items
        .Where(b => b.TravelStartDate.HasValue)
        .OrderBy(b => b.TravelStartDate.Value)
        .GroupBy(b => new { b.TravelStartDate!.Value.Year, b.TravelStartDate.Value.Month })
        .ToList();
        
    var unscheduled = Model.Items.Where(b => !b.TravelStartDate.HasValue).ToList();
}

@if (Model.Items.Count == 0)
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-200/40 p-8 text-center">
        <h3 class="text-lg font-semibold">No bookings found</h3>
        <p class="mt-2 opacity-70">
            There are no bookings matching your criteria to display on the timeline.
        </p>
    </div>
}
else
{
    <div class="flex flex-col lg:flex-row gap-8">
        <div class="flex-1">
            @if (timelineItems.Count == 0)
            {
                <div class="alert alert-info">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>None of the filtered bookings have travel dates set.</span>
                </div>
            }
            else
            {
                <div class="space-y-8">
                    @foreach (var group in timelineItems)
                    {
                        var groupDate = new DateOnly(group.Key.Year, group.Key.Month, 1);
                        <div>
                            <h3 class="text-xl font-bold border-b border-base-300 pb-2 mb-4">@groupDate.ToString("MMMM yyyy")</h3>
                            <ul class="timeline timeline-vertical timeline-compact max-md:timeline-compact">
                                @for (int i = 0; i < group.Count(); i++)
                                {
                                    var item = group.ElementAt(i);
                                    var isFirst = i == 0;
                                    var isLast = i == group.Count() - 1;
                                    <li>
                                        @if (!isFirst) { <hr class="bg-base-300" /> }
                                        
                                        <div class="timeline-start text-right w-24 sm:w-32 pt-1 font-mono text-sm opacity-70">
                                            @item.TravelStartDate!.Value.ToString("MMM dd")
                                            @if (item.TravelEndDate.HasValue && item.TravelEndDate != item.TravelStartDate)
                                            {
                                                <br/>
                                                <span class="text-xs opacity-50">to @item.TravelEndDate.Value.ToString("MMM dd")</span>
                                            }
                                        </div>
                                        
                                        <div class="timeline-middle text-primary">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                                        </div>
                                        
                                        <div class="timeline-end timeline-box w-full max-w-md shadow-sm border-base-200">
                                            <div class="flex justify-between items-start gap-4">
                                                <div>
                                                    <a href="@Url.Action("Details", "Booking", new { slug, id = item.Id })" class="font-bold link link-hover text-lg">@item.BookingRef</a>
                                                    <div class="text-sm">@item.ClientName</div>
                                                </div>
                                                <span class="badge badge-sm badge-outline">@item.Status</span>
                                            </div>
                                            <div class="mt-2 text-xs opacity-70 flex gap-2 flex-wrap">
                                                <span class="badge badge-ghost badge-sm">@item.Pax pax</span>
                                                <span class="badge badge-ghost badge-sm">@item.ItemCount services</span>
                                            </div>
                                        </div>
                                        
                                        @if (!isLast) { <hr class="bg-base-300" /> }
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
        
        @if (unscheduled.Count > 0)
        {
            <div class="lg:w-80 shrink-0">
                <div class="card bg-base-200/50 border border-base-300">
                    <div class="card-body p-4">
                        <h4 class="font-bold text-sm uppercase tracking-wider opacity-70 mb-2">Unscheduled</h4>
                        <div class="flex flex-col gap-2">
                            @foreach (var item in unscheduled)
                            {
                                <a href="@Url.Action("Details", "Booking", new { slug, id = item.Id })" class="block p-3 rounded-lg bg-base-100 border border-base-200 hover:border-primary transition-colors">
                                    <div class="font-bold flex justify-between">
                                        <span>@item.BookingRef</span>
                                        <span class="badge badge-xs badge-outline">@item.Status</span>
                                    </div>
                                    <div class="text-xs opacity-70 mt-1">@item.ClientName</div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}