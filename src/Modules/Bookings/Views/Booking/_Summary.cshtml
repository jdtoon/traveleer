@model saas.Modules.Bookings.DTOs.BookingDetailsDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
            <div class="flex flex-wrap items-center gap-3">
                <h1 class="text-2xl font-bold">@Model.BookingRef</h1>
                <span class="badge badge-outline">@Model.Status</span>
            </div>
            <p class="mt-2 opacity-70">@Model.ClientName · @(Model.TravelStartDate?.ToString("dd MMM yyyy") ?? "Travel dates pending")@if (Model.TravelEndDate.HasValue) { <text> - @Model.TravelEndDate.Value.ToString("dd MMM yyyy")</text> }</p>
        </div>
        <div class="flex gap-2">
            <a class="btn btn-ghost btn-sm" href="@Url.Action("Index", "Booking", new { slug })">Back to Bookings</a>
            @if (Model.QuoteId.HasValue)
            {
                <a class="btn btn-outline btn-sm" href="@Url.Action("Details", "Quote", new { slug, id = Model.QuoteId })">View Quote</a>
            }
            <has-permission name="bookings.edit">
                <button class="btn btn-primary btn-sm" hx-get="@Url.Action("NewItem", "Booking", new { slug, id = Model.Id })" hx-target="#modal-container">+ Add Service</button>
            </has-permission>
        </div>
    </div>

    <div class="grid gap-4 xl:grid-cols-[1.6fr_1fr]">
        <div class="grid gap-4 md:grid-cols-2">
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Travel</div>
                    <div class="font-medium">@(Model.TravelStartDate?.ToString("dd MMM yyyy") ?? "TBC")@if (Model.TravelEndDate.HasValue) { <text> - @Model.TravelEndDate.Value.ToString("dd MMM yyyy")</text> }</div>
                    <div class="text-sm opacity-70">@Model.Pax pax</div>
                </div>
            </div>
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Client</div>
                    <div class="font-medium">@Model.ClientName</div>
                    <div class="text-sm opacity-70">Reference: @(string.IsNullOrWhiteSpace(Model.ClientReference) ? "Not set" : Model.ClientReference)</div>
                </div>
            </div>
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Totals</div>
                    <div class="font-medium">Cost: @Model.CostCurrencyCode @Model.TotalCost.ToString("N2")</div>
                    <div class="font-medium">Selling: @Model.SellingCurrencyCode @Model.TotalSelling.ToString("N2")</div>
                    <div class="text-sm opacity-70">Profit: @Model.SellingCurrencyCode @Model.TotalProfit.ToString("N2")</div>
                </div>
            </div>
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Source</div>
                    <div class="font-medium">@(string.IsNullOrWhiteSpace(Model.QuoteReferenceNumber) ? "Standalone booking" : Model.QuoteReferenceNumber)</div>
                    <div class="text-sm opacity-70">@(Model.QuoteId.HasValue ? "Created from an accepted quote." : "Created directly in bookings.")</div>
                </div>
            </div>
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Lead Guest</div>
                    <div class="font-medium">@(string.IsNullOrWhiteSpace(Model.LeadGuestName) ? "Not set" : Model.LeadGuestName)</div>
                    <div class="text-sm opacity-70">@(string.IsNullOrWhiteSpace(Model.LeadGuestNationality) ? "Nationality not set" : Model.LeadGuestNationality)</div>
                </div>
            </div>
        </div>

        <div class="grid gap-4">
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Special Requests</div>
                    <p class="text-sm opacity-80">@(string.IsNullOrWhiteSpace(Model.SpecialRequests) ? "No special requests recorded." : Model.SpecialRequests)</p>
                </div>
            </div>
            <div class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body gap-2">
                    <div class="text-sm uppercase tracking-wide opacity-60">Internal Notes</div>
                    <p class="text-sm opacity-80">@(string.IsNullOrWhiteSpace(Model.InternalNotes) ? "No internal notes recorded." : Model.InternalNotes)</p>
                </div>
            </div>
        </div>
    </div>
</div>