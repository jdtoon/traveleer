@model saas.Modules.Bookings.DTOs.PaymentLinkPublicDto
@{
    ViewData["Title"] = "Payment";
}
<div class="card border border-base-300 bg-base-100 shadow-lg">
    <div class="card-body gap-6 text-center">
        <div>
            <h2 class="text-2xl font-bold">Payment Request</h2>
            <p class="text-sm opacity-60 mt-1">Booking @Model.BookingRef</p>
            @if (!string.IsNullOrWhiteSpace(Model.ClientName))
            {
                <p class="text-sm opacity-60">For: @Model.ClientName</p>
            }
        </div>

        <div class="divider"></div>

        <div>
            <p class="text-sm uppercase tracking-wide opacity-60">Amount Due</p>
            <p class="text-4xl font-bold mt-1">@Model.CurrencyCode @Model.Amount.ToString("N2")</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="rounded-box bg-base-200 p-4 text-sm">
                @Model.Description
            </div>
        }

        <div class="text-xs opacity-50">
            This link expires on @Model.ExpiresAt.ToString("dd MMM yyyy HH:mm") UTC
        </div>

        <form method="post" action="/pay/@Model.TenantSlug/@Model.Token/checkout">
            <button type="submit" class="btn btn-primary btn-lg w-full">
                Pay @Model.CurrencyCode @Model.Amount.ToString("N2")
            </button>
        </form>

        <a href="/pay/@Model.TenantSlug/@Model.Token/cancel" class="link link-hover text-sm opacity-60">Cancel</a>
    </div>
</div>
