@{
    ViewData["Title"] = "Link Expired";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Link Expired</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/app.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-base-200 text-base-content flex items-center justify-center">
    <div class="card border border-base-300 bg-base-100 shadow-lg max-w-md">
        <div class="card-body gap-6 text-center">
            <div class="text-error text-6xl">&#9888;</div>
            <h2 class="text-2xl font-bold">Payment Link Unavailable</h2>
            <p class="text-sm opacity-60">
                This payment link has expired, been cancelled, or is no longer valid.
                Please contact the agency for a new payment link.
            </p>
        </div>
    </div>
</body>
</html>
