@model saas.Modules.Bookings.DTOs.PaymentLinkFormDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
}
<dialog class="modal modal-open">
    <div class="modal-box">
        <h3 class="text-lg font-bold">Create Payment Link</h3>
        <form hx-post="@Url.Action("Create", "PaymentLink", new { slug, bookingId = Model.BookingId })" hx-target="#modal-container" hx-swap="innerHTML">
            @Html.AntiForgeryToken()
            <div class="form-control mt-4">
                <label class="label"><span class="label-text">Amount</span></label>
                <input type="number" name="Amount" value="@(Model.Amount > 0 ? Model.Amount : "")" step="0.01" min="0.01" class="input input-bordered" required />
                <span asp-validation-for="Amount" class="text-error text-sm"></span>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Description</span></label>
                <textarea name="Description" class="textarea textarea-bordered" maxlength="500" placeholder="e.g. Deposit for Safari Package">@Model.Description</textarea>
                <span asp-validation-for="Description" class="text-error text-sm"></span>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Link expires in (days)</span></label>
                <input type="number" name="ExpiryDays" value="@Model.ExpiryDays" min="1" max="90" class="input input-bordered" required />
                <span asp-validation-for="ExpiryDays" class="text-error text-sm"></span>
            </div>
            <input type="hidden" name="CurrencyCode" value="@Model.CurrencyCode" />
            <div class="modal-action">
                <button type="button" class="btn" onclick="this.closest('dialog').close()">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Link</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button hx-get="/ui/modal-close" hx-target="#modal-container">close</button></form>
</dialog>
