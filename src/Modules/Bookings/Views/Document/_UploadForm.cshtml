@model saas.Modules.Bookings.DTOs.DocumentUploadDto
@{
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var isBooking = Model.BookingId.HasValue;
    var uploadAction = isBooking
        ? Url.Action("UploadBookingDocument", "Document", new { slug, bookingId = Model.BookingId!.Value })
        : Url.Action("UploadClientDocument", "Document", new { slug, clientId = Model.ClientId!.Value });
}
<dialog class="modal modal-open">
    <div class="modal-box">
        <h3 class="text-lg font-bold">Upload Document</h3>
        <form hx-post="@uploadAction"
              hx-target="#modal-container"
              hx-swap="innerHTML"
              hx-encoding="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="form-control mt-4">
                <label class="label"><span class="label-text">File</span></label>
                <input type="file" name="File" class="file-input file-input-bordered w-full" required />
                <span asp-validation-for="File" class="text-error text-sm mt-1"></span>
                <div class="label"><span class="label-text-alt opacity-60">Max 10 MB. Executable files are not allowed.</span></div>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Document Type</span></label>
                <select name="DocumentType" class="select select-bordered">
                    @foreach (var dt in Enum.GetValues<saas.Modules.Bookings.Entities.DocumentType>())
                    {
                        if (dt == Model.DocumentType)
                        {
                            <option value="@((int)dt)" selected>@dt</option>
                        }
                        else
                        {
                            <option value="@((int)dt)">@dt</option>
                        }
                    }
                </select>
            </div>
            <div class="form-control mt-2">
                <label class="label"><span class="label-text">Description (optional)</span></label>
                <textarea name="Description" class="textarea textarea-bordered" maxlength="500" placeholder="Optional notes about this document">@Model.Description</textarea>
            </div>
            <div class="modal-action">
                <button type="button" class="btn" onclick="this.closest('dialog').close()">Cancel</button>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button hx-get="/ui/modal-close" hx-target="#modal-container">close</button></form>
</dialog>
