      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Billing": {
    "Provider": "Mock",
    "Tax": {
      "Rate": 0.15,
      "Label": "VAT",
      "Included": true
    },
    "Company": {
      "Name": "Dev Corp",
      "Address": "123 Dev Street"
    },
    "Invoice": {
      "Prefix": "DEV-INV",
      "PaymentTermDays": 7
    },
    "Trial": {
      "DefaultDays": 14
    },
    "GracePeriod": {
      "Days": 3,
      "DunningAttempts": 3,
      "DunningIntervalHours": 24
