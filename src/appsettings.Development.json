  "DevSeed": {
    "Enabled": true,
    "TenantSlug": "demo",
    "TenantName": "Demo Workspace",
    "AdminEmail": "admin@demo.local",
    "AdminPassword": "Admin1234!",
    "MemberEmail": "member@demo.local",
    "MemberPassword": "Member1234!",
