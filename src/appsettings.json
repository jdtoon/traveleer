{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Site": {
    "BaseUrl": "https://localhost:5001",
    "Name": "SaaS App",
    "SupportEmail": "support@localhost"
  },
  "ConnectionStrings": {
    "CoreDatabase": "Data Source=db/core.db",
    "AuditDatabase": "Data Source=db/audit.db"
  },
  "SuperAdmin": {
    "Email": "admin@localhost"
  },
  "Tenancy": {
    "DatabasePath": "db/tenants"
  },
  "Email": {
    "Provider": "Console",
    "FromAddress": "no-reply@localhost",
    "FromName": "SaaS App",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "",
      "Password": "",
      "UseSsl": true
    },
    "MailerSend": {
      "ApiToken": ""
    }
  },
  "Billing": {
    "Provider": "Mock",
    "Paystack": {
      "SecretKey": "",
      "PublicKey": "",
      "WebhookSecret": "",
      "CallbackBaseUrl": "https://localhost:5001"
    }
  },
  "Turnstile": {
    "Provider": "Mock",
    "SiteKey": "",
    "SecretKey": ""
  },
  "FeatureFlags": {
    "AllEnabledLocally": true
  },
  "Backup": {
    "LitestreamConfigPath": "db/litestream.yml",
    "SentinelPath": "db/.litestream-reload",
    "R2Bucket": "saas-backups",
    "R2Endpoint": "",
    "SyncInterval": "30s",
    "MonitorInterval": "5s",
    "CheckpointInterval": "5m",
    "SnapshotInterval": "24h",
    "SnapshotRetention": "168h",
    "AutoRestoreEnabled": true,
    "KeyBackupEnabled": true,
    "KeyBackupInterval": "1h",
    "KeyBackupPath": "system/keys/dataprotection-keys.zip",
    "KeyBackupMarkerPath": "db/.keys-last-backup"
  },
  "Storage": {
    "Provider": "Local",
    "LocalBasePath": "db/uploads"
  }
}
