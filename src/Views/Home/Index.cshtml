@inject Microsoft.Extensions.Options.IOptions<saas.Shared.SiteSettings> SiteOptions
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Home";
    var siteName = SiteOptions.Value.Name;
}

<section class="flex items-center justify-center py-24 px-4">
    <div class="text-center max-w-2xl">
        <h1 class="text-5xl font-bold mb-6">@siteName</h1>
        <p class="text-lg text-base-content/70 mb-8">
            Multi-tenant SaaS platform. Create your workspace and start collaborating.
        </p>
        <div class="flex justify-center gap-4">
            <a href="/register" class="btn btn-primary btn-lg">Create Workspace</a>
            <a href="/super-admin/login" class="btn btn-ghost btn-lg">Admin Login</a>
        </div>
    </div>
</section>
