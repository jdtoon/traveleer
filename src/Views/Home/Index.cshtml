@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold">Dashboard</h1>
    <p class="opacity-60">Welcome to your modular monolith</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <!-- Welcome Card -->
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h2 class="card-title">Swap.Htmx</h2>
            <p class="opacity-70">Server-driven reactive web applications with HTMX and source generators.</p>
        </div>
    </div>

    <!-- Notes Module Card -->
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h2 class="card-title">Notes Module</h2>
            <p class="opacity-70">Sample module demonstrating modular architecture with full CRUD operations.</p>
            <div class="card-actions justify-end mt-4">
                <swap-nav to="/Notes" class="btn btn-primary btn-sm">Go to Notes</swap-nav>
            </div>
        </div>
    </div>

    <!-- Getting Started Card -->
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h2 class="card-title">Getting Started</h2>
            <ul class="text-sm space-y-1 opacity-70">
                <li>• Add modules in <code class="bg-base-200 px-1 rounded text-xs">Modules/</code></li>
                <li>• Register in <code class="bg-base-200 px-1 rounded text-xs">Program.cs</code></li>
                <li>• Configure in <code class="bg-base-200 px-1 rounded text-xs">MvcExtensions.cs</code></li>
            </ul>
        </div>
    </div>

    <!-- Architecture Card -->
    <div class="card bg-base-100 shadow">
        <div class="card-body">
            <h2 class="card-title">Architecture</h2>
            <ul class="text-sm space-y-1 opacity-70">
                <li><span class="font-medium">Infrastructure/</span> - Cross-cutting</li>
                <li><span class="font-medium">Data/</span> - DB context</li>
                <li><span class="font-medium">Modules/</span> - Features</li>
                <li><span class="font-medium">Views/</span> - Shared views</li>
            </ul>
        </div>
    </div>
</div>
