@inject saas.Shared.ITenantContext TenantContext
@inject saas.Shared.IFeatureService FeatureService
@{
    var slug = TenantContext.Slug;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var notesEnabled = await FeatureService.IsEnabledAsync("notes");
    var auditLogEnabled = await FeatureService.IsEnabledAsync("audit_log");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(TenantContext.TenantName ?? "saas")</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#6366f1" />

    <!-- DaisyUI + Tailwind CSS -->
    <link rel="stylesheet" href="/css/styles.css" asp-append-version="true" />

    <!-- Swap.Htmx CSS -->
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-base-100 text-base-content">
    <script src="/js/theme.js"></script>
    <!-- Skip navigation link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-primary focus:text-primary-content focus:px-4 focus:py-2 focus:rounded">
        Skip to main content
    </a>
    <!-- Drawer for mobile menu -->
    <div class="drawer lg:drawer-open">
        <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col">
            <!-- Navbar (mobile) -->
            <div class="navbar bg-base-100 border-b border-base-300 lg:hidden">
                <div class="flex-none">
                    <label for="mobile-drawer" class="btn btn-square btn-ghost drawer-button" aria-label="Open navigation menu">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </label>
                </div>
                <div class="flex-1">
                    <span class="text-xl font-bold">@(TenantContext.TenantName ?? "saas")</span>
                </div>
            </div>

            <!-- Main Content -->
            <main class="flex-1 p-4 md:p-6 overflow-auto" id="main-content" role="main" aria-label="Main content">
                @RenderBody()
            </main>
        </div>

        <!-- Sidebar -->
        <div class="drawer-side z-40">
            <label for="mobile-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="bg-base-200 w-64 min-h-full flex flex-col" role="navigation" aria-label="Main navigation">
                <!-- Brand -->
                <div class="p-4 border-b border-base-300">
                    <span class="text-xl font-bold">@(TenantContext.TenantName ?? "saas")</span>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 p-4">
                    <ul class="menu menu-md gap-1">
                        <li>
                            <swap-nav to="/@slug" class="@(controller == "Dashboard" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                Dashboard
                            </swap-nav>
                        </li>
                        @if (notesEnabled)
                        {
                        <li>
                            <swap-nav to="/@slug/Notes" class="@(controller == "Notes" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Notes
                            </swap-nav>
                        </li>
                        }
                    </ul>
                </nav>

                <!-- Admin link -->
                <has-permission name="users.read">
                <div class="px-4 pb-2">
                    <a href="/@slug/TenantAdmin/Users"
                       class="btn btn-sm btn-outline w-full gap-2 @(controller == "TenantAdmin" || controller == "TenantBilling" ? "btn-active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Admin
                    </a>
                </div>
                </has-permission>

                <!-- Footer -->
                <div class="p-4 border-t border-base-300 space-y-2">
                    <div class="flex items-center justify-between px-2">
                        <span class="text-xs text-base-content/60">Theme</span>
                        <label class="swap swap-rotate" aria-label="Toggle dark mode">
                            <input type="checkbox" class="theme-toggle" aria-label="Toggle dark mode" />
                            <svg class="swap-off h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/></svg>
                            <svg class="swap-on h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Z"/></svg>
                        </label>
                    </div>
                    <form method="post" action="/@slug/logout">
                        <button type="submit" class="btn btn-ghost btn-sm w-full justify-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            Sign Out
                        </button>
                    </form>
                </div>
            </aside>
        </div>
    </div>

    <!-- Toast container (screen reader announcements) -->
    <div id="toast-container" class="toast toast-end" aria-live="polite" aria-atomic="true" role="status"></div>

    <!-- Modal container -->
    <div id="modal-container" role="dialog" aria-modal="true" aria-hidden="true"></div>

    <!-- Scripts -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
    <script src="/js/bundle.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
