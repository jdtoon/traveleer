@inject saas.Shared.ITenantContext TenantContext
@{
    var slug = TenantContext.Slug;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(TenantContext.TenantName ?? "saas")</title>

    <!-- DaisyUI + Tailwind CSS -->
    <link rel="stylesheet" href="/css/styles.css" asp-append-version="true" />

    <!-- Swap.Htmx CSS -->
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
</head>
<body data-theme="corporate" class="min-h-screen bg-base-100 text-base-content">
    <!-- Drawer for mobile menu -->
    <div class="drawer lg:drawer-open">
        <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col">
            <!-- Navbar (mobile) -->
            <div class="navbar bg-base-100 border-b border-base-300 lg:hidden">
                <div class="flex-none">
                    <label for="mobile-drawer" class="btn btn-square btn-ghost drawer-button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </label>
                </div>
                <div class="flex-1">
                    <span class="text-xl font-bold">@(TenantContext.TenantName ?? "saas")</span>
                </div>
            </div>

            <!-- Main Content -->
            <main class="flex-1 p-4 md:p-6 overflow-auto" id="main-content">
                @RenderBody()
            </main>
        </div>

        <!-- Sidebar -->
        <div class="drawer-side z-40">
            <label for="mobile-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="bg-base-200 w-64 min-h-full flex flex-col">
                <!-- Brand -->
                <div class="p-4 border-b border-base-300">
                    <span class="text-xl font-bold">@(TenantContext.TenantName ?? "saas")</span>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 p-4">
                    <ul class="menu menu-md gap-1">
                        <li>
                            <swap-nav to="/@slug" class="@(controller == "Home" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                Dashboard
                            </swap-nav>
                        </li>
                        <li>
                            <swap-nav to="/@slug/Notes" class="@(controller == "Notes" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Notes
                            </swap-nav>
                        </li>
                        <has-permission name="users.read">
                        <li>
                            <swap-nav to="/@slug/TenantAdmin/Users" class="@(controller == "TenantAdmin" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                                </svg>
                                Users
                            </swap-nav>
                        </li>
                        </has-permission>
                        <has-permission name="users.read">
                        <li>
                            <swap-nav to="/@slug/TenantBilling" class="@(controller == "TenantBilling" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                                </svg>
                                Billing
                            </swap-nav>
                        </li>
                        </has-permission>
                    </ul>
                </nav>

                <!-- Footer -->
                <div class="p-4 border-t border-base-300">
                    <form method="post" action="/@slug/logout">
                        <button type="submit" class="btn btn-ghost btn-sm w-full justify-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            Sign Out
                        </button>
                    </form>
                </div>
            </aside>
        </div>
    </div>

    <!-- Modal container -->
    <div id="modal-container"></div>

    <!-- Scripts -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
    <script src="/js/bundle.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
