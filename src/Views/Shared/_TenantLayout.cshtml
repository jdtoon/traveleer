@inject saas.Shared.ITenantContext TenantContext
@inject saas.Shared.IFeatureService FeatureService
@inject saas.Shared.ICurrentUser CurrentUser
@{
    var slug = TenantContext.Slug;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var brandingEnabled = await FeatureService.IsEnabledAsync("branding");
    var bookingsEnabled = await FeatureService.IsEnabledAsync("bookings");
    var clientsEnabled = await FeatureService.IsEnabledAsync("clients");
    var inventoryEnabled = await FeatureService.IsEnabledAsync("inventory");
    var quotesEnabled = await FeatureService.IsEnabledAsync("quotes");
    var rateCardsEnabled = await FeatureService.IsEnabledAsync("ratecards");
    var settingsEnabled = await FeatureService.IsEnabledAsync("settings");
}
<!DOCTYPE html>
<html lang="en" data-theme="lemonade">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(TenantContext.TenantName ?? "saas")</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#6366f1" />

    <!-- DaisyUI + Tailwind CSS -->
    <link rel="stylesheet" href="/css/app.css" asp-append-version="true" />

    <!-- Swap.Htmx CSS -->
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
</head>
<body class="tenant-brand-surface min-h-screen bg-base-100 text-base-content">
    <div id="branding-theme-vars"
         hx-get="@Url.Action("ThemeVars", "Branding", new { slug })"
         hx-trigger="load, branding.refresh from:body"
         hx-swap="outerHTML"></div>
    <!-- Skip navigation link -->
    <a href="#main-content" class="skip-branding sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:rounded">
        Skip to main content
    </a>
    <!-- Drawer for mobile menu -->
    <div class="drawer lg:drawer-open">
        <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col">
            <!-- Navbar (mobile) -->
            <div class="navbar bg-base-100 border-b border-base-300 lg:hidden">
                <div class="flex-none">
                    <label for="mobile-drawer" class="btn btn-square btn-ghost drawer-button" aria-label="Open navigation menu">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </label>
                </div>
                <div class="flex-1">
                    <div id="tenant-brand-shell-mobile"
                         hx-get="@Url.Action("Shell", "Branding", new { slug })"
                         hx-trigger="load, branding.refresh from:body"
                         hx-swap="innerHTML">
                        <span class="text-xl font-bold">@(TenantContext.TenantName ?? "saas")</span>
                    </div>
                </div>
                <div class="flex-none">
                </div>
            </div>

            <!-- Announcement banners -->
            @await Html.PartialAsync("_AnnouncementBanner")

            <!-- Main Content -->
            <main class="flex-1 p-4 md:p-6 overflow-auto" id="main-content" role="main" aria-label="Main content">
                @RenderBody()
            </main>
        </div>

        <!-- Sidebar -->
        <div class="drawer-side z-40">
            <label for="mobile-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="bg-base-200 w-64 min-h-full flex flex-col" role="navigation" aria-label="Main navigation">
                <!-- Brand -->
                <div class="p-4 border-b border-base-300">
                    <div id="tenant-brand-shell"
                         hx-get="@Url.Action("Shell", "Branding", new { slug })"
                         hx-trigger="load, branding.refresh from:body"
                         hx-swap="innerHTML">
                        <span class="text-xl font-bold">@(TenantContext.TenantName ?? "saas")</span>
                    </div>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 p-4">
                    <ul class="menu menu-md gap-1">
                        <li>
                            <swap-nav to="/@slug" class="@(controller == "Dashboard" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                Dashboard
                            </swap-nav>
                        </li>
                        @* ── App modules (customize this section) ──────── *@
                        @if (brandingEnabled && CurrentUser.HasPermission("branding.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/branding" class="@(controller == "Branding" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h10" />
                                </svg>
                                Branding
                            </swap-nav>
                        </li>
                        }
                        @if (bookingsEnabled && CurrentUser.HasPermission("bookings.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/bookings" class="@(controller == "Booking" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V9m-7-4h6m0 0v6m0-6L10 14" />
                                </svg>
                                Bookings
                            </swap-nav>
                        </li>
                        }
                        @if (clientsEnabled && CurrentUser.HasPermission("clients.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/clients" class="@(controller == "Client" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5V4H2v16h5m10 0v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2m10 0H7m8-10a4 4 0 11-8 0 4 4 0 018 0z" />
                                </svg>
                                Clients
                            </swap-nav>
                        </li>
                        }
                        @if (inventoryEnabled && CurrentUser.HasPermission("inventory.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/inventory" class="@(controller == "Inventory" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V7a2 2 0 00-2-2h-3V3H9v2H6a2 2 0 00-2 2v6m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0H4m4-3h8" />
                                </svg>
                                Inventory
                            </swap-nav>
                        </li>
                        }
                        @if (quotesEnabled && CurrentUser.HasPermission("quotes.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/quotes" class="@(controller == "Quote" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 5h10a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2z" />
                                </svg>
                                Quotes
                            </swap-nav>
                        </li>
                        }
                        @if (rateCardsEnabled && CurrentUser.HasPermission("ratecards.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/rate-cards" class="@(controller == "RateCard" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
                                </svg>
                                Rate Cards
                            </swap-nav>
                        </li>
                        }
                        @if (settingsEnabled && CurrentUser.HasPermission("masterdata.read"))
                        {
                        <li>
                            <swap-nav to="/@slug/settings" class="@(controller == "Settings" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Settings
                            </swap-nav>
                        </li>
                        }
                        @* ── End app modules ──────────────────────────── *@
                        <li class="menu-title mt-2"><span>Account</span></li>
                        <li>
                            <swap-nav to="/@slug/Profile" class="@(controller == "Profile" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                Profile & 2FA
                            </swap-nav>
                        </li>
                        <li>
                            <swap-nav to="/@slug/profile/sessions" class="@(controller == "Session" ? "active" : "")" onclick="document.getElementById('mobile-drawer').checked=false">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                Sessions
                            </swap-nav>
                        </li>
                    </ul>
                </nav>

                <!-- Admin link -->
                <has-permission name="users.read">
                <div class="px-4 pb-2">
                    <a href="/@slug/admin/users"
                       class="btn btn-sm btn-outline w-full gap-2 @(controller == "TenantAdmin" || controller == "TenantBilling" ? "btn-active" : "")">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Admin
                    </a>
                </div>
                </has-permission>

                <!-- Footer -->
                <div class="p-4 border-t border-base-300 space-y-2">
                    <form method="post" action="/@slug/logout">
                        <button type="submit" class="btn btn-ghost btn-sm w-full justify-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            Sign Out
                        </button>
                    </form>
                </div>
            </aside>
        </div>
    </div>

    <!-- Toast container (screen reader announcements) -->
    <div id="toast-container" class="toast toast-end" aria-live="polite" aria-atomic="true" role="status"></div>

    <!-- Modal container -->
    <div id="modal-container" role="dialog" aria-modal="true" aria-hidden="true"></div>

    <!-- Scripts -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
    <script src="/js/bundle.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
