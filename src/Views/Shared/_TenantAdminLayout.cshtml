@inject saas.Shared.ITenantContext TenantContext
@inject saas.Shared.IFeatureService FeatureService 
@{
    var slug = TenantContext.Slug;
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var customRolesEnabled = await FeatureService.IsEnabledAsync("custom_roles");
    var auditLogEnabled = await FeatureService.IsEnabledAsync("audit_log");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - @(TenantContext.TenantName ?? "saas")</title>

    <!-- DaisyUI + Tailwind CSS -->
    <link rel="stylesheet" href="/css/styles.css" asp-append-version="true" />

    <!-- Swap.Htmx CSS -->
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-base-100 text-base-content">
    <script src="/js/theme.js"></script>
    <!-- Drawer for mobile menu -->
    <div class="drawer lg:drawer-open">
        <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col">
            <!-- Navbar (mobile) -->
            <div class="navbar bg-base-100 border-b border-base-300 lg:hidden">
                <div class="flex-none">
                    <label for="mobile-drawer" class="btn btn-square btn-ghost drawer-button">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </label>
                </div>
                <div class="flex-1">
                    <span class="text-xl font-bold">Administration</span>
                </div>
            </div>

            <!-- Breadcrumb -->
            <div class="px-4 md:px-6 pt-4">
                <div class="text-sm breadcrumbs">
                    <ul>
                        <li><a href="/@slug">@(TenantContext.TenantName ?? "App")</a></li>
                        <li><a href="/@slug/TenantAdmin/Users">Admin</a></li>
                        @if (ViewData["Breadcrumb"] is not null)
                        {
                            <li>@ViewData["Breadcrumb"]</li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Main Content -->
            <main class="flex-1 p-4 md:p-6 overflow-auto" id="main-content">
                @RenderBody()
            </main>
        </div>

        <!-- Sidebar -->
        <div class="drawer-side z-40">
            <label for="mobile-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <aside class="bg-base-200 w-64 min-h-full flex flex-col">
                <!-- Brand -->
                <div class="p-4 border-b border-base-300">
                    <span class="text-lg font-bold">⚙️ Administration</span>
                    <p class="text-xs opacity-60 mt-1">@(TenantContext.TenantName ?? "saas")</p>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 p-4">
                    <ul class="menu menu-md gap-1">
                        <li class="menu-title"><span>Management</span></li>
                        <li>
                            <swap-nav to="/@slug/TenantAdmin/Users" class="@(action is "Users" or "UserList" or "InviteUser" or "ManageUserRoles" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                                </svg>
                                Users
                            </swap-nav>
                        </li>
                        @if (customRolesEnabled)
                        {
                        <li>
                            <swap-nav to="/@slug/TenantAdmin/Roles" class="@(action is "Roles" or "RoleList" or "RoleDetail" or "CreateRole" or "EditRole" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                </svg>
                                Roles
                            </swap-nav>
                        </li>
                        }
                        <li class="menu-title mt-2"><span>Billing</span></li>
                        <li>
                            <swap-nav to="/@slug/TenantBilling" class="@(controller == "TenantBilling" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                                </svg>
                                Subscription & Billing
                            </swap-nav>
                        </li>
                        @if (auditLogEnabled)
                        {
                        <li class="menu-title mt-2"><span>Monitoring</span></li>
                        <li>
                            <swap-nav to="/@slug/AuditLog" class="@(controller == "AuditLog" ? "active" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                                </svg>
                                Audit Log
                            </swap-nav>
                        </li>
                        }
                    </ul>
                </nav>

                <!-- Back to App -->
                <div class="p-4 border-t border-base-300">
                    <a href="/@slug" class="btn btn-ghost btn-sm w-full justify-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
                        </svg>
                        ← Back to App
                    </a>
                </div>
            </aside>
        </div>
    </div>

    <!-- Modal container -->
    <div id="modal-container"></div>

    <!-- Scripts -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
    <script src="/js/bundle.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
