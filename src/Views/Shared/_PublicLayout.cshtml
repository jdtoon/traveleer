@inject Microsoft.Extensions.Options.IOptions<saas.Shared.SiteSettings> SiteOptions
@{
    var siteName = SiteOptions.Value.Name;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#6366f1" />

    <!-- DaisyUI + Tailwind CSS -->
    <link rel="stylesheet" href="/css/styles.css" asp-append-version="true" />

    <!-- Swap.Htmx CSS -->
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-base-200 text-base-content">
    <script src="/js/theme.js"></script>
    <!-- Skip navigation link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-primary focus:text-primary-content focus:px-4 focus:py-2 focus:rounded">
        Skip to main content
    </a>

    <!-- Mobile slide-in drawer -->
    <div class="drawer">
        <input id="public-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col">
            <!-- Navbar -->
            <header class="navbar bg-base-100 border-b border-base-300 shadow-sm sticky top-0 z-30" role="banner">
                <div class="flex-none lg:hidden">
                    <label for="public-drawer" class="btn btn-square btn-ghost" aria-label="Open navigation menu">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </label>
                </div>
                <div class="flex-1">
                    <a href="/" class="btn btn-ghost text-xl font-bold">@siteName</a>
                </div>
                <nav class="flex-none hidden lg:flex" role="navigation" aria-label="Main navigation">
                    <ul class="menu menu-horizontal gap-1">
                        <li><a href="/pricing">Pricing</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                    <a href="/register" class="btn btn-primary btn-sm ml-2">Get Started</a>
                    <a href="/login-redirect" class="btn btn-ghost btn-sm ml-1">Sign In</a>
                </nav>
                <div class="flex-none gap-2">
                    <label class="swap swap-rotate btn btn-ghost btn-sm btn-circle" aria-label="Toggle dark mode">
                        <input type="checkbox" class="theme-toggle" aria-label="Toggle dark mode" />
                        <svg class="swap-off h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/></svg>
                        <svg class="swap-on h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Z"/></svg>
                    </label>
                    @await RenderSectionAsync("HeaderActions", required: false)
                </div>
            </header>

            <!-- Main Content -->
            <main class="flex-1" id="main-content" role="main" aria-label="Main content">
                @RenderBody()
            </main>
        </div>

        <!-- Mobile drawer sidebar -->
        <div class="drawer-side z-40">
            <label for="public-drawer" aria-label="Close menu" class="drawer-overlay"></label>
            <aside class="bg-base-200 w-72 min-h-full flex flex-col" role="navigation" aria-label="Mobile navigation">
                <div class="p-4 border-b border-base-300">
                    <a href="/" class="text-xl font-bold" onclick="document.getElementById('public-drawer').checked=false">@siteName</a>
                </div>
                <nav class="flex-1 p-4">
                    <ul class="menu menu-md gap-1">
                        <li><a href="/pricing" onclick="document.getElementById('public-drawer').checked=false">Pricing</a></li>
                        <li><a href="/about" onclick="document.getElementById('public-drawer').checked=false">About</a></li>
                        <li><a href="/contact" onclick="document.getElementById('public-drawer').checked=false">Contact</a></li>
                    </ul>
                </nav>
                <div class="p-4 border-t border-base-300 space-y-2">
                    <a href="/register" class="btn btn-primary btn-sm w-full" onclick="document.getElementById('public-drawer').checked=false">Get Started</a>
                    <a href="/login-redirect" class="btn btn-ghost btn-sm w-full" onclick="document.getElementById('public-drawer').checked=false">Sign In</a>
                </div>
            </aside>
        </div>
    </div>

    <!-- Toast container -->
    <div id="toast-container" class="toast toast-end" aria-live="polite" aria-atomic="true" role="status"></div>

    <!-- Modal container -->
    <div id="modal-container" role="dialog" aria-modal="true" aria-hidden="true"></div>

    <!-- Scripts -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
    <script src="/js/bundle.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
