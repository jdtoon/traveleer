# Force LF line endings for shell scripts (critical for Docker Linux containers)
*.sh text eol=lf
litestream-wrapper.sh text eol=lf

# Dockerfile should also use LF
Dockerfile text eol=lf

# YAML configs
*.yml text eol=lf
*.yaml text eol=lf

# =============================================================================
# Merge strategies for upstream framework pulls
# =============================================================================
# Program.cs has framework + app module sections — union merge avoids conflicts
# when both sides add modules to their respective sections
src/Program.cs merge=union

# Local settings should never be overwritten by upstream
src/appsettings.local.json merge=ours

# App modules are project-specific — upstream never touches these
src/Modules/Notes/** merge=ours
