## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# Database files
*.db
*.db-shm
*.db-wal

# Library Manager (libman)
src/wwwroot/lib/

# Local file uploads (when R2 not configured)
src/wwwroot/uploads/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files (contain secrets!)
.env
.env.local
.env.production

# Docker

# Ignore SQLite database files in docker volumes but not source code
docker-data/
*.db
*.db-shm
*.db-wal

examples/
keys/
Generated/
test-publish/